---
import type { Page } from 'astro';
import { Icon } from 'astro-icon/components';

type Props = Page;
const page = Astro.props;
---

<div class="paginator-shell">
	{
		page.url.prev ? (
			<a class="paginator-link prev ui-pressable" href={page.url.prev} aria-label="Go to previous page">
				<Icon name="ri:arrow-left-s-line" class="size-6 fill-current" title="Go to previous page" />
				<span>Previous</span>
			</a>
		) : null
	}
	{
		page.url.next ? (
			<a class="paginator-link next ui-pressable" href={page.url.next} aria-label="Go to next page">
				<span>Next</span>
				<Icon name="ri:arrow-right-s-line" class="size-6 fill-current" title="Go to next page" />
			</a>
		) : null
	}
</div>

<style>
	.paginator-shell {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1.75rem;
	}

	.paginator-link {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		gap: 0.35rem;
		border-radius: var(--radius-button);
		padding: 0.7rem 1rem;
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			box-shadow var(--motion-gentle),
			color var(--motion-gentle);
	}

	.paginator-link:hover,
	.paginator-link:focus-visible {
		color: var(--color-accent);
	}

	.paginator-link.prev {
		justify-self: start;
	}

	.paginator-link.next {
		justify-self: end;
	}

	.paginator-link span {
		font-size: 0.92rem;
	}
</style>
