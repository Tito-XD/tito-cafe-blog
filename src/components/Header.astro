---
import fs from 'node:fs/promises';
import { Icon } from 'astro-icon/components';
import { Hide, SiteDescription, SiteTitle, Socials } from '~/config';
import Nav from './Nav.astro';
import ThemeToggler from './ThemeToggler.astro';

interface Props {
	currentNav?: string;
}
const { currentNav } = Astro.props;

const customLogo = (await fs.stat('./src/assets/logo.png')).isFile();

const socialConfig: Record<string, Record<string, string>> = {
	bilibili: { icon: 'ri:bilibili-fill' },
	dingding: { icon: 'ri:dingding-fill' },
	discord: { icon: 'ri:discord-fill' },
	douban: { icon: 'ri:douban-fill' },
	dribbble: { icon: 'ri:dribbble-fill' },
	facebook: { icon: 'ri:facebook-box-fill' },
	flickr: { icon: 'ri:flickr-fill' },
	github: { icon: 'ri:github-fill' },
	gitlab: { icon: 'ri:gitlab-fill' },
	google: { icon: 'ri:google-fill' },
	instagram: { icon: 'ri:instagram-fill' },
	kakaoTalk: { icon: 'ri:kakao-talk-fill' },
	line: { icon: 'ri:line-fill' },
	linkedin: { icon: 'ri:linkedin-box-fill' },
	mail: { icon: 'ri:mail-fill' },
	mastodon: { icon: 'ri:mastodon-fill' },
	medium: { icon: 'ri:medium-fill' },
	messenger: { icon: 'ri:messenger-fill' },
	miniProgram: { icon: 'ri:mini-program-fill' },
	neteaseCloudMusic: { icon: 'ri:netease-cloud-music-fill' },
	notion: { icon: 'ri:notion-fill' },
	patreon: { icon: 'ri:patreon-fill' },
	paypal: { icon: 'ri:paypal-fill' },
	pinterest: { icon: 'ri:pinterest-fill' },
	playstation: { icon: 'ri:playstation-fill' },
	productHunt: { icon: 'ri:product-hunt-fill' },
	qq: { icon: 'ri:qq-fill' },
	reddit: { icon: 'ri:reddit-fill' },
	rss: { icon: 'ri:rss-fill', label: 'the RSS link' },
	skype: { icon: 'ri:skype-fill' },
	slack: { icon: 'ri:slack-fill' },
	snapchat: { icon: 'ri:snapchat-fill' },
	soundcloud: { icon: 'ri:soundcloud-fill' },
	spotify: { icon: 'ri:spotify-fill' },
	stackOverflow: { icon: 'ri:stack-overflow-fill' },
	steam: { icon: 'ri:steam-fill' },
	switch: { icon: 'ri:switch-fill' },
	telegram: { icon: 'ri:telegram-fill' },
	threads: { icon: 'ri:threads-fill' },
	tiktok: { icon: 'ri:tiktok-fill' },
	trello: { icon: 'ri:trello-fill' },
	tumblr: { icon: 'ri:tumblr-fill' },
	twitch: { icon: 'ri:twitch-fill' },
	x: { icon: 'ri:twitter-x-fill' },
	xiaohongshu: { icon: 'xiaohongshu', label: 'Xiaohongshu' },
	wechat: { icon: 'ri:wechat-fill' },
	weibo: { icon: 'ri:weibo-fill' },
	whatsapp: { icon: 'ri:whatsapp-fill' },
	xbox: { icon: 'ri:xbox-fill' },
	youtube: { icon: 'ri:youtube-fill' },
	zhihu: { icon: 'ri:zhihu-fill' },
};

const socialOrder = ['xiaohongshu', 'x', 'weibo', 'bilibili', 'telegram', 'mail', 'rss'];

const socials: Record<string, string>[] = [];
for (const platform of socialOrder) {
	if (Socials[platform].url && socialConfig[platform]) {
		socials.push({
			platform,
			...Socials[platform],
			...socialConfig[platform],
		});
	}
}
---

<header class="relative grid grid-cols-2 items-start justify-between lg:flex">
	{
		!Hide.includes("logo") ? (
		<a
				transition:persist
				href="/"
				aria-label="go to index"
				class={customLogo ? 'w-[20rem] h-[6rem]' : ' '}
			>
				{customLogo ? (

					<Icon name="logo" title="go to index" class="w-[20rem] h-[6rem]"/>
				) : (
					SiteTitle
				)}
			</a>
		) : (
			<div />
		)
	}
	<button
		transition:persist
		id="menu-btn"
		class="ui-pressable justify-self-end p-2 text-[var(--color-text)] lg:hidden"
		title="open menu"
		aria-label="open menu"
		aria-expanded="false"
		aria-controls="mobile-drawer"
	>
		<Icon name="ri:menu-fill" class="size-8" />
	</button>
	<div id="mobile-drawer" class="mobile-drawer lg:hidden" data-state="closed" aria-hidden="true">
		<button
			id="mobile-drawer-overlay"
			class="mobile-drawer__overlay"
			type="button"
			tabindex="-1"
			aria-label="Close menu"
		/>
		<aside class="mobile-drawer__panel" aria-label="Mobile navigation">
			<div class="mobile-drawer__header">
				<span class="mobile-drawer__eyebrow">Menu</span>
				<button
					id="mobile-drawer-close"
					type="button"
					class="header-icon-link ui-pressable"
					title="close menu"
					aria-label="close menu"
				>
					<Icon name="ri:close-line" />
				</button>
			</div>
			<div class="mobile-menu-surface">
				<Nav currentNav={currentNav} compact />
				<div class="mobile-menu-actions">
					{
						!Hide.includes("search") && (
							<a
								href="/search"
								class="header-icon-link ui-pressable"
								title="Navigate to search page"
								aria-label="Navigate to search page"
							>
								<Icon name="ri:search-2-line" />
							</a>
						)
					}
					{!Hide.includes("themeToggler") && <ThemeToggler />}
				</div>
				{!Hide.includes("siteDescription") && <p class="mobile-menu-description">{SiteDescription}</p>}
				{
					socials.length > 0 && (
						<div class="mobile-menu-socials">
							{socials.map(({ platform, icon, url, label }) => (
								<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
									<Icon name={icon} class="fill-current" title={label ?? platform} />
								</a>
							))}
						</div>
					)
				}
			</div>
		</aside>
	</div>
	<div
		class="col-span-2 hidden flex-col gap-3 text-center lg:flex lg:items-end"
	>
		<div
			class="mb-[2dvh] flex flex-col items-center gap-3 lg:mb-7 lg:flex-row lg:gap-8"
		>
			<Nav currentNav={currentNav} />
			{
				!Hide.includes("search") && (
					<a
						href="/search"
						class="header-icon-link ui-pressable"
						title="Navigate to search page"
						aria-label="Navigate to search page"
					>
						<Icon name="ri:search-2-line" />
					</a>
				)
			}
			{!Hide.includes("themeToggler") && <ThemeToggler />}
		</div>
		<Fragment transition:persist>
			{!Hide.includes("siteDescription") && <div>{SiteDescription}</div>}
			{
				socials.length > 0 && (
					<div class="mt-[2dvh] flex flex-wrap justify-center gap-3 lg:mt-0">
						{socials.map(({ platform, icon, url, label }) => (
							<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
								<Icon name={icon} class="fill-current" title={label ?? platform} />
							</a>
						))}
					</div>
				)
			}
		</Fragment>
	</div>
</header>

<style>
	.header-icon-link,
	.header-social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.header-icon-link {
		height: 2.15rem;
		width: 2.15rem;
		opacity: 0.88;
	}

	.header-social-link {
		height: 2.05rem;
		width: 2.05rem;
		opacity: 0.82;
	}

	.header-icon-link:hover,
	.header-icon-link:focus-visible,
	.header-social-link:hover,
	.header-social-link:focus-visible {
		opacity: 1;
	}

	.mobile-menu-panel {
		padding-top: 0.9rem;
	}

	.mobile-drawer {
		position: fixed;
		inset: 0;
		z-index: 50;
		overflow: hidden;
		visibility: hidden;
		pointer-events: none;
	}

	.mobile-drawer[data-state='open'] {
		visibility: visible;
		pointer-events: auto;
	}

	.mobile-drawer__overlay {
		position: absolute;
		inset: 0;
		border: 0;
		background: rgba(18, 20, 23, 0.32);
		opacity: 0;
		transition: opacity var(--motion-gentle);
	}

	.mobile-drawer__panel {
		position: absolute;
		top: 0;
		right: 0;
		display: grid;
		grid-template-rows: auto minmax(0, 1fr);
		gap: 0.9rem;
		width: min(82vw, 22rem);
		height: 100dvh;
		padding: max(1rem, env(safe-area-inset-top)) 1rem
			max(1rem, env(safe-area-inset-bottom));
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--color-surface) 96%, var(--color-accent-soft) 4%),
				color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-2) 10%)
			);
		box-shadow:
			-1rem 0 2rem rgba(var(--color-shadow-rgb), 0.12),
			inset 1px 0 0 color-mix(in srgb, var(--color-border) 78%, transparent);
		visibility: inherit;
		transform: translate3d(calc(100% + 2rem), 0, 0);
		transition: transform var(--motion-lift);
		will-change: transform;
		overflow: hidden;
	}

	.mobile-drawer[data-state='open'] .mobile-drawer__overlay {
		opacity: 1;
	}

	.mobile-drawer[data-state='open'] .mobile-drawer__panel {
		transform: translateX(0);
	}

	.mobile-drawer__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding-bottom: 0.15rem;
	}

	.mobile-drawer__eyebrow {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.mobile-menu-surface {
		display: grid;
		gap: 0.9rem;
		align-content: start;
		padding: 0.25rem 0 0;
		min-height: 0;
		overflow-y: auto;
		padding-bottom: max(1rem, env(safe-area-inset-bottom));
		-webkit-overflow-scrolling: touch;
	}

	.mobile-menu-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.65rem;
	}

	.mobile-menu-description {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		text-align: left;
		color: var(--color-muted);
	}

	.mobile-menu-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		padding-bottom: 0.15rem;
	}

	@media (max-width: 767px) {
		.mobile-drawer {
			inset: -1rem;
		}

		.mobile-drawer__panel {
			width: min(88vw, 22rem);
			padding-top: calc(1rem + env(safe-area-inset-top));
		}

		#menu-btn {
			padding: 0.65rem;
		}

		#menu-btn :global(svg) {
			width: 1.9rem;
			height: 1.9rem;
		}
	}
</style>

<script>
	const setupMobileDrawer = () => {
		const windowWithCleanup = window as Window & {
			__revampedMenuCleanup?: () => void;
		};
		windowWithCleanup.__revampedMenuCleanup?.();

		const root = document.documentElement;
		const button = document.getElementById('menu-btn');
		const drawer = document.getElementById('mobile-drawer');
		const overlay = document.getElementById('mobile-drawer-overlay');
		const closeButton = document.getElementById('mobile-drawer-close');
		if (!button || !drawer || !overlay || !closeButton) {
			return;
		}

		const closeDrawer = () => {
			drawer.setAttribute('data-state', 'closed');
			drawer.setAttribute('aria-hidden', 'true');
			button.setAttribute('aria-expanded', 'false');
			button.setAttribute('aria-label', 'open menu');
			root.style.removeProperty('overflow');
		};

		const openDrawer = () => {
			drawer.setAttribute('data-state', 'open');
			drawer.setAttribute('aria-hidden', 'false');
			button.setAttribute('aria-expanded', 'true');
			button.setAttribute('aria-label', 'close menu');
			root.style.overflow = 'hidden';
		};

		const toggleDrawer = () => {
			if (window.matchMedia('(min-width: 1024px)').matches) {
				closeDrawer();
				return;
			}
			if (drawer.getAttribute('data-state') === 'open') {
				closeDrawer();
				return;
			}
			openDrawer();
		};

		const handleKeydown = (event: KeyboardEvent) => {
			if (event.key === 'Escape') {
				closeDrawer();
			}
		};

		const handleResize = () => {
			if (window.matchMedia('(min-width: 1024px)').matches) {
				closeDrawer();
			}
		};

		button.addEventListener('click', toggleDrawer);
		overlay.addEventListener('click', closeDrawer);
		closeButton.addEventListener('click', closeDrawer);
		drawer.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeDrawer));
		document.addEventListener('keydown', handleKeydown);
		window.addEventListener('resize', handleResize);

		windowWithCleanup.__revampedMenuCleanup = () => {
			closeDrawer();
			button.removeEventListener('click', toggleDrawer);
			overlay.removeEventListener('click', closeDrawer);
			closeButton.removeEventListener('click', closeDrawer);
			drawer.querySelectorAll('a').forEach((link) => link.removeEventListener('click', closeDrawer));
			document.removeEventListener('keydown', handleKeydown);
			window.removeEventListener('resize', handleResize);
		};
	};

	setupMobileDrawer();
	document.addEventListener('astro:page-load', setupMobileDrawer);
</script>
