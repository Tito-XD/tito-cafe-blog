---
import { Icon } from 'astro-icon/components';
import { Hide, SiteDescription, SiteTitle, Socials } from '~/config';
import Nav from './Nav.astro';
import ThemeToggler from './ThemeToggler.astro';

interface Props {
	currentNav?: string;
}
const { currentNav } = Astro.props;

const socialConfig: Record<string, Record<string, string>> = {
	bilibili: { icon: 'ri:bilibili-fill' },
	dingding: { icon: 'ri:dingding-fill' },
	discord: { icon: 'ri:discord-fill' },
	douban: { icon: 'ri:douban-fill' },
	dribbble: { icon: 'ri:dribbble-fill' },
	facebook: { icon: 'ri:facebook-box-fill' },
	flickr: { icon: 'ri:flickr-fill' },
	github: { icon: 'ri:github-fill' },
	gitlab: { icon: 'ri:gitlab-fill' },
	google: { icon: 'ri:google-fill' },
	instagram: { icon: 'ri:instagram-fill' },
	kakaoTalk: { icon: 'ri:kakao-talk-fill' },
	line: { icon: 'ri:line-fill' },
	linkedin: { icon: 'ri:linkedin-box-fill' },
	mail: { icon: 'ri:mail-fill' },
	mastodon: { icon: 'ri:mastodon-fill' },
	medium: { icon: 'ri:medium-fill' },
	messenger: { icon: 'ri:messenger-fill' },
	miniProgram: { icon: 'ri:mini-program-fill' },
	neteaseCloudMusic: { icon: 'ri:netease-cloud-music-fill' },
	notion: { icon: 'ri:notion-fill' },
	patreon: { icon: 'ri:patreon-fill' },
	paypal: { icon: 'ri:paypal-fill' },
	pinterest: { icon: 'ri:pinterest-fill' },
	playstation: { icon: 'ri:playstation-fill' },
	productHunt: { icon: 'ri:product-hunt-fill' },
	qq: { icon: 'ri:qq-fill' },
	reddit: { icon: 'ri:reddit-fill' },
	rss: { icon: 'ri:rss-fill', label: 'the RSS link' },
	skype: { icon: 'ri:skype-fill' },
	slack: { icon: 'ri:slack-fill' },
	snapchat: { icon: 'ri:snapchat-fill' },
	soundcloud: { icon: 'ri:soundcloud-fill' },
	spotify: { icon: 'ri:spotify-fill' },
	stackOverflow: { icon: 'ri:stack-overflow-fill' },
	steam: { icon: 'ri:steam-fill' },
	switch: { icon: 'ri:switch-fill' },
	telegram: { icon: 'ri:telegram-fill' },
	threads: { icon: 'ri:threads-fill' },
	tiktok: { icon: 'ri:tiktok-fill' },
	trello: { icon: 'ri:trello-fill' },
	tumblr: { icon: 'ri:tumblr-fill' },
	twitch: { icon: 'ri:twitch-fill' },
	x: { icon: 'ri:twitter-x-fill' },
	xiaohongshu: { icon: 'xiaohongshu', label: 'Xiaohongshu' },
	wechat: { icon: 'ri:wechat-fill' },
	weibo: { icon: 'ri:weibo-fill' },
	whatsapp: { icon: 'ri:whatsapp-fill' },
	xbox: { icon: 'ri:xbox-fill' },
	youtube: { icon: 'ri:youtube-fill' },
	zhihu: { icon: 'ri:zhihu-fill' },
};

const socialOrder = ['xiaohongshu', 'x', 'weibo', 'bilibili', 'telegram', 'mail', 'rss'];

const socials: Record<string, string>[] = [];
for (const platform of socialOrder) {
	if (Socials[platform]?.url && socialConfig[platform]) {
		socials.push({
			platform,
			...Socials[platform],
			...socialConfig[platform],
		});
	}
}
---

<header class="relative grid grid-cols-2 items-start justify-between lg:flex">
	{
		!Hide.includes('logo') ? (
			<a transition:persist href="/" aria-label="go to index" class="site-logo-link">
				<img src="/sample/logo.svg" alt={SiteTitle} class="site-logo-mark" />
				<span class="sr-only">{SiteTitle}</span>
			</a>
		) : (
			<div />
		)
	}
	<button
		transition:persist
		id="menu-btn"
		class="ui-pressable justify-self-end p-2 text-[var(--color-text)] lg:hidden"
		title="open menu"
		aria-label="open menu"
		aria-expanded="false"
		aria-controls="menu"
	>
		<Icon name="ri:menu-fill" class="size-8" />
	</button>
	<div id="menu" class="mobile-menu-panel col-span-2 hidden lg:hidden">
		<div class="mobile-menu-surface">
			<Nav currentNav={currentNav} compact />
			<div class="mobile-menu-actions">
				{
					!Hide.includes('search') && (
						<a
							href="/search"
							class="header-icon-link ui-pressable"
							title="Navigate to search page"
							aria-label="Navigate to search page"
						>
							<Icon name="ri:search-2-line" />
						</a>
					)
				}
				{!Hide.includes('themeToggler') && <ThemeToggler />}
			</div>
			{!Hide.includes('siteDescription') && <p class="mobile-menu-description">{SiteDescription}</p>}
			{
				socials.length > 0 && (
					<div class="mobile-menu-socials">
						{socials.map(({ platform, icon, url, label }) => (
							<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
								<Icon name={icon} class="fill-current" title={label ?? platform} />
							</a>
						))}
					</div>
				)
			}
		</div>
	</div>
	<div class="col-span-2 hidden flex-col gap-3 text-center lg:flex lg:items-end">
		<div class="mb-[2dvh] flex flex-col items-center gap-3 lg:mb-7 lg:flex-row lg:gap-8">
			<Nav currentNav={currentNav} />
			{
				!Hide.includes('search') && (
					<a
						href="/search"
						class="header-icon-link ui-pressable"
						title="Navigate to search page"
						aria-label="Navigate to search page"
					>
						<Icon name="ri:search-2-line" />
					</a>
				)
			}
			{!Hide.includes('themeToggler') && <ThemeToggler />}
		</div>
		<Fragment transition:persist>
			{!Hide.includes('siteDescription') && <div>{SiteDescription}</div>}
			{
				socials.length > 0 && (
					<div class="mt-[2dvh] flex flex-wrap justify-center gap-3 lg:mt-0">
						{socials.map(({ platform, icon, url, label }) => (
							<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
								<Icon name={icon} class="fill-current" title={label ?? platform} />
							</a>
						))}
					</div>
				)
			}
		</Fragment>
	</div>
</header>

<style>
	.site-logo-link {
		display: inline-flex;
		width: min(100%, 20rem);
		align-items: center;
	}

	.site-logo-mark {
		width: 100%;
		height: auto;
	}

	.header-icon-link,
	.header-social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.header-icon-link {
		height: 2.15rem;
		width: 2.15rem;
		opacity: 0.88;
	}

	.header-social-link {
		height: 2.05rem;
		width: 2.05rem;
		opacity: 0.82;
	}

	.header-icon-link:hover,
	.header-icon-link:focus-visible,
	.header-social-link:hover,
	.header-social-link:focus-visible {
		opacity: 1;
	}

	.mobile-menu-panel {
		padding-top: 0.9rem;
	}

	.mobile-menu-surface {
		display: grid;
		gap: 0.9rem;
		border-radius: calc(var(--radius-card) - 0.1rem);
		background: color-mix(in srgb, var(--color-surface) 94%, var(--color-accent-soft) 6%);
		padding: 0.95rem;
		box-shadow:
			0 0.9rem 2rem rgba(var(--color-shadow-rgb), 0.1),
			inset 0 1px 0 color-mix(in srgb, var(--color-surface) 82%, transparent);
	}

	.mobile-menu-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.65rem;
	}

	.mobile-menu-description {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		text-align: left;
		color: var(--color-muted);
	}

	.mobile-menu-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	@media (max-width: 767px) {
		#menu-btn {
			padding: 0.65rem;
		}

		#menu-btn :global(svg) {
			width: 1.9rem;
			height: 1.9rem;
		}
	}
</style>

<script>
	const toggleMenu = (document: Document) => {
		if (window.matchMedia('(min-width: 1024px)').matches) {
			return;
		}
		const btn = document.getElementById('menu-btn');
		const menu = document.getElementById('menu');
		btn?.addEventListener('click', () => {
			const menuExpanded = btn.getAttribute('aria-expanded') === 'true';
			btn.setAttribute('aria-expanded', menuExpanded ? 'false' : 'true');
			btn.setAttribute('aria-label', menuExpanded ? 'close menu' : 'open menu');
			menu?.classList.toggle('hidden');
		});
		if (btn && menu) {
			menu.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', () => {
					btn.setAttribute('aria-expanded', 'false');
					btn.setAttribute('aria-label', 'open menu');
					menu.classList.add('hidden');
				});
			});
		}
	};
	toggleMenu(document);
	document.addEventListener('astro:before-swap', (e) => toggleMenu(e.newDocument));
</script>
