---
import fs from 'node:fs/promises';
import { Icon } from 'astro-icon/components';
import { Hide, SiteDescription, SiteTitle, Socials } from '~/config';
import { socialConfig, socialOrder } from '~/data/socials';
import Nav from './Nav.astro';
import ThemeToggler from './ThemeToggler.astro';

interface Props {
	currentNav?: string;
}
const { currentNav } = Astro.props;

const customLogo = (await fs.stat('./src/assets/logo.png')).isFile();

const socials: Record<string, string>[] = [];
for (const platform of socialOrder) {
	if (Socials[platform].url && socialConfig[platform]) {
		socials.push({
			platform,
			...Socials[platform],
			...socialConfig[platform],
		});
	}
}
---

<header class="relative grid grid-cols-2 items-start justify-between lg:flex">
	{
		!Hide.includes("logo") ? (
		<a
				transition:persist
				href="/"
				aria-label="go to index"
				class={customLogo ? 'w-[20rem] h-[6rem]' : ' '}
			>
				{customLogo ? (

					<Icon name="logo" title="go to index" class="w-[20rem] h-[6rem]"/>
				) : (
					SiteTitle
				)}
			</a>
		) : (
			<div />
		)
	}
	<button
		transition:persist
		id="menu-btn"
		class="mobile-menu-trigger ui-pressable justify-self-end lg:hidden"
		title="open menu"
		aria-label="open menu"
		aria-expanded="false"
		aria-controls="mobile-drawer"
	>
		<Icon name="ri:apps-2-line" class="mobile-menu-trigger__icon" />
	</button>
	<div id="mobile-drawer" class="mobile-drawer lg:hidden" data-state="closed" aria-hidden="true">
		<aside class="mobile-drawer__panel" aria-label="Mobile navigation">
			<div class="mobile-drawer__header">
				<span class="mobile-drawer__eyebrow">Menu</span>
				<button
					id="mobile-drawer-close"
					type="button"
					class="header-icon-link ui-pressable"
					title="close menu"
					aria-label="close menu"
				>
					<Icon name="ri:close-line" />
				</button>
			</div>
			<div class="mobile-menu-surface">
				<Nav currentNav={currentNav} compact />
				<div class="mobile-menu-actions">
					{
						!Hide.includes("search") && (
							<a
								href="/search"
								class="header-icon-link ui-pressable"
								title="Navigate to search page"
								aria-label="Navigate to search page"
							>
								<Icon name="ri:search-2-line" />
							</a>
						)
					}
					{!Hide.includes("themeToggler") && <ThemeToggler />}
				</div>
				{!Hide.includes("siteDescription") && <p class="mobile-menu-description">{SiteDescription}</p>}
				{
					socials.length > 0 && (
						<div class="mobile-menu-socials">
							{socials.map(({ platform, icon, url, label }) => (
								<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
									<Icon name={icon} class="fill-current" title={label ?? platform} />
								</a>
							))}
						</div>
					)
				}
			</div>
		</aside>
	</div>
	<div
		class="col-span-2 hidden flex-col gap-3 text-center lg:flex lg:items-end"
	>
		<div
			class="mb-[2dvh] flex flex-col items-center gap-3 lg:mb-7 lg:flex-row lg:gap-8"
		>
			<Nav currentNav={currentNav} />
			{
				!Hide.includes("search") && (
					<a
						href="/search"
						class="header-icon-link ui-pressable"
						title="Navigate to search page"
						aria-label="Navigate to search page"
					>
						<Icon name="ri:search-2-line" />
					</a>
				)
			}
			{!Hide.includes("themeToggler") && <ThemeToggler />}
		</div>
		<Fragment transition:persist>
			{!Hide.includes("siteDescription") && <div>{SiteDescription}</div>}
			{
				socials.length > 0 && (
					<div class="mt-[2dvh] flex flex-wrap justify-center gap-3 lg:mt-0">
						{socials.map(({ platform, icon, url, label }) => (
							<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
								<Icon name={icon} class="fill-current" title={label ?? platform} />
							</a>
						))}
					</div>
				)
			}
		</Fragment>
	</div>
</header>

<style>
	.header-icon-link,
	.header-social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.header-icon-link {
		height: 2.15rem;
		width: 2.15rem;
		opacity: 0.88;
	}

	.header-social-link {
		height: 2.05rem;
		width: 2.05rem;
		opacity: 0.82;
	}

	.header-icon-link:hover,
	.header-icon-link:focus-visible,
	.header-social-link:hover,
	.header-social-link:focus-visible {
		opacity: 1;
	}

	.mobile-menu-panel {
		padding-top: 0.9rem;
	}

	.mobile-drawer {
		position: absolute;
		top: calc(100% + 0.75rem);
		left: 50%;
		z-index: 40;
		width: min(21rem, calc(100vw - 2.5rem), calc(100% - 0.5rem));
		pointer-events: none;
		transform: translateX(-50%);
	}

	.mobile-drawer[data-state='open'] {
		pointer-events: auto;
	}

	.mobile-drawer__panel {
		display: grid;
		grid-template-rows: auto minmax(0, 1fr);
		gap: 0.9rem;
		width: 100%;
		max-height: min(72dvh, calc(100dvh - 7rem));
		padding: 1rem;
		border-radius: 1.35rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 82%, var(--color-accent-soft));
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--color-surface) 96%, var(--color-accent-soft) 4%),
				color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-2) 10%)
			);
		box-shadow:
			0 1.1rem 2.6rem rgba(var(--color-shadow-rgb), 0.16),
			0 0 0 1px rgba(255, 255, 255, 0.04) inset;
		opacity: 0;
		transform: translateY(-0.5rem) scale(0.98);
		transform-origin: top center;
		transition:
			transform var(--motion-lift),
			opacity var(--motion-gentle);
		will-change: transform;
		overflow: hidden;
	}

	.mobile-drawer[data-state='open'] .mobile-drawer__panel {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.mobile-drawer__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding-bottom: 0.15rem;
	}

	.mobile-drawer__eyebrow {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.mobile-menu-surface {
		display: grid;
		gap: 0.9rem;
		align-content: start;
		padding: 0.25rem 0 0;
		min-height: 0;
		overflow-y: auto;
		padding-bottom: 0.35rem;
		-webkit-overflow-scrolling: touch;
	}

	.mobile-menu-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.65rem;
	}

	.mobile-menu-description {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		text-align: left;
		color: var(--color-muted);
	}

	.mobile-menu-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		padding-bottom: 0.15rem;
	}

	.mobile-menu-trigger {
		display: inline-flex;
		height: 3rem;
		width: 3rem;
		align-items: center;
		justify-content: center;
		border-radius: 1rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-soft) 8%);
		color: var(--color-text);
		box-shadow: 0 0.55rem 1.4rem rgba(var(--color-shadow-rgb), 0.08);
		transition:
			transform var(--motion-gentle),
			border-color var(--motion-gentle),
			background var(--motion-gentle),
			box-shadow var(--motion-gentle),
			color var(--motion-gentle);
	}

	.mobile-menu-trigger:hover,
	.mobile-menu-trigger:focus-visible,
	.mobile-menu-trigger[aria-expanded='true'] {
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 86%, var(--color-accent-soft) 14%);
		color: var(--color-accent);
		box-shadow: 0 0.85rem 1.8rem rgba(var(--color-shadow-rgb), 0.14);
	}

	.mobile-menu-trigger__icon {
		width: 1.4rem;
		height: 1.4rem;
	}

	@media (max-width: 767px) {
		.mobile-drawer__panel {
			max-height: min(76dvh, calc(100dvh - 6rem));
		}

		.mobile-drawer {
			width: min(19.5rem, calc(100vw - 2rem), calc(100% - 0.25rem));
		}

		.mobile-menu-trigger {
			height: 2.8rem;
			width: 2.8rem;
		}
	}
</style>

<script>
	const setupMobileDrawer = () => {
		const windowWithCleanup = window as Window & {
			__revampedMenuCleanup?: () => void;
		};
		windowWithCleanup.__revampedMenuCleanup?.();

		const root = document.documentElement;
		const button = document.getElementById('menu-btn');
		const drawer = document.getElementById('mobile-drawer');
		const closeButton = document.getElementById('mobile-drawer-close');
		if (!button || !drawer || !closeButton) {
			return;
		}

		const closeDrawer = () => {
			drawer.setAttribute('data-state', 'closed');
			drawer.setAttribute('aria-hidden', 'true');
			button.setAttribute('aria-expanded', 'false');
			button.setAttribute('aria-label', 'open menu');
			root.style.removeProperty('overflow');
		};

		const openDrawer = () => {
			drawer.setAttribute('data-state', 'open');
			drawer.setAttribute('aria-hidden', 'false');
			button.setAttribute('aria-expanded', 'true');
			button.setAttribute('aria-label', 'close menu');
			root.style.overflow = 'hidden';
		};

		const toggleDrawer = () => {
			if (window.matchMedia('(min-width: 1024px)').matches) {
				closeDrawer();
				return;
			}
			if (drawer.getAttribute('data-state') === 'open') {
				closeDrawer();
				return;
			}
			openDrawer();
		};

		const handleKeydown = (event: KeyboardEvent) => {
			if (event.key === 'Escape') {
				closeDrawer();
			}
		};

		const handlePointerDown = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Node)) {
				return;
			}
			if (drawer.contains(target) || button.contains(target)) {
				return;
			}
			closeDrawer();
		};

		const handleResize = () => {
			if (window.matchMedia('(min-width: 1024px)').matches) {
				closeDrawer();
			}
		};

		button.addEventListener('click', toggleDrawer);
		closeButton.addEventListener('click', closeDrawer);
		drawer.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeDrawer));
		document.addEventListener('mousedown', handlePointerDown);
		document.addEventListener('keydown', handleKeydown);
		window.addEventListener('resize', handleResize);

		windowWithCleanup.__revampedMenuCleanup = () => {
			closeDrawer();
			button.removeEventListener('click', toggleDrawer);
			closeButton.removeEventListener('click', closeDrawer);
			drawer.querySelectorAll('a').forEach((link) => link.removeEventListener('click', closeDrawer));
			document.removeEventListener('mousedown', handlePointerDown);
			document.removeEventListener('keydown', handleKeydown);
			window.removeEventListener('resize', handleResize);
		};
	};

	setupMobileDrawer();
	document.addEventListener('astro:page-load', setupMobileDrawer);
</script>
