---
interface Props {
	active: 'blog' | 'tags' | 'timeline';
	className?: string;
}

const { active, className } = Astro.props;

const items = [
	{ id: 'blog', label: 'Blog', href: '/blog' },
	{ id: 'tags', label: 'Tags', href: '/tags' },
	{ id: 'timeline', label: 'Timeline', href: '/archives' },
] as const;
---

<nav class:list={['blog-section-tabs', className]} aria-label="Blog sections">
	{
		items.map((item) => (
			<a
				href={item.href}
				class="blog-section-tab ui-pressable"
				aria-current={active === item.id ? 'page' : undefined}
			>
				{item.label}
			</a>
		))
	}
</nav>

<style>
	.blog-section-tabs {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.blog-section-tab {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: calc(var(--radius-chip) + 0.1rem);
		padding: 0.58rem 0.95rem;
		background: color-mix(in srgb, var(--color-surface) 88%, var(--color-surface-2) 12%);
		color: var(--color-muted);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.blog-section-tab:hover,
	.blog-section-tab:focus-visible {
		color: var(--color-text);
		background: color-mix(in srgb, var(--color-surface) 80%, var(--color-surface-2) 20%);
	}

	.blog-section-tab[aria-current='page'] {
		color: var(--color-accent);
		background: color-mix(in srgb, var(--color-surface) 76%, var(--color-surface-2) 24%);
	}

	@media (max-width: 640px) {
		.blog-section-tab {
			padding: 0.5rem 0.82rem;
			font-size: 0.95rem;
		}
	}
</style>
