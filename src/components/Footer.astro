---
import { FooterDescription, Hide } from '~/config';
---

<footer class="site-footer" transition:persist>
	{!Hide.includes('footerDescription') && <p class="site-footer__tagline">{FooterDescription}</p>}
	<p class="site-footer__copyright">
		&copy; {new Date().getFullYear()} Tito_XD. Powered by <a
			class="site-footer__link"
			href="https://astro.build"
			target="_blank"
			rel="noopener"
			aria-label="Read more about Astro">Astro</a
		> and <a
			class="site-footer__link"
			href="https://github.com/ladit/astro-blog-zozo"
			target="_blank"
			rel="noopener"
			aria-label="Read more about this theme">Zozo</a
		>.
	</p>
</footer>

<style>
	.site-footer {
		margin-top: clamp(2rem, 4vw, 3.5rem);
		padding-top: clamp(1.25rem, 3vw, 2rem);
		border-top: 1px solid color-mix(
			in srgb,
			var(--color-border) 82%,
			var(--color-accent-soft)
		);
		text-align: center;
		color: var(--color-muted);
	}

	.site-footer__tagline {
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
		letter-spacing: 0.01em;
		color: color-mix(in srgb, var(--color-muted) 84%, var(--color-text));
	}

	.site-footer__copyright {
		margin: 0;
		font-size: 0.95rem;
		opacity: 0.9;
	}

	.site-footer__link {
		color: var(--color-accent);
		text-decoration: underline;
		text-decoration-color: color-mix(
			in srgb,
			var(--color-accent) 64%,
			transparent
		);
		text-underline-offset: 0.2em;
	}

	.site-footer__link:hover,
	.site-footer__link:focus-visible {
		color: color-mix(in srgb, var(--color-accent) 82%, var(--color-text));
	}
</style>