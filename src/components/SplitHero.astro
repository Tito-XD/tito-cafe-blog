---
interface Props {
	title: string;
	className?: string;
}

const { title, className } = Astro.props;
---

<section class:list={['split-hero', className]}>
	<div class="split-hero__art">
		<slot name="art" />
	</div>
	<div class="split-hero__copy">
		<h1 class="split-hero__title">{title}</h1>
		<div class="split-hero__body">
			<slot />
		</div>
	</div>
</section>

<style>
	.split-hero {
		display: grid;
		gap: 1.15rem;
		align-items: center;
		width: min(100%, 58rem);
		margin: 0 auto;
		padding: clamp(1rem, 4vh, 2.5rem) 0 clamp(0.5rem, 2vh, 1rem);
	}

	.split-hero__art {
		max-width: min(100%, 21rem);
		justify-self: center;
	}

	.split-hero__copy {
		display: grid;
		gap: 0.95rem;
		max-width: 39rem;
	}

	.split-hero__title {
		margin: 0;
		font-size: clamp(2rem, 4.2vw, 3rem);
		font-weight: 800;
		line-height: 1.12;
		letter-spacing: -0.02em;
		text-wrap: balance;
		white-space: pre-line;
	}

	.split-hero__body {
		display: grid;
		gap: 0.85rem;
	}

	.split-hero__body :global(p) {
		margin: 0;
		font-size: 1rem;
		line-height: 1.9;
		color: color-mix(in srgb, var(--color-text) 92%, var(--color-muted));
		text-wrap: pretty;
	}

	@media (min-width: 1024px) {
		.split-hero {
			grid-template-columns: minmax(15rem, 21rem) minmax(0, 1fr);
			gap: 1.75rem;
		}

		.split-hero__art {
			justify-self: center;
		}
	}
</style>
