---
import { Icon } from 'astro-icon/components';
import { Hide } from '~/config';
import ThemeToggler from './ThemeToggler.astro';

interface Props {
	mobile?: boolean;
}

const { mobile = false } = Astro.props;
const showSearch = !Hide.includes('search');
const showThemeToggler = !Hide.includes('themeToggler');
---

{
	(showSearch || showThemeToggler) && (
		<div class:list={['header-actions', mobile && 'header-actions--mobile']}>
			{
				showSearch && (
					<a
						href="/search"
						class="header-icon-link ui-pressable"
						title="Navigate to search page"
						aria-label="Navigate to search page"
					>
						<Icon name="ri:search-2-line" />
					</a>
				)
			}
			{showThemeToggler && <ThemeToggler />}
		</div>
	)
}

<style>
	.header-actions {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
	}

	.header-actions--mobile {
		justify-content: flex-end;
	}

	.header-icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.15rem;
		width: 2.15rem;
		color: var(--color-text);
		text-decoration: none;
		opacity: 0.88;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.header-icon-link:hover,
	.header-icon-link:focus-visible {
		opacity: 1;
	}
</style>
