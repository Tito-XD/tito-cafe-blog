---
import { Icon } from 'astro-icon/components';
---

<button
	transition:persist
	id="back-to-top"
	class="back-to-top hidden"
	title="Back to top"
	aria-label="Back to top"
>
	<Icon name="ri:arrow-up-double-fill" class="size-8 self-center fill-current" />
</button>

<style>
	.back-to-top {
		position: fixed;
		right: 1.5rem;
		bottom: 1.5rem;
		display: grid;
		height: 2.75rem;
		width: 2.75rem;
		place-content: center;
		border-radius: var(--radius-button);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 84%, var(--color-accent-soft));
		color: var(--color-text);
		opacity: 0.68;
		backdrop-filter: blur(12px);
		box-shadow: 0 0.75rem 1.5rem rgba(var(--color-shadow-rgb), 0.16);
		transition:
			transform var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			border-color var(--motion-gentle);
	}

	.back-to-top:hover,
	.back-to-top:focus-visible {
		opacity: 1;
		color: var(--color-accent);
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 54%, var(--color-border));
	}
</style>

<script>
	const setupBackToTop = () => {
		const windowWithCleanup = window as Window & {
			__revampedBackToTopCleanup?: () => void;
		};
		windowWithCleanup.__revampedBackToTopCleanup?.();

		const button = document.getElementById('back-to-top');
		if (!button) {
			return;
		}

		const updateVisibility = () => {
			const scrolled = window.scrollY >= 24;
			button.classList.toggle('hidden', !scrolled);
			button.classList.toggle('grid', scrolled);
		};

		const scrollToTop = () => {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		};

		button.addEventListener('click', scrollToTop);
		window.addEventListener('scroll', updateVisibility, { passive: true });
		window.addEventListener('resize', updateVisibility);
		updateVisibility();

		windowWithCleanup.__revampedBackToTopCleanup = () => {
			button.removeEventListener('click', scrollToTop);
			window.removeEventListener('scroll', updateVisibility);
			window.removeEventListener('resize', updateVisibility);
		};
	};

	setupBackToTop();
	document.addEventListener('astro:page-load', setupBackToTop);
</script>
