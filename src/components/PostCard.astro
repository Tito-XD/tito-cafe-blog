---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getPostRouteSlug } from '~/utils/collection';

type Props = CollectionEntry<'posts'>;
const post = Astro.props;
let date = post.data.lastmod;
if (post.data.hide?.includes('lastmod') && post.data.date) {
	date = post.data.date;
	if (post.data.hide?.includes('date')) {
		date = undefined;
	}
}
const postSlug = getPostRouteSlug(post);
---

<div class="my-5 flex flex-col gap-4 xl:flex-row">
	<div class="flex-col gap-4">
		<h2 class="text-4xl">
			<a href={`/posts/${postSlug}`} aria-label={`Read post: ${post.data.title}`}>
				{post.data.title}
			</a>
		</h2>
		<p class="text-lg text-[var(--color-text)]">{post.data.description}</p>
		<div class="text-[var(--color-muted)]">
			{
				date && (
					<time class="mr-5" datetime={date.toISOString()}>
						{date.toLocaleDateString()}
					</time>
				)
			}
			{
				(!post.data.hide || !post.data.hide.includes('tags')) &&
					post.data.tags?.map((tag) => (
						<a
							class="mr-2 hover:text-[var(--color-accent)]"
							href={`/tags/${tag}/1`}
							aria-label={`More posts of tag ${tag}`}
						>
							{tag}
						</a>
					))
			}
		</div>
	</div>
	{
		post.data.image && (
			<Picture
				class="mr-4 max-w-full rounded-lg border border-[color:var(--color-border)] xl:max-w-sm"
				src={post.data.image}
				formats={['avif', 'webp']}
				alt={`hero image for ${post.data.title}`}
			/>
		)
	}
</div>
<hr class="border-[color:var(--color-border)]" />
