---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getPostRouteSlug } from '~/utils/collection';

type Props = CollectionEntry<'posts'>;
const post = Astro.props;
let date = post.data.lastmod;
if (post.data.hide?.includes('lastmod') && post.data.date) {
	date = post.data.date;
	if (post.data.hide?.includes('date')) {
		date = undefined;
	}
}
const postSlug = getPostRouteSlug(post);
---

<article class="post-card-shell">
	<div class="post-card-copy">
		<h2 class="post-card-title">
			<a class="post-card-link" href={`/posts/${postSlug}`} aria-label={`Read post: ${post.data.title}`}>
				{post.data.title}
			</a>
		</h2>
		<p class="post-card-description">{post.data.description}</p>
		<div class="post-card-meta">
			{
				date && (
					<time class="post-card-date" datetime={date.toISOString()}>
						{date.toLocaleDateString()}
					</time>
				)
			}
			{
				(!post.data.hide || !post.data.hide.includes('tags')) &&
					post.data.tags?.map((tag) => (
						<a
							class="post-card-tag"
							href={`/tags/${tag}/1`}
							aria-label={`More posts of tag ${tag}`}
						>
							{tag}
						</a>
					))
			}
		</div>
	</div>
	{
		post.data.image && (
			<Picture
				class="post-card-image"
				src={post.data.image}
				formats={['avif', 'webp']}
				alt={`hero image for ${post.data.title}`}
			/>
		)
	}
	</article>
<hr class="border-[color:var(--color-border)]" />

<style>
	.post-card-shell {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin: 1.4rem 0;
		border-radius: 1.45rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--color-surface) 96%, var(--color-accent-soft) 4%),
				color-mix(in srgb, var(--color-surface) 94%, var(--color-surface-2) 6%)
			);
		padding: 1.2rem;
		box-shadow: 0 0.7rem 1.8rem rgba(var(--color-shadow-rgb), 0.08);
		transition:
			transform 320ms ease,
			border-color 320ms ease,
			box-shadow 320ms ease,
			background 320ms ease;
	}

	.post-card-shell:hover,
	.post-card-shell:focus-within {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		box-shadow: 0 1rem 2.1rem rgba(var(--color-shadow-rgb), 0.14);
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--color-surface) 90%, var(--color-accent-soft) 10%),
				color-mix(in srgb, var(--color-surface) 92%, var(--color-surface-2) 8%)
			);
	}

	.post-card-copy {
		display: grid;
		gap: 0.9rem;
		min-width: 0;
	}

	.post-card-title {
		margin: 0;
		font-size: clamp(2rem, 4vw, 2.7rem);
		line-height: 1.02;
	}

	.post-card-link {
		color: inherit;
		text-decoration: none;
	}

	.post-card-shell:hover .post-card-link,
	.post-card-shell:focus-within .post-card-link {
		color: var(--color-accent);
	}

	.post-card-description {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.8;
		color: var(--color-text);
	}

	.post-card-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		align-items: center;
		color: var(--color-muted);
	}

	.post-card-date {
		margin-right: 0.35rem;
	}

	.post-card-tag {
		display: inline-flex;
		align-items: center;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-soft) 8%);
		padding: 0.3rem 0.7rem;
		color: var(--color-muted);
		text-decoration: none;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			background 220ms ease,
			color 220ms ease;
	}

	.post-card-tag:hover,
	.post-card-tag:focus-visible {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 56%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 84%, var(--color-accent-soft) 16%);
		color: var(--color-accent);
	}

	.post-card-image {
		max-width: 100%;
		border-radius: 1.1rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
	}

	.post-card-shell:hover .post-card-image,
	.post-card-shell:focus-within .post-card-image {
		border-color: color-mix(in srgb, var(--color-accent) 42%, var(--color-border));
	}

	@media (min-width: 1280px) {
		.post-card-shell {
			flex-direction: row;
			align-items: center;
		}

		.post-card-image {
			max-width: 24rem;
		}
	}
</style>
