---
interface Props {
	id: string;
	avatar: string;
	bio: string;
	link: string;
	index: number;
}
const { id, avatar, bio, link, index } = Astro.props;

const toAvatarCssVar = (src: string) =>
	src ? `url("${src.replaceAll('"', '\\"')}")` : 'none';

const ariaLabel = id || link || `friend-${index + 1}`;
---

<li
	class="friend-card group snap-start"
	data-friend-card
	data-open="false"
	data-has-avatar={avatar ? 'true' : 'false'}
	style={`--friend-avatar: ${toAvatarCssVar(avatar)};`}
>
	<div class="friend-card-content">
		{
			(avatar || id) && (
				<button
					type="button"
					class="friend-card-trigger"
					data-friend-toggle
					aria-expanded="false"
					aria-label={`Toggle details for ${ariaLabel}`}
				>
					{avatar && (
						<img
							src={avatar}
							alt={id ? `${id} avatar` : 'Friend avatar'}
							loading="lazy"
							decoding="async"
						/>
					)}
					{id && <h2>{id}</h2>}
				</button>
			)
		}

		{
			(bio || link) && (
				<div class="friend-details">
					{bio && <p>{bio}</p>}
					{link && (
						<a href={link} target="_blank" rel="noopener noreferrer">
							{link}
						</a>
					)}
				</div>
			)
		}
	</div>
</li>

<style>
	.friend-card {
		position: relative;
		display: flex;
		width: 100%;
		min-height: 10.5rem;
		aspect-ratio: 7 / 5;
		overflow: hidden;
		border-radius: var(--radius-soft);
		border: 1px solid var(--color-border);
		background: linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 95%, var(--color-accent-soft) 5%), color-mix(in srgb, var(--color-surface) 78%, var(--color-surface-2)));
		box-shadow: 0 0.75rem 1.6rem rgba(var(--color-shadow-rgb), 0.08);
		transition: transform 320ms ease;
	}

	.friend-card::before,
	.friend-card::after {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 320ms ease;
		pointer-events: none;
	}

	.friend-card::before {
		background-image: var(--friend-avatar);
		background-size: cover;
		background-position: center;
		filter: blur(14px);
		transform: scale(1.08);
	}

	.friend-card::after {
		background: color-mix(in srgb, var(--color-surface) 54%, transparent);
	}

	.friend-card[data-has-avatar='false']::before,
	.friend-card[data-has-avatar='false']::after {
		display: none;
	}

	.friend-card:hover,
	.friend-card:focus-within,
	.friend-card[data-open='true'] {
		transform: scale(1.04);
		z-index: 2;
	}

	.friend-card:hover::before,
	.friend-card:hover::after,
	.friend-card:focus-within::before,
	.friend-card:focus-within::after,
	.friend-card[data-open='true']::before,
	.friend-card[data-open='true']::after {
		opacity: 1;
	}

	.friend-card-content {
		position: relative;
		z-index: 1;
		display: flex;
		height: 100%;
		width: 100%;
		flex-direction: column;
	}

	.friend-card-trigger {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.85rem;
		background: transparent;
		border: 0;
		text-align: left;
		color: inherit;
	}

	.friend-card-trigger img {
		height: 2.35rem;
		width: 2.35rem;
		flex-shrink: 0;
		border-radius: 999px;
		object-fit: cover;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-surface));
	}

	.friend-card-trigger h2 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.25;
		word-break: break-word;
	}

	.friend-details {
		margin-top: auto;
		display: grid;
		gap: 0.45rem;
		padding: 0 0.85rem 0.85rem;
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		transform: translateY(8px);
		transition: max-height 320ms ease, opacity 320ms ease, transform 320ms ease;
	}

	.friend-card:hover .friend-details,
	.friend-card:focus-within .friend-details,
	.friend-card[data-open='true'] .friend-details {
		max-height: 7.8rem;
		opacity: 1;
		transform: translateY(0);
	}

	.friend-details p {
		margin: 0;
		font-size: 0.84rem;
		line-height: 1.45;
		color: color-mix(in srgb, var(--color-muted) 92%, var(--color-text));
	}

	.friend-details a {
		font-size: 0.8rem;
		color: var(--color-accent);
		text-decoration: underline;
		word-break: break-all;
	}
</style>
