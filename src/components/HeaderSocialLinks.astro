---
import { Icon } from 'astro-icon/components';
import type { EnabledSocialLink } from '~/utils/socials';

interface Props {
	socials: EnabledSocialLink[];
	mobile?: boolean;
}

const { socials, mobile = false } = Astro.props;
---

{
	socials.length > 0 && (
		<div class:list={[mobile ? 'mobile-menu-socials' : 'header-socials']}>
			{
				socials.map(({ platform, icon, url, label }) => (
					<a class="header-social-link ui-pressable" href={url} aria-label={label ?? platform}>
						<Icon name={icon} class="fill-current" title={label ?? platform} />
					</a>
				))
			}
		</div>
	)
}

<style>
	.header-socials,
	.mobile-menu-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.header-social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.05rem;
		width: 2.05rem;
		color: var(--color-text);
		text-decoration: none;
		opacity: 0.82;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.header-social-link:hover,
	.header-social-link:focus-visible {
		opacity: 1;
	}

	.mobile-menu-socials {
		padding-bottom: 0.15rem;
	}
</style>
