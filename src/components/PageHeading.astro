---
interface Props {
	title: string;
	className?: string;
}

const { title, className } = Astro.props;
---

<section class:list={['page-heading', className]}>
	<div class="page-heading__row">
		<h1 class="page-title">{title}</h1>
		<slot />
	</div>
</section>

<style>
	.page-heading__row {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.page-heading__row {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 1.25rem;
		}
	}
</style>
