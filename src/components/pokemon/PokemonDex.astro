---
import { Icon } from 'astro-icon/components';
import { pokemonPrimaryFilters } from '~/data/pokemon-filters';
import {
	buildDexFilterMeta,
	type DexScope,
	type PokemonSpecies,
} from '~/utils/pokemon-dex';

type Props = {
	dexId: string;
	pokemonList: unknown;
	chains: unknown;
	artworkBase: string;
	showFilters?: boolean;
	/** National = full cross-region filters; regional = scoped to current dex page. */
	dexScope?: DexScope;
};

const {
	dexId,
	pokemonList,
	chains,
	artworkBase,
	showFilters = false,
	dexScope = 'national',
} = Astro.props;
const wikiBase = 'https://wiki.52poke.com/wiki/';
const speciesList = pokemonList as PokemonSpecies[];
const filterMeta = showFilters ? buildDexFilterMeta(speciesList, dexScope) : null;
const visiblePrimaryFilters = filterMeta
	? pokemonPrimaryFilters.filter((filter) =>
			filterMeta.enabledPrimaries.includes(filter.key),
		)
	: [];
---

<div class="pokemon-dex" data-dex-id={dexId}>
	<div class="p151-toolbar">
		<label class="p151-search">
			<Icon name="ri:search-line" class="p151-search__icon" aria-hidden="true" />
			<input
				class="pokemon-dex-search"
				type="search"
				placeholder="输入编号/中英文名"
				autocomplete="off"
			/>
		</label>
		<button class="p151-toolbar__toggle pokemon-dex-hide-names" type="button" aria-pressed="false">
			隐藏名字核对
		</button>
	</div>
	{
		showFilters && (
			<div class="pokedex-filters-wrap">
				<div class="pokedex-filters" role="group" aria-label="图鉴筛选">
					{visiblePrimaryFilters.map((filter) => (
						<button
							class="pokedex-filter"
							type="button"
							data-filter={filter.key}
						>
							{filter.label}
						</button>
					))}
				</div>
				{
					filterMeta?.showHomeSubfilters && (
						<div
							class="pokedex-subfilters pokedex-subfilters--home"
							role="group"
							aria-label="出身地区"
							hidden
						>
							<span class="pokedex-subfilters__label">出身</span>
							{filterMeta.availableHomeRegions.map((region) => (
								<button
									class="pokedex-filter pokedex-subfilter"
									type="button"
									data-filter={`home:${region}`}
								>
									{region}
								</button>
							))}
						</div>
					)
				}
				{
					filterMeta && filterMeta.availableFormRegions.length > 0 && (
						<div
							class="pokedex-subfilters pokedex-subfilters--form"
							role="group"
							aria-label="地区形态"
							hidden
						>
							<span class="pokedex-subfilters__label">形态</span>
							{filterMeta.availableFormRegions.map((region) => (
								<button
									class="pokedex-filter pokedex-subfilter"
									type="button"
									data-filter={`form:${region}`}
								>
									{region}
								</button>
							))}
						</div>
					)
				}
			</div>
		)
	}
	<p class="p151-toolbar-hint pokemon-dex-hide-hint" hidden>名字已隐藏，点按卡片显示中文名核对。</p>
	<ul class="p151-grid pokemon-dex-grid"></ul>
</div>

<script
	is:inline
	define:vars={{
		dexId,
		pokemonList,
		chains,
		artworkBase,
		wikiBase,
		showFilters,
		filterMeta,
	}}
>
	const PRIMARY_KEYS = ['legendary', 'mythical', 'forms', 'regional', 'paradox'];
	const HOME_PARENT_KEYS = ['legendary', 'mythical', 'paradox'];

	const state = {
		dexHideNames: false,
		activeFilters: [],
	};

	const els = {
		root: null,
		panelDex: null,
		dexSearch: null,
		dexGrid: null,
		dexHideNamesBtn: null,
		dexHideHint: null,
		filterBtns: [],
		homeSubfilterRow: null,
		formSubfilterRow: null,
	};

	const refreshEls = () => {
		els.root = document.querySelector(`[data-dex-id="${dexId}"]`);
		if (!els.root) return;
		els.panelDex = els.root;
		els.dexSearch = els.root.querySelector('.pokemon-dex-search');
		els.dexGrid = els.root.querySelector('.pokemon-dex-grid');
		els.dexHideNamesBtn = els.root.querySelector('.pokemon-dex-hide-names');
		els.dexHideHint = els.root.querySelector('.pokemon-dex-hide-hint');
		els.filterBtns = [...els.root.querySelectorAll('.pokedex-filter')];
		els.homeSubfilterRow = els.root.querySelector('.pokedex-subfilters--home');
		els.formSubfilterRow = els.root.querySelector('.pokedex-subfilters--form');
	};

	const pokemonById = Object.fromEntries(pokemonList.map((p) => [p.id, p]));

	const TYPE_COLORS = {
		normal: '#9fa19f',
		fighting: '#c22e28',
		fire: '#ee8130',
		water: '#4592c4',
		electric: '#c9a01e',
		grass: '#5bbd4a',
		ice: '#3aa8a3',
		poison: '#9140a0',
		ground: '#c9a227',
		flying: '#8b7ad6',
		psychic: '#ee6b76',
		bug: '#91a119',
		rock: '#bfb889',
		ghost: '#735797',
		dragon: '#6f35fc',
		dark: '#715344',
		steel: '#8a8aa8',
		fairy: '#d685ad',
	};

	const REMOTE_ART =
		'https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork';

	const wikiUrl = (nameCn) => `${wikiBase}${encodeURIComponent(nameCn)}`;
	const artUrl = (artId) => `${artworkBase}/${artId}.png`;
	const artFallback = (artId) => `${REMOTE_ART}/${artId}.png`;

	const sortChainsByMinId = (list) =>
		[...list].sort((a, b) => Math.min(...a) - Math.min(...b));

	const renderTypeLabel = (typeName, label, kind = 'type') => {
		const color = TYPE_COLORS[typeName] || TYPE_COLORS.normal;
		const chipClass =
			kind === 'weak'
				? 'pokedex-type-chip pokedex-type-chip--weak'
				: 'pokedex-type-chip';
		return `<span class="${chipClass}" style="--type-color:${color}">${label}</span>`;
	};

	const renderTypeRow = (p) => {
		const types = p.types || [];
		const typesCn = p.typesCn || [];
		return types
			.map((typeName, index) => renderTypeLabel(typeName, typesCn[index] || typeName))
			.join('');
	};

	const renderWeaknessRow = (p) => {
		const weaknesses = p.weaknesses || [];
		const labels = p.weaknessesCn || [];
		if (weaknesses.length === 0) return '';
		const items = weaknesses
			.map((typeName, index) =>
				renderTypeLabel(typeName, labels[index] || typeName, 'weak'),
			)
			.join('');
		const weakLabel = labels.join('、');
		return `<div class="p151-member__weak" aria-label="弱点 ${weakLabel}"><span class="p151-weak-prefix">弱</span>${items}</div>`;
	};

	const chainSharedType = (ids) => {
		const typeSets = ids.map((id) => (pokemonById[id]?.types || []));
		if (typeSets.length === 0) return 'normal';

		const sharedAcrossAll = [...new Set(typeSets.flat())].filter((typeName) =>
			typeSets.every((set) => set.includes(typeName)),
		);

		if (sharedAcrossAll.length > 0) {
			const firstPrimary = typeSets[0][0];
			if (sharedAcrossAll.includes(firstPrimary)) return firstPrimary;
			return sharedAcrossAll[0];
		}

		return typeSets[0][0] || 'normal';
	};

	const speciesToEntry = (species, variety) => {
		const v = variety || species.varieties.find((row) => row.isDefault) || species.varieties[0];
		return {
			key: `${species.id}-${v.formKey}`,
			speciesId: species.id,
			artId: v.artId,
			nameCn: v.nameCn || species.nameCn,
			nameEn: v.nameEn || species.nameEn,
			formLabelCn: v.formLabelCn || '',
			types: v.types,
			typesCn: v.typesCn,
			weaknesses: v.weaknesses,
			weaknessesCn: v.weaknessesCn,
		};
	};

	const matchesPokemon = (entry, filterText) => {
		const q = filterText.trim().toLowerCase();
		if (!q) return true;
		const typesText = (entry.typesCn || []).join('');
		const weakText = (entry.weaknessesCn || []).join('');
		const species = pokemonById[entry.speciesId];
		const genusText = species?.genusCn || '';
		const jaText = species?.nameJa || '';
		const regionText = species?.regionCn || '';
		return (
			String(entry.speciesId).includes(q) ||
			entry.nameCn.includes(filterText.trim()) ||
			entry.nameEn.toLowerCase().includes(q) ||
			(entry.formLabelCn && entry.formLabelCn.includes(filterText.trim())) ||
			typesText.includes(filterText.trim()) ||
			weakText.includes(filterText.trim()) ||
			genusText.includes(filterText.trim()) ||
			jaText.includes(filterText.trim()) ||
			regionText.includes(filterText.trim())
		);
	};

	const getPrimaries = () =>
		state.activeFilters.filter((key) => PRIMARY_KEYS.includes(key));

	const getHomeRegions = () =>
		state.activeFilters
			.filter((key) => key.startsWith('home:'))
			.map((key) => key.slice(5));

	const getFormRegions = () =>
		state.activeFilters
			.filter((key) => key.startsWith('form:'))
			.map((key) => key.slice(5));

	const hasActiveFilters = () => state.activeFilters.length > 0;

	const filterModeActive = () => showFilters && hasActiveFilters();

	const speciesMatchesFilters = (species) => {
		const primaries = getPrimaries();
		const homeRegions = getHomeRegions();
		const formRegions = getFormRegions();

		if (primaries.length === 0 && homeRegions.length === 0 && formRegions.length === 0) {
			return true;
		}

		for (const key of primaries) {
			if (key === 'legendary' && !species.isLegendary) return false;
			if (key === 'mythical' && !species.isMythical) return false;
			if (key === 'paradox' && !species.isParadox) return false;
			if (key === 'forms' && !species.hasAltForms) return false;
			if (key === 'regional' && !species.hasRegionalForm) return false;
		}

		if (homeRegions.length > 0 && !homeRegions.includes(species.regionCn)) return false;

		if (formRegions.length > 0) {
			const hasForm = species.varieties.some(
				(v) => v.isRegional && formRegions.includes(v.formLabelCn),
			);
			if (!hasForm) return false;
		}

		return true;
	};

	const varietyMatchesFilters = (variety) => {
		const primaries = getPrimaries();
		const formRegions = getFormRegions();
		const wantForms = primaries.includes('forms');
		const wantRegional = primaries.includes('regional');

		if (formRegions.length > 0) {
			if (!variety.isRegional || !formRegions.includes(variety.formLabelCn)) return false;
		}

		if (wantForms && wantRegional) {
			const isAlt = !variety.isDefault && !variety.isRegional;
			const isReg = variety.isRegional;
			return (wantForms && isAlt) || (wantRegional && isReg);
		}

		if (wantForms) return !variety.isDefault && !variety.isRegional;
		if (wantRegional) return variety.isRegional;
		if (formRegions.length > 0) {
			return variety.isRegional && formRegions.includes(variety.formLabelCn);
		}

		return variety.isDefault;
	};

	const buildFilterEntries = () => {
		const primaries = getPrimaries();
		const formRegions = getFormRegions();
		const varietyMode =
			primaries.includes('forms') ||
			primaries.includes('regional') ||
			formRegions.length > 0;

		const seen = new Set();
		const entries = [];
		const push = (entry) => {
			if (seen.has(entry.key)) return;
			seen.add(entry.key);
			entries.push(entry);
		};

		for (const species of pokemonList) {
			if (!speciesMatchesFilters(species)) continue;

			if (varietyMode) {
				for (const variety of species.varieties) {
					if (varietyMatchesFilters(variety)) {
						push(speciesToEntry(species, variety));
					}
				}
				continue;
			}

			const defaultVariety =
				species.varieties.find((row) => row.isDefault) || species.varieties[0];
			push(speciesToEntry(species, defaultVariety));
		}

		return entries;
	};

	const renderMember = (entry) => {
		const typeRow = renderTypeRow(entry);
		const weakRow = renderWeaknessRow(entry);
		const sup = String(entry.speciesId).padStart(3, '0');
		const label = entry.formLabelCn
			? `${entry.nameCn}（${entry.formLabelCn}）`
			: entry.nameCn;
		const artAlt = state.dexHideNames ? '宝可梦立绘' : label;
		const maskClass = state.dexHideNames ? ' p151-member--mask-name' : '';

		return `
    <a class="p151-member${maskClass}" href="${wikiUrl(entry.nameCn)}" target="_blank" rel="noreferrer noopener" data-key="${entry.key}" data-id="${entry.speciesId}">
      <img class="p151-member__art" src="${artUrl(entry.artId)}" onerror="this.onerror=null;this.src='${artFallback(entry.artId)}'" alt="${artAlt}" width="72" height="72" loading="lazy" />
      <span class="p151-member__no">${sup}</span>
      <span class="p151-member__label">${label}</span>
      <span class="p151-member__en">${entry.nameEn}</span>
      ${typeRow ? `<div class="p151-member__types">${typeRow}</div>` : ''}
      ${weakRow}
    </a>`;
	};

	const renderFlatGrid = (entries) => {
		const cells = entries
			.map((entry) => `<li class="pokedex-flat-cell">${renderMember(entry)}</li>`)
			.join('');
		els.dexGrid.innerHTML = cells;
		els.dexGrid.classList.add('pokedex-grid--flat');
	};

	const renderEvoline = (ids) => {
		const members = ids
			.map((id) => renderMember(speciesToEntry(pokemonById[id])))
			.join('<span class="p151-evoline__sep" aria-hidden="true">›</span>');
		const chainType = chainSharedType(ids);
		const chainColor = TYPE_COLORS[chainType] || TYPE_COLORS.normal;
		const chainStyle = ` style="--p151-chain-type: ${chainColor}"`;

		return `<li class="p151-evoline p151-evoline--typed" data-count="${ids.length}"${chainStyle}>${members}</li>`;
	};

	const renderDex = (filter = '') => {
		if (!els.dexGrid) return;

		if (filterModeActive()) {
			const entries = buildFilterEntries()
				.filter((entry) => matchesPokemon(entry, filter))
				.sort((a, b) => a.speciesId - b.speciesId || a.artId - b.artId);
			renderFlatGrid(entries);
			return;
		}

		els.dexGrid.classList.remove('pokedex-grid--flat');
		const trimmed = filter.trim();
		const visibleChains = sortChainsByMinId(
			chains.filter(
				(ids) =>
					!trimmed ||
					ids.some((id) => matchesPokemon(speciesToEntry(pokemonById[id]), filter)),
			),
		);
		els.dexGrid.innerHTML = visibleChains.map(renderEvoline).join('');
	};

	const syncFilterButtons = () => {
		els.filterBtns.forEach((btn) => {
			const active = state.activeFilters.includes(btn.dataset.filter);
			btn.classList.toggle('is-active', active);
			btn.setAttribute('aria-pressed', active ? 'true' : 'false');
		});
	};

	const pruneOrphanSubfilters = () => {
		const primaries = getPrimaries();
		const showHomeParents = primaries.some((key) => HOME_PARENT_KEYS.includes(key));
		if (!showHomeParents) {
			state.activeFilters = state.activeFilters.filter((key) => !key.startsWith('home:'));
		}
		if (!primaries.includes('regional')) {
			state.activeFilters = state.activeFilters.filter((key) => !key.startsWith('form:'));
		}

		if (!filterMeta) return;

		state.activeFilters = state.activeFilters.filter((key) => {
			if (PRIMARY_KEYS.includes(key)) {
				return filterMeta.enabledPrimaries.includes(key);
			}
			if (key.startsWith('home:')) {
				return (
					filterMeta.showHomeSubfilters &&
					filterMeta.availableHomeRegions.includes(key.slice(5))
				);
			}
			if (key.startsWith('form:')) {
				return filterMeta.availableFormRegions.includes(key.slice(5));
			}
			return false;
		});
	};

	const updateSubfilterVisibility = () => {
		const primaries = getPrimaries();
		const showHome =
			filterMeta?.showHomeSubfilters &&
			primaries.some((key) => HOME_PARENT_KEYS.includes(key));
		const showForm =
			filterMeta &&
			filterMeta.availableFormRegions.length > 0 &&
			(primaries.includes('regional') || getFormRegions().length > 0);
		if (els.homeSubfilterRow) els.homeSubfilterRow.hidden = !showHome;
		if (els.formSubfilterRow) els.formSubfilterRow.hidden = !showForm;
	};

	const isFilterAllowed = (filterKey) => {
		if (!filterMeta) return false;
		if (PRIMARY_KEYS.includes(filterKey)) {
			return filterMeta.enabledPrimaries.includes(filterKey);
		}
		if (filterKey.startsWith('home:')) {
			return (
				filterMeta.showHomeSubfilters &&
				filterMeta.availableHomeRegions.includes(filterKey.slice(5))
			);
		}
		if (filterKey.startsWith('form:')) {
			return filterMeta.availableFormRegions.includes(filterKey.slice(5));
		}
		return false;
	};

	const setDexHideNames = (on) => {
		state.dexHideNames = on;
		els.panelDex?.classList.toggle('p151-panel--hide-names', on);
		els.dexHideNamesBtn?.setAttribute('aria-pressed', on ? 'true' : 'false');
		els.dexHideNamesBtn?.classList.toggle('is-active', on);
		if (els.dexHideNamesBtn) {
			els.dexHideNamesBtn.textContent = on ? '显示全部名字' : '隐藏名字核对';
		}
		if (els.dexHideHint) els.dexHideHint.hidden = !on;
		renderDex(els.dexSearch?.value || '');
	};

	const toggleFilter = (filterKey) => {
		if (!isFilterAllowed(filterKey)) return;

		const idx = state.activeFilters.indexOf(filterKey);
		if (idx >= 0) state.activeFilters.splice(idx, 1);
		else state.activeFilters.push(filterKey);

		pruneOrphanSubfilters();
		updateSubfilterVisibility();
		syncFilterButtons();
		renderDex(els.dexSearch?.value || '');
	};

	const cleanupKey = `__pokemonDexCleanup_${dexId}`;

	const setup = () => {
		const windowWithCleanup = window;
		windowWithCleanup[cleanupKey]?.();
		refreshEls();
		if (!els.root) return;

		setDexHideNames(false);
		state.activeFilters = [];
		updateSubfilterVisibility();
		syncFilterButtons();

		const onDexSearch = (e) => renderDex(e.target.value);
		const onHideNames = () => setDexHideNames(!state.dexHideNames);
		const onDexGridClick = (e) => {
			if (!state.dexHideNames) return;
			const member = e.target.closest('.p151-member');
			if (!member) return;
			if (!member.classList.contains('p151-member--revealed')) {
				e.preventDefault();
				member.classList.add('p151-member--revealed');
				const label = member.querySelector('.p151-member__label');
				if (label) {
					const art = member.querySelector('.p151-member__art');
					if (art) art.alt = label.textContent || '宝可梦立绘';
				}
			}
		};
		const onFilterClick = (e) => {
			const btn = e.target.closest('.pokedex-filter');
			if (!btn) return;
			toggleFilter(btn.dataset.filter);
		};

		els.dexSearch?.addEventListener('input', onDexSearch);
		els.dexHideNamesBtn?.addEventListener('click', onHideNames);
		els.dexGrid?.addEventListener('click', onDexGridClick);
		els.root.addEventListener('click', onFilterClick);

		renderDex('');

		windowWithCleanup[cleanupKey] = () => {
			els.dexSearch?.removeEventListener('input', onDexSearch);
			els.dexHideNamesBtn?.removeEventListener('click', onHideNames);
			els.dexGrid?.removeEventListener('click', onDexGridClick);
			els.root?.removeEventListener('click', onFilterClick);
		};
	};

	setup();
	document.addEventListener('astro:page-load', setup);
</script>

<style is:global>
	.pokedex-filters-wrap {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		margin-bottom: 0.85rem;
	}

	.pokedex-filters,
	.pokedex-subfilters {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
	}

	.pokedex-subfilters__label {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--color-muted);
		margin-right: 0.1rem;
	}

	.pokedex-filter {
		padding: 0.38rem 0.72rem;
		border-radius: var(--radius-chip);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		background: var(--color-surface);
		color: var(--color-muted);
		font-size: 0.8rem;
		font-weight: 600;
		cursor: pointer;
	}

	.pokedex-subfilter {
		padding: 0.32rem 0.58rem;
		font-size: 0.74rem;
	}

	.pokedex-filter.is-active {
		border-color: color-mix(in srgb, var(--color-accent) 72%, var(--color-border) 28%);
		background: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface) 86%);
		color: color-mix(in srgb, var(--color-accent) 82%, var(--color-text) 18%);
	}

	.pokedex-grid--flat {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(5.5rem, 1fr));
		gap: 0.45rem;
	}

	.pokedex-flat-cell {
		list-style: none;
		min-width: 0;
	}

	.pokedex-flat-cell .p151-member {
		width: 100%;
	}
</style>
