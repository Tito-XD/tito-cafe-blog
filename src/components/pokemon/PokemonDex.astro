---
import { Icon } from 'astro-icon/components';
import { GENERATION_HOME_REGION, pokemonPrimaryFilters } from '~/data/pokemon-filters';
import {
	buildDexFilterMeta,
	type DexScope,
	type PokemonSpecies,
} from '~/utils/pokemon-dex';
import pokemon30ArtKeys from '~/data/pokemon30-art-keys.json';

type Props = {
	dexId: string;
	pokemonList: unknown;
	chains: unknown;
	artworkBase: string;
	showFilters?: boolean;
	dexScope?: DexScope;
	pageRegionCn?: string;
};

const {
	dexId,
	pokemonList,
	chains,
	artworkBase,
	showFilters = false,
	dexScope = 'national',
	pageRegionCn = '',
} = Astro.props;
const wikiBase = 'https://wiki.52poke.com/wiki/';
const speciesList = pokemonList as PokemonSpecies[];
const filterMeta = showFilters
	? buildDexFilterMeta(speciesList, dexScope, pageRegionCn)
	: null;
const visiblePrimaryFilters = filterMeta
	? pokemonPrimaryFilters.filter((filter) =>
			filterMeta.enabledPrimaries.includes(filter.key),
		)
	: [];
---

<div class="pokemon-dex" data-dex-id={dexId}>
	<div class="p151-toolbar">
		<label class="p151-search">
			<Icon name="ri:search-line" class="p151-search__icon" aria-hidden="true" />
			<input
				class="pokemon-dex-search"
				type="search"
				placeholder="输入编号/中英文名"
				autocomplete="off"
			/>
		</label>
		<button class="p151-toolbar__toggle pokemon-dex-hide-names" type="button" aria-pressed="false">
			隐藏名字核对
		</button>
	</div>
	{
		showFilters && (
			<button
				class="p151-toolbar__toggle pokedex-filters-toggle"
				type="button"
				aria-expanded="false"
			>
				展开筛选
			</button>
		)
	}
	{
		showFilters && (
			<div class="pokedex-filters-panel" hidden>
				<div class="pokedex-filters-wrap">
					<div class="pokedex-filters" role="group" aria-label="图鉴筛选">
						{visiblePrimaryFilters.map((filter) => (
							<button class="pokedex-filter" type="button" data-filter={filter.key}>
								{filter.label}
							</button>
						))}
					</div>
					{
						filterMeta?.subGroups.map((group) => (
							<div
								class="pokedex-subfilters"
								data-sub-group={group.id}
								role="group"
								aria-label={group.ariaLabel}
								hidden
							>
								{group.showLabel && group.label && (
									<span class="pokedex-subfilters__label">{group.label}</span>
								)}
								{group.options.map((option) => (
									<button
										class="pokedex-filter pokedex-subfilter"
										type="button"
										data-filter={option.filterKey}
									>
										{option.label}
									</button>
								))}
							</div>
						))
					}
				</div>
			</div>
		)
	}
	<p class="p151-toolbar-hint pokemon-dex-hide-hint" hidden>名字已隐藏，点按卡片显示中文名核对。</p>
	<ul class="p151-grid pokemon-dex-grid"></ul>
</div>

<script
	is:inline
	define:vars={{
		dexId,
		pokemonList,
		chains,
		artworkBase,
		wikiBase,
		showFilters,
		filterMeta,
		generationHomeRegion: GENERATION_HOME_REGION,
		pokemon30ArtKeys,
	}}
>
	const state = { dexHideNames: false, activeFilters: [], filtersExpanded: false };

	const els = {
		root: null,
		panelDex: null,
		dexSearch: null,
		dexGrid: null,
		dexHideNamesBtn: null,
		dexHideHint: null,
		filterBtns: [],
		filtersToggle: null,
		filtersPanel: null,
	};

	const refreshEls = () => {
		els.root = document.querySelector(`[data-dex-id="${dexId}"]`);
		if (!els.root) return;
		els.panelDex = els.root;
		els.dexSearch = els.root.querySelector('.pokemon-dex-search');
		els.dexGrid = els.root.querySelector('.pokemon-dex-grid');
		els.dexHideNamesBtn = els.root.querySelector('.pokemon-dex-hide-names');
		els.dexHideHint = els.root.querySelector('.pokemon-dex-hide-hint');
		els.filterBtns = [...els.root.querySelectorAll('.pokedex-filter')];
		els.filtersToggle = els.root.querySelector('.pokedex-filters-toggle');
		els.filtersPanel = els.root.querySelector('.pokedex-filters-panel');
	};

	const pokemonById = Object.fromEntries(pokemonList.map((p) => [p.id, p]));

	const TYPE_COLORS = {
		normal: '#9fa19f',
		fighting: '#c22e28',
		fire: '#ee8130',
		water: '#4592c4',
		electric: '#c9a01e',
		grass: '#5bbd4a',
		ice: '#3aa8a3',
		poison: '#9140a0',
		ground: '#c9a227',
		flying: '#8b7ad6',
		psychic: '#ee6b76',
		bug: '#91a119',
		rock: '#bfb889',
		ghost: '#735797',
		dragon: '#6f35fc',
		dark: '#715344',
		steel: '#8a8aa8',
		fairy: '#d685ad',
	};

	const REMOTE_ART =
		'https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork';

	const wikiUrl = (nameCn) => `${wikiBase}${encodeURIComponent(nameCn)}`;

	const isPokemon30ArtOn = () => {
		try {
			const raw = localStorage.getItem('pokemon-30th-art');
			if (raw === 'on' || raw === '"on"') return true;
		} catch {
			/* ignore */
		}
		return false;
	};

	const get30thArtKey = (entry) => {
		const mapped = pokemon30ArtKeys.byArtId?.[entry.artId];
		if (mapped) return mapped;
		return String(entry.speciesId).padStart(4, '0');
	};

	const pokemon30RemoteBase =
		pokemon30ArtKeys.remoteBase ||
		'https://www.pokemon.co.jp/ex/30th_logo/assets/img/download';

	const artUrl = (entry) => {
		if (!isPokemon30ArtOn()) {
			return `${artworkBase}/${entry.artId}.png`;
		}
		return `/pokemon30/artwork/${get30thArtKey(entry)}.png`;
	};

	const artFallback = (entry) => {
		if (isPokemon30ArtOn()) {
			return `${pokemon30RemoteBase}/${get30thArtKey(entry)}.png`;
		}
		return `${REMOTE_ART}/${entry.artId}.png`;
	};

	const sortChainsByMinId = (list) =>
		[...list].sort((a, b) => Math.min(...a) - Math.min(...b));

	const renderTypeLabel = (typeName, label, kind = 'type') => {
		const color = TYPE_COLORS[typeName] || TYPE_COLORS.normal;
		const chipClass =
			kind === 'weak'
				? 'pokedex-type-chip pokedex-type-chip--weak'
				: 'pokedex-type-chip';
		return `<span class="${chipClass}" style="--type-color:${color}">${label}</span>`;
	};

	const renderTypeRow = (p) => {
		const types = p.types || [];
		const typesCn = p.typesCn || [];
		return types
			.map((typeName, index) => renderTypeLabel(typeName, typesCn[index] || typeName))
			.join('');
	};

	const renderWeaknessRow = (p) => {
		const weaknesses = p.weaknesses || [];
		const labels = p.weaknessesCn || [];
		if (weaknesses.length === 0) return '';
		const items = weaknesses
			.map((typeName, index) =>
				renderTypeLabel(typeName, labels[index] || typeName, 'weak'),
			)
			.join('');
		const weakLabel = labels.join('、');
		return `<div class="p151-member__weak" aria-label="弱点 ${weakLabel}"><span class="p151-weak-prefix">弱</span>${items}</div>`;
	};

	const speciesToEntry = (species, variety) => {
		const v = variety || species.varieties.find((row) => row.isDefault) || species.varieties[0];
		return {
			key: `${species.id}-${v.formKey}`,
			speciesId: species.id,
			artId: v.artId,
			nameCn: v.nameCn || species.nameCn,
			nameEn: v.nameEn || species.nameEn,
			formLabelCn: v.formLabelCn || '',
			types: v.types,
			typesCn: v.typesCn,
			weaknesses: v.weaknesses,
			weaknessesCn: v.weaknessesCn,
		};
	};

	const matchesPokemon = (entry, filterText) => {
		const q = filterText.trim().toLowerCase();
		if (!q) return true;
		const species = pokemonById[entry.speciesId];
		const typesText = (entry.typesCn || []).join('');
		const weakText = (entry.weaknessesCn || []).join('');
		return (
			String(entry.speciesId).includes(q) ||
			entry.nameCn.includes(filterText.trim()) ||
			entry.nameEn.toLowerCase().includes(q) ||
			(entry.formLabelCn && entry.formLabelCn.includes(filterText.trim())) ||
			typesText.includes(filterText.trim()) ||
			weakText.includes(filterText.trim()) ||
			(species?.genusCn || '').includes(filterText.trim()) ||
			(species?.nameJa || '').includes(filterText.trim()) ||
			(species?.regionCn || '').includes(filterText.trim())
		);
	};

	const getPrimaries = () => {
		if (!filterMeta) return [];
		return state.activeFilters.filter((key) => filterMeta.primaryKeys.includes(key));
	};

	const getSubs = (prefix) =>
		state.activeFilters
			.filter((key) => key.startsWith(`${prefix}:`))
			.map((key) => key.slice(prefix.length + 1));

	const filterModeActive = () => {
		if (!showFilters || !filterMeta) return false;
		const primaries = getPrimaries();
		if (primaries.length === 0) return false;
		if (primaries.includes('type') && getSubs('type').length === 0) return false;
		return true;
	};

	const matchesScopedRegionalSpecies = (species) => {
		if (filterMeta?.scope !== 'regional' || !filterMeta.pageRegionCn) {
			return species.hasRegionalForm;
		}
		return species.varieties.some(
			(v) => v.isRegional && v.formLabelCn === filterMeta.pageRegionCn,
		);
	};

	const matchesScopedRegionalVariety = (variety) => {
		if (filterMeta?.scope !== 'regional' || !filterMeta.pageRegionCn) {
			return variety.isRegional;
		}
		return variety.isRegional && variety.formLabelCn === filterMeta.pageRegionCn;
	};

	const isOtherAltVariety = (variety) =>
		!variety.isDefault &&
		!variety.isRegional &&
		!variety.isMega &&
		!variety.isGmax &&
		!variety.isTotem;

	const varietyMatchesKind = (variety, kind) => {
		if (kind === 'mega') return variety.isMega;
		if (kind === 'gmax') return variety.isGmax;
		if (kind === 'totem') return variety.isTotem;
		return false;
	};

	const speciesMatchesFilters = (species) => {
		const primaries = getPrimaries();
		const homeRegions = getSubs('home');
		const formRegions = getSubs('form');
		const starterRegions = getSubs('starter');
		const typeNames = getSubs('type');

		if (
			primaries.length === 0 &&
			homeRegions.length === 0 &&
			formRegions.length === 0 &&
			starterRegions.length === 0 &&
			typeNames.length === 0 &&
			getSubs('kind').length === 0
		) {
			return true;
		}

		for (const key of primaries) {
			if (key === 'legendary' && !species.isLegendary) return false;
			if (key === 'mythical' && !species.isMythical) return false;
			if (key === 'paradox' && !species.isParadox) return false;
			if (key === 'baby' && !species.isBaby) return false;
			if (key === 'pseudo' && !species.isPseudoLegendary) return false;
			if (key === 'ultra' && !species.isUltraBeast) return false;
			if (key === 'fossil' && !species.isFossil) return false;
			if (key === 'starter' && !species.isStarter) return false;
			if (key === 'basic' && species.evolutionStage !== 'basic') return false;
			if (key === 'final' && species.evolutionStage !== 'final') return false;
			if (key === 'monotype' && species.types.length !== 1) return false;
			if (key === 'dualtype' && species.types.length !== 2) return false;
			if (key === 'forms' && !species.hasAltForms) return false;
			if (key === 'regional' && !matchesScopedRegionalSpecies(species)) return false;
		}

		if (homeRegions.length > 0 && !homeRegions.includes(species.regionCn)) return false;

		if (starterRegions.length > 0) {
			const label = generationHomeRegion[species.starterGen] || '';
			if (!starterRegions.includes(label)) return false;
		}

		if (typeNames.length > 0) {
			if (!species.types.some((typeName) => typeNames.includes(typeName))) return false;
		}

		if (formRegions.length > 0) {
			const hasForm = species.varieties.some(
				(v) => v.isRegional && formRegions.includes(v.formLabelCn),
			);
			if (!hasForm) return false;
		}

		return true;
	};

	const varietyMatchesFilters = (variety) => {
		const primaries = getPrimaries();
		const formRegions = getSubs('form');
		const kindFilters = getSubs('kind');
		const wantForms = primaries.includes('forms');
		const wantRegional = primaries.includes('regional');

		if (formRegions.length > 0) {
			if (!variety.isRegional || !formRegions.includes(variety.formLabelCn)) return false;
		}

		if (wantForms && wantRegional) {
			const isAlt = wantForms && (kindFilters.length > 0
				? kindFilters.some((kind) => varietyMatchesKind(variety, kind))
				: isOtherAltVariety(variety));
			const isReg = matchesScopedRegionalVariety(variety);
			return isAlt || isReg;
		}

		if (wantForms) {
			if (kindFilters.length > 0) {
				return kindFilters.some((kind) => varietyMatchesKind(variety, kind));
			}
			return isOtherAltVariety(variety);
		}

		if (wantRegional) return matchesScopedRegionalVariety(variety);

		if (kindFilters.length > 0) {
			return kindFilters.some((kind) => varietyMatchesKind(variety, kind));
		}

		if (formRegions.length > 0) {
			return variety.isRegional && formRegions.includes(variety.formLabelCn);
		}

		return variety.isDefault;
	};

	const varietyModeActive = () => {
		const primaries = getPrimaries();
		if (primaries.includes('forms') || primaries.includes('regional')) return true;
		if (getSubs('kind').length > 0) return true;
		if (getSubs('form').length > 0) return true;
		return false;
	};

	const buildFilterEntries = () => {
		const seen = new Set();
		const entries = [];
		const push = (entry) => {
			if (seen.has(entry.key)) return;
			seen.add(entry.key);
			entries.push(entry);
		};

		for (const species of pokemonList) {
			if (!speciesMatchesFilters(species)) continue;

			if (varietyModeActive()) {
				for (const variety of species.varieties) {
					if (varietyMatchesFilters(variety)) {
						push(speciesToEntry(species, variety));
					}
				}
				continue;
			}

			const defaultVariety =
				species.varieties.find((row) => row.isDefault) || species.varieties[0];
			push(speciesToEntry(species, defaultVariety));
		}

		return entries;
	};

	const getPrimaryTypeColor = (entry) => {
		const primaryType = entry.types?.[0] || 'normal';
		return TYPE_COLORS[primaryType] || TYPE_COLORS.normal;
	};

	const renderMember = (entry) => {
		const typeRow = renderTypeRow(entry);
		const weakRow = renderWeaknessRow(entry);
		const sup = String(entry.speciesId).padStart(3, '0');
		const label = entry.formLabelCn
			? `${entry.nameCn}（${entry.formLabelCn}）`
			: entry.nameCn;
		const artAlt = state.dexHideNames ? '宝可梦立绘' : label;
		const maskClass = state.dexHideNames ? ' p151-member--mask-name' : '';
		const typeColor = getPrimaryTypeColor(entry);

		return `
    <a class="p151-member p151-member--card p151-member--typed${maskClass}" style="--p151-chain-type:${typeColor}" href="${wikiUrl(entry.nameCn)}" target="_blank" rel="noreferrer noopener" data-key="${entry.key}" data-id="${entry.speciesId}">
      <img class="p151-member__art" src="${artUrl(entry)}" onerror="this.onerror=null;this.src='${artFallback(entry)}'" alt="${artAlt}" width="72" height="72" loading="lazy" />
      <span class="p151-member__no">${sup}</span>
      <span class="p151-member__label">${label}</span>
      <span class="p151-member__en">${entry.nameEn}</span>
      ${typeRow ? `<div class="p151-member__types">${typeRow}</div>` : ''}
      ${weakRow}
    </a>`;
	};

	const renderFlatGrid = (entries) => {
		els.dexGrid.innerHTML = entries
			.map((entry) => `<li class="pokedex-flat-cell">${renderMember(entry)}</li>`)
			.join('');
		els.dexGrid.classList.remove('pokedex-grid--chains');
		els.dexGrid.classList.add('pokedex-grid--flat');
	};

	const renderChainGroup = (ids) => {
		const parts = [];
		ids.forEach((id, index) => {
			parts.push(renderMember(speciesToEntry(pokemonById[id])));
			if (index < ids.length - 1) {
				parts.push('<span class="pokedex-chain__sep" aria-hidden="true">›</span>');
			}
		});
		return `<li class="pokedex-chain-group" data-count="${ids.length}"><div class="pokedex-chain-group__track">${parts.join('')}</div></li>`;
	};

	const renderDex = (filter = '') => {
		if (!els.dexGrid) return;

		if (filterModeActive()) {
			const entries = buildFilterEntries()
				.filter((entry) => matchesPokemon(entry, filter))
				.sort((a, b) => a.speciesId - b.speciesId || a.artId - b.artId);
			renderFlatGrid(entries);
			return;
		}

		els.dexGrid.classList.remove('pokedex-grid--flat');
		els.dexGrid.classList.add('pokedex-grid--chains');
		const trimmed = filter.trim();
		const visibleChains = sortChainsByMinId(
			chains.filter(
				(ids) =>
					!trimmed ||
					ids.some((id) => matchesPokemon(speciesToEntry(pokemonById[id]), filter)),
			),
		);
		els.dexGrid.innerHTML = visibleChains.map(renderChainGroup).join('');
	};

	const syncFilterButtons = () => {
		els.filterBtns.forEach((btn) => {
			const active = state.activeFilters.includes(btn.dataset.filter);
			btn.classList.toggle('is-active', active);
			btn.setAttribute('aria-pressed', active ? 'true' : 'false');
		});
	};

	const allSubFilterKeys = () => {
		if (!filterMeta) return [];
		return filterMeta.subGroups.flatMap((group) =>
			group.options.map((option) => option.filterKey),
		);
	};

	const pruneOrphanSubfilters = () => {
		if (!filterMeta) return;

		const primaries = getPrimaries();

		for (const group of filterMeta.subGroups) {
			const parentActive = group.parentKeys.some((key) => primaries.includes(key));
			if (!parentActive) {
				const keys = new Set(group.options.map((option) => option.filterKey));
				state.activeFilters = state.activeFilters.filter((key) => !keys.has(key));
			}
		}

		const allowedSubs = new Set(allSubFilterKeys());
		state.activeFilters = state.activeFilters.filter((key) => {
			if (filterMeta.primaryKeys.includes(key)) {
				return filterMeta.enabledPrimaries.includes(key);
			}
			if (allowedSubs.has(key)) return true;
			return false;
		});
	};

	const findSubGroup = (filterKey) => {
		if (!filterMeta) return null;
		return filterMeta.subGroups.find((group) =>
			group.options.some((option) => option.filterKey === filterKey),
		);
	};

	const updateSubfilterVisibility = () => {
		if (!filterMeta || !els.root) return;
		const primaries = getPrimaries();
		for (const group of filterMeta.subGroups) {
			const row = els.root.querySelector(`[data-sub-group="${group.id}"]`);
			if (!row) continue;
			const parentActive = group.parentKeys.some((key) => primaries.includes(key));
			row.hidden = !parentActive;
			if (parentActive) row.removeAttribute('hidden');
			else row.setAttribute('hidden', '');
		}
	};

	const isFilterAllowed = (filterKey) => {
		if (!filterMeta) return false;
		if (filterMeta.primaryKeys.includes(filterKey)) {
			return filterMeta.enabledPrimaries.includes(filterKey);
		}
		return allSubFilterKeys().includes(filterKey);
	};

	const setDexHideNames = (on) => {
		state.dexHideNames = on;
		els.panelDex?.classList.toggle('p151-panel--hide-names', on);
		els.dexHideNamesBtn?.setAttribute('aria-pressed', on ? 'true' : 'false');
		els.dexHideNamesBtn?.classList.toggle('is-active', on);
		if (els.dexHideNamesBtn) {
			els.dexHideNamesBtn.textContent = on ? '显示全部名字' : '隐藏名字核对';
		}
		if (els.dexHideHint) els.dexHideHint.hidden = !on;
		renderDex(els.dexSearch?.value || '');
	};

	const setFiltersExpanded = (expanded) => {
		state.filtersExpanded = expanded;
		if (els.filtersPanel) {
			els.filtersPanel.hidden = !expanded;
			if (expanded) els.filtersPanel.removeAttribute('hidden');
			else els.filtersPanel.setAttribute('hidden', '');
		}
		if (els.filtersToggle) {
			els.filtersToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
			els.filtersToggle.textContent = expanded ? '收起筛选' : '展开筛选';
			els.filtersToggle.classList.toggle('is-active', expanded);
		}
		if (!expanded) {
			state.activeFilters = [];
			updateSubfilterVisibility();
			syncFilterButtons();
			renderDex(els.dexSearch?.value || '');
		}
	};

	const onFiltersToggle = () => setFiltersExpanded(!state.filtersExpanded);

	const toggleFilter = (filterKey) => {
		if (!isFilterAllowed(filterKey)) return;

		const isPrimary = filterMeta.primaryKeys.includes(filterKey);

		if (isPrimary) {
			// 单选：同时只查看一个主分类
			if (state.activeFilters.includes(filterKey)) {
				state.activeFilters = [];
			} else {
				state.activeFilters = [filterKey];
			}
		} else {
			const group = findSubGroup(filterKey);
			if (!group) return;
			const primaries = getPrimaries();
			const parentActive = group.parentKeys.some((key) => primaries.includes(key));
			if (!parentActive) return;

			const groupKeys = group.options.map((option) => option.filterKey);
			const wasActive = state.activeFilters.includes(filterKey);
			state.activeFilters = state.activeFilters.filter((key) => !groupKeys.includes(key));
			if (!wasActive) state.activeFilters.push(filterKey);
		}

		pruneOrphanSubfilters();
		updateSubfilterVisibility();
		syncFilterButtons();
		renderDex(els.dexSearch?.value || '');
	};

	const cleanupKey = `__pokemonDexCleanup_${dexId}`;

	const setup = () => {
		const windowWithCleanup = window;
		windowWithCleanup[cleanupKey]?.();
		refreshEls();
		if (!els.root) return;

		setDexHideNames(false);
		state.activeFilters = [];
		setFiltersExpanded(false);
		updateSubfilterVisibility();
		syncFilterButtons();

		const onDexSearch = (e) => renderDex(e.target.value);
		const onHideNames = () => setDexHideNames(!state.dexHideNames);
		const onDexGridClick = (e) => {
			if (!state.dexHideNames) return;
			const member = e.target.closest('.p151-member');
			if (!member?.classList.contains('p151-member--revealed')) {
				if (member) {
					e.preventDefault();
					member.classList.add('p151-member--revealed');
					const label = member.querySelector('.p151-member__label');
					const art = member.querySelector('.p151-member__art');
					if (label && art) art.alt = label.textContent || '宝可梦立绘';
				}
			}
		};
		const onFilterClick = (e) => {
			const btn = e.target.closest('.pokedex-filter');
			if (!btn) return;
			toggleFilter(btn.dataset.filter);
		};

		const onArtModeChange = () => renderDex(els.dexSearch?.value || '');

		els.dexSearch?.addEventListener('input', onDexSearch);
		els.dexHideNamesBtn?.addEventListener('click', onHideNames);
		els.dexGrid?.addEventListener('click', onDexGridClick);
		els.filtersToggle?.addEventListener('click', onFiltersToggle);
		els.root.addEventListener('click', onFilterClick);
		document.addEventListener('pokemon-art-mode-change', onArtModeChange);
		renderDex('');

		windowWithCleanup[cleanupKey] = () => {
			els.dexSearch?.removeEventListener('input', onDexSearch);
			els.dexHideNamesBtn?.removeEventListener('click', onHideNames);
			els.dexGrid?.removeEventListener('click', onDexGridClick);
			els.filtersToggle?.removeEventListener('click', onFiltersToggle);
			els.root?.removeEventListener('click', onFilterClick);
			document.removeEventListener('pokemon-art-mode-change', onArtModeChange);
		};
	};

	setup();
	document.addEventListener('astro:page-load', setup);
</script>

