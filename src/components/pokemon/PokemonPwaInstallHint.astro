<div class="pokemon-pwa-install" id="pokemon-pwa-install" hidden>
	<div class="pokemon-pwa-install__body">
		<p class="pokemon-pwa-install__title">安装图鉴 App</p>
		<p class="pokemon-pwa-install__text">添加到主屏幕，线下活动可离线查图鉴与测验。</p>
	</div>
	<button type="button" class="pokemon-pwa-install__action ui-pressable" id="pokemon-pwa-install-btn">
		安装
	</button>
	<button
		type="button"
		class="pokemon-pwa-install__close"
		id="pokemon-pwa-install-dismiss"
		aria-label="关闭"
	>
		×
	</button>
</div>

<style>
	.pokemon-pwa-install {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin: 0 0 1rem;
		padding: 0.7rem 0.8rem;
		border-radius: var(--radius-soft);
		border: 1px solid color-mix(in srgb, var(--color-accent) 42%, var(--color-border) 58%);
		background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface) 88%);
	}

	.pokemon-pwa-install__body {
		flex: 1 1 auto;
		min-width: 0;
	}

	.pokemon-pwa-install__title {
		margin: 0;
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1.3;
	}

	.pokemon-pwa-install__text {
		margin: 0.15rem 0 0;
		font-size: 0.78rem;
		color: var(--color-muted);
		line-height: 1.45;
	}

	.pokemon-pwa-install__action {
		flex: 0 0 auto;
		padding: 0.45rem 0.85rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 55%, var(--color-border) 45%);
		background: var(--color-accent);
		color: #fff;
		font-size: 0.82rem;
		font-weight: 700;
		cursor: pointer;
	}

	.pokemon-pwa-install__close {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		border: none;
		border-radius: var(--radius-chip);
		background: transparent;
		color: var(--color-muted);
		font-size: 1.2rem;
		line-height: 1;
		cursor: pointer;
	}

	.pokemon-pwa-install__close:hover,
	.pokemon-pwa-install__close:focus-visible {
		color: var(--color-text);
		background: color-mix(in srgb, var(--color-surface-2) 70%, transparent);
	}

	@media (display-mode: standalone) {
		.pokemon-pwa-install {
			display: none;
		}
	}
</style>

<script>
	const DISMISS_KEY = 'pokedex-pwa-install-dismissed';

	type InstallPromptEvent = Event & {
		prompt: () => Promise<void>;
		userChoice: Promise<{ outcome: 'accepted' | 'dismissed' }>;
	};

	const setupInstallHint = () => {
		const root = document.getElementById('pokemon-pwa-install');
		const installBtn = document.getElementById('pokemon-pwa-install-btn');
		const dismissBtn = document.getElementById('pokemon-pwa-install-dismiss');
		if (!root || !installBtn || !dismissBtn) return;

		let deferredPrompt: InstallPromptEvent | null = null;

		const hide = () => {
			root.hidden = true;
		};

		const showIfEligible = () => {
			if (window.matchMedia('(display-mode: standalone)').matches) {
				hide();
				return;
			}
			try {
				if (localStorage.getItem(DISMISS_KEY) === '1') return;
			} catch {
				/* ignore */
			}
			if (deferredPrompt) root.hidden = false;
		};

		window.addEventListener('beforeinstallprompt', (event) => {
			event.preventDefault();
			deferredPrompt = event as InstallPromptEvent;
			showIfEligible();
		});

		installBtn.addEventListener('click', async () => {
			if (!deferredPrompt) return;
			deferredPrompt.prompt();
			await deferredPrompt.userChoice;
			deferredPrompt = null;
			hide();
		});

		dismissBtn.addEventListener('click', () => {
			try {
				localStorage.setItem(DISMISS_KEY, '1');
			} catch {
				/* ignore */
			}
			hide();
		});

		showIfEligible();
	};

	setupInstallHint();
	document.addEventListener('astro:page-load', setupInstallHint);
</script>
