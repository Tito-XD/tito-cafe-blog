---
interface NavItem {
	name: string;
	href: string;
	children?: NavItem[];
}

interface Props {
	currentNav?: string;
	compact?: boolean;
}

const { currentNav, compact = false } = Astro.props;

const navs: NavItem[] = [
	{ name: 'Home', href: '/' },
	{
		name: 'Blog',
		href: '/blog',
		children: [
			{ name: 'Tags', href: '/tags' },
			{ name: 'Timeline', href: '/archives' },
		],
	},
	{ name: 'Gallery', href: '/gallery' },
	{ name: 'Friends', href: '/friends' },
	{ name: 'About', href: '/about' },
];

const isActive = (nav: NavItem) =>
	currentNav === nav.name || nav.children?.some((child) => currentNav === child.name);
---

<nav>
	<ul
		class:list={[
			'font-default-sans',
			compact ? 'grid grid-cols-2 gap-2' : 'flex flex-col gap-3 lg:flex-row lg:items-center',
		]}
	>
		{
			navs.map((nav) => {
				const active = isActive(nav);
				const hasChildren = Boolean(nav.children?.length);
				return (
					<li class:list={['nav-item', hasChildren && 'nav-item--has-children', compact && 'nav-item--compact']}>
						<a
							href={nav.href}
							class="nav-link ui-type-link ui-pressable"
							data-text={nav.name}
							aria-label={`Navigate to ${nav.name}`}
							aria-current={active ? 'page' : undefined}
							data-compact={compact ? 'true' : 'false'}
						>
							<span class="ui-type-link__text">{nav.name}</span>
						</a>
						{
							hasChildren && (
								compact ? (
									<div class="nav-children-inline">
										{nav.children!.map((child) => (
											<a
												href={child.href}
												class="nav-child-link ui-pressable"
												aria-label={`Navigate to ${child.name}`}
												aria-current={currentNav === child.name ? 'page' : undefined}
											>
												{child.name}
											</a>
										))}
									</div>
								) : (
									<div class="nav-dropdown" aria-label={`${nav.name} links`}>
										{nav.children!.map((child) => (
											<a
												href={child.href}
												class="nav-child-link ui-pressable"
												aria-label={`Navigate to ${child.name}`}
												aria-current={currentNav === child.name ? 'page' : undefined}
											>
												{child.name}
											</a>
										))}
									</div>
								)
							)
						}
					</li>
				);
			})
		}
	</ul>
</nav>

<style>
	.nav-item {
		position: relative;
	}

	.nav-item--compact {
		display: contents;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 0;
		border-radius: var(--radius-button);
		padding: 0.45rem 0.8rem;
		color: var(--color-text);
		opacity: 0.78;
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.nav-link[data-compact='true'] {
		width: 100%;
		padding: 0.6rem 0.8rem;
		font-size: 0.98rem;
	}

	.nav-link:hover,
	.nav-link:focus-visible,
	.nav-link[aria-current='page'] {
		opacity: 1;
	}

	.nav-dropdown {
		position: absolute;
		top: calc(100% + 0.55rem);
		left: 50%;
		z-index: 20;
		display: grid;
		min-width: 10rem;
		gap: 0.35rem;
		padding: 0.55rem;
		border-radius: calc(var(--radius-card) - 0.1rem);
		border: 1px solid color-mix(in srgb, var(--color-border) 82%, var(--color-accent-soft));
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--color-surface) 96%, var(--color-accent-soft) 4%),
				color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-2) 10%)
			);
		box-shadow:
			0 1rem 2rem rgba(var(--color-shadow-rgb), 0.12),
			0 0 0 1px rgba(255, 255, 255, 0.04) inset;
		opacity: 0;
		pointer-events: none;
		transform: translateX(-50%) translateY(-0.35rem);
		transition:
			opacity var(--motion-gentle),
			transform var(--motion-gentle);
	}

	.nav-item--has-children:hover .nav-dropdown,
	.nav-item--has-children:focus-within .nav-dropdown {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(-50%) translateY(0);
	}

	.nav-children-inline {
		grid-column: span 2;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: -0.2rem;
		padding: 0 0.1rem 0.15rem;
	}

	.nav-child-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-chip);
		padding: 0.42rem 0.78rem;
		font-size: 0.84rem;
		line-height: 1.2;
		color: var(--color-muted);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.nav-child-link:hover,
	.nav-child-link:focus-visible,
	.nav-child-link[aria-current='page'] {
		color: var(--color-accent);
	}

	@media (max-width: 1023px) {
		.nav-item:not(.nav-item--compact) {
			display: block;
		}
	}
</style>
