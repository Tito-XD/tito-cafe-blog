---
interface Props {
	currentNav?: string;
}
const { currentNav } = Astro.props;

const navs = [
	{ name: 'Home', href: '/' },
	{ name: 'Blog', href: '/blog' },
	{ name: 'Friends', href: '/friends' },
	{ name: 'Tags', href: '/tags' },
	{ name: 'Archives', href: '/archives' },
	{ name: 'About', href: '/about' },
];
---

<nav>
	<ul class="flex flex-col gap-3 font-default-sans lg:flex-row">
		{
			navs.map((nav) => (
				<li>
					<a
						href={nav.href}
						class="nav-link"
						aria-label={`Navigate to ${nav.name}`}
						aria-current={currentNav === nav.name ? 'page' : undefined}
					>
						{nav.name}
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		border: 1px solid transparent;
		padding: 0.45rem 0.8rem;
		color: var(--color-text);
		opacity: 0.78;
		text-decoration: none;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			background 220ms ease,
			color 220ms ease,
			opacity 220ms ease;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 90%, var(--color-accent-soft) 10%);
		opacity: 1;
		color: var(--color-accent);
	}

	.nav-link[aria-current='page'] {
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 86%, var(--color-accent-soft) 14%);
		color: var(--color-accent);
		opacity: 1;
	}
</style>
