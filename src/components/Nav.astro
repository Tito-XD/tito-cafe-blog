---
interface Props {
	currentNav?: string;
	compact?: boolean;
}
const { currentNav, compact = false } = Astro.props;

const navs = [
	{ name: 'Home', href: '/' },
	{ name: 'Blog', href: '/blog' },
	{ name: 'Gallery', href: '/gallery' },
	{ name: 'Friends', href: '/friends' },
	{ name: 'About', href: '/about' },
];
---

<nav>
	<ul class:list={['font-default-sans', compact ? 'grid grid-cols-2 gap-2 sm:grid-cols-3' : 'flex flex-col gap-3 lg:flex-row']}>
		{
			navs.map((nav) => (
				<li>
					<a
						href={nav.href}
						class="nav-link ui-type-link ui-pressable"
						data-text={nav.name}
						aria-label={`Navigate to ${nav.name}`}
						aria-current={currentNav === nav.name ? 'page' : undefined}
						data-compact={compact ? 'true' : 'false'}
					>
						<span class="ui-type-link__text">{nav.name}</span>
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 0;
		border-radius: var(--radius-button);
		padding: 0.45rem 0.8rem;
		color: var(--color-text);
		opacity: 0.78;
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.nav-link[data-compact='true'] {
		width: 100%;
		padding: 0.6rem 0.8rem;
		font-size: 0.98rem;
	}

	.nav-link:hover,
	.nav-link:focus-visible,
	.nav-link[aria-current='page'] {
		opacity: 1;
	}
</style>
