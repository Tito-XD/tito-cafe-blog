---
interface Props {
	currentNav?: string;
}
const { currentNav } = Astro.props;

const navs = [
	{ name: 'Home', href: '/' },
	{ name: 'Blog', href: '/blog' },
	{ name: 'Friends', href: '/friends' },
	{ name: 'Tags', href: '/tags' },
	{ name: 'Archives', href: '/archives' },
	{ name: 'About', href: '/about' },
];
---

<nav>
	<ul class="flex flex-col gap-3 font-default-sans lg:flex-row">
		{
			navs.map((nav) => (
				<li>
					<a
						href={nav.href}
						class="nav-link ui-type-link ui-pressable"
						data-text={nav.name}
						aria-label={`Navigate to ${nav.name}`}
						aria-current={currentNav === nav.name ? 'page' : undefined}
					>
						<span class="ui-type-link__text">{nav.name}</span>
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-button);
		padding: 0.45rem 0.8rem;
		color: var(--color-text);
		opacity: 0.78;
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.nav-link:hover,
	.nav-link:focus-visible,
	.nav-link[aria-current='page'] {
		opacity: 1;
	}
</style>
