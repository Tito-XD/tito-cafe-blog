---
import { Icon } from 'astro-icon/components';
import { Hide, SiteDescription } from '~/config';
import type { EnabledSocialLink } from '~/utils/socials';
import HeaderActions from './HeaderActions.astro';
import HeaderSocialLinks from './HeaderSocialLinks.astro';
import Nav from './Nav.astro';

interface Props {
	currentNav?: string;
	socials: EnabledSocialLink[];
}

const { currentNav, socials } = Astro.props;
---

<button
	transition:persist
	data-mobile-menu-trigger
	class="mobile-menu-trigger ui-pressable justify-self-end lg:hidden"
	title="open menu"
	aria-label="open menu"
	aria-expanded="false"
	aria-controls="mobile-drawer"
>
	<Icon name="ri:apps-2-line" class="mobile-menu-trigger__icon" />
</button>

<div
	id="mobile-drawer"
	data-mobile-menu
	class="mobile-drawer lg:hidden"
	data-state="closed"
	aria-hidden="true"
>
	<aside class="mobile-drawer__panel" aria-label="Mobile navigation">
		<div class="mobile-drawer__header">
			<span class="mobile-drawer__eyebrow">Menu</span>
			<button
				type="button"
				data-mobile-menu-close
				class="mobile-menu-close ui-pressable"
				title="close menu"
				aria-label="close menu"
			>
				<Icon name="ri:close-line" />
			</button>
		</div>
		<div class="mobile-menu-surface">
			<Nav currentNav={currentNav} compact />
			<HeaderActions mobile />
			{!Hide.includes('siteDescription') && <p class="mobile-menu-description">{SiteDescription}</p>}
			<HeaderSocialLinks socials={socials} mobile />
		</div>
	</aside>
</div>

<style>
	.mobile-drawer {
		position: absolute;
		top: calc(100% + 0.75rem);
		left: 50%;
		z-index: 40;
		width: min(21rem, calc(100vw - 2.5rem), calc(100% - 0.5rem));
		pointer-events: none;
		transform: translateX(-50%);
	}

	.mobile-drawer[data-state='open'] {
		pointer-events: auto;
	}

	.mobile-drawer__panel {
		display: grid;
		grid-template-rows: auto minmax(0, 1fr);
		gap: 0.9rem;
		width: 100%;
		max-height: min(72dvh, calc(100dvh - 7rem));
		padding: 1rem;
		border-radius: 1.35rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 82%, var(--color-accent-soft));
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--color-surface) 96%, var(--color-accent-soft) 4%),
				color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-2) 10%)
			);
		box-shadow:
			0 1.1rem 2.6rem rgba(var(--color-shadow-rgb), 0.16),
			0 0 0 1px rgba(255, 255, 255, 0.04) inset;
		opacity: 0;
		transform: translateY(-0.5rem) scale(0.98);
		transform-origin: top center;
		transition:
			transform var(--motion-lift),
			opacity var(--motion-gentle);
		will-change: transform;
		overflow: hidden;
	}

	.mobile-drawer[data-state='open'] .mobile-drawer__panel {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.mobile-drawer__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding-bottom: 0.15rem;
	}

	.mobile-drawer__eyebrow {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.mobile-menu-surface {
		display: grid;
		gap: 0.9rem;
		align-content: start;
		padding: 0.25rem 0 0;
		min-height: 0;
		overflow-y: auto;
		padding-bottom: 0.35rem;
		-webkit-overflow-scrolling: touch;
	}

	.mobile-menu-description {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		text-align: left;
		color: var(--color-muted);
	}

	.mobile-menu-trigger,
	.mobile-menu-close {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text);
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.mobile-menu-trigger {
		height: 3rem;
		width: 3rem;
		border-radius: 1rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-soft) 8%);
		box-shadow: 0 0.55rem 1.4rem rgba(var(--color-shadow-rgb), 0.08);
	}

	.mobile-menu-close {
		height: 2.15rem;
		width: 2.15rem;
	}

	.mobile-menu-trigger:hover,
	.mobile-menu-trigger:focus-visible,
	.mobile-menu-trigger[aria-expanded='true'] {
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 86%, var(--color-accent-soft) 14%);
		color: var(--color-accent);
		box-shadow: 0 0.85rem 1.8rem rgba(var(--color-shadow-rgb), 0.14);
	}

	.mobile-menu-trigger__icon {
		width: 1.4rem;
		height: 1.4rem;
	}

	@media (min-width: 1024px) {
		.mobile-menu-trigger,
		.mobile-drawer {
			display: none !important;
		}
	}

	@media (max-width: 767px) {
		.mobile-drawer__panel {
			max-height: min(76dvh, calc(100dvh - 6rem));
		}

		.mobile-drawer {
			width: min(19.5rem, calc(100vw - 2rem), calc(100% - 0.25rem));
		}

		.mobile-menu-trigger {
			height: 2.8rem;
			width: 2.8rem;
		}
	}
</style>

<script>
	const setupMobileDrawer = () => {
		const windowWithCleanup = window as Window & {
			__revampedMenuCleanup?: () => void;
		};
		windowWithCleanup.__revampedMenuCleanup?.();

		const root = document.documentElement;
		const button = document.querySelector('[data-mobile-menu-trigger]');
		const drawer = document.querySelector('[data-mobile-menu]');
		const closeButton = document.querySelector('[data-mobile-menu-close]');
		if (
			!(button instanceof HTMLButtonElement) ||
			!(drawer instanceof HTMLElement) ||
			!(closeButton instanceof HTMLButtonElement)
		) {
			return;
		}

		const links = Array.from(drawer.querySelectorAll('a'));

		const closeDrawer = () => {
			drawer.setAttribute('data-state', 'closed');
			drawer.setAttribute('aria-hidden', 'true');
			button.setAttribute('aria-expanded', 'false');
			button.setAttribute('aria-label', 'open menu');
			root.style.removeProperty('overflow');
		};

		const openDrawer = () => {
			drawer.setAttribute('data-state', 'open');
			drawer.setAttribute('aria-hidden', 'false');
			button.setAttribute('aria-expanded', 'true');
			button.setAttribute('aria-label', 'close menu');
			root.style.overflow = 'hidden';
		};

		const toggleDrawer = () => {
			if (window.matchMedia('(min-width: 1024px)').matches) {
				closeDrawer();
				return;
			}
			if (drawer.getAttribute('data-state') === 'open') {
				closeDrawer();
				return;
			}
			openDrawer();
		};

		const handleKeydown = (event: KeyboardEvent) => {
			if (event.key === 'Escape') {
				closeDrawer();
			}
		};

		const handlePointerDown = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Node)) {
				return;
			}
			if (drawer.contains(target) || button.contains(target)) {
				return;
			}
			closeDrawer();
		};

		const handleResize = () => {
			if (window.matchMedia('(min-width: 1024px)').matches) {
				closeDrawer();
			}
		};

		button.addEventListener('click', toggleDrawer);
		closeButton.addEventListener('click', closeDrawer);
		links.forEach((link) => link.addEventListener('click', closeDrawer));
		document.addEventListener('mousedown', handlePointerDown);
		document.addEventListener('keydown', handleKeydown);
		window.addEventListener('resize', handleResize);

		windowWithCleanup.__revampedMenuCleanup = () => {
			closeDrawer();
			button.removeEventListener('click', toggleDrawer);
			closeButton.removeEventListener('click', closeDrawer);
			links.forEach((link) => link.removeEventListener('click', closeDrawer));
			document.removeEventListener('mousedown', handlePointerDown);
			document.removeEventListener('keydown', handleKeydown);
			window.removeEventListener('resize', handleResize);
		};
	};

	setupMobileDrawer();
	document.addEventListener('astro:page-load', setupMobileDrawer);
</script>
