---
import SplitHero from '~/components/SplitHero.astro';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
---

<ScaffoldLayout title="About" description="About this template." currentNav="About">
	<SplitHero title="About" className="about-intro">
		<img
			slot="art"
			class="about-intro__art"
			src="/sample/about-hero.svg"
			alt="Sample about hero for Revamped Astro Zozo"
		/>
		<p>Revamped Astro Zozo is a derivative theme branch shaped from a heavily customized Astro blog codebase.</p>
		<p>
			Compared with the original Astro Zozo baseline, it adds a gallery system, friends
			page, warmer theme tokens, compact mobile navigation, and a cleaner content structure
			for markdown-driven pages.
		</p>
		<p>
			Use it as a starting point, swap the sample content, and keep only the pieces that fit
			your own writing and visual rhythm.
		</p>
	</SplitHero>
</ScaffoldLayout>

<style>
	.about-intro__art {
		width: 100%;
		max-width: min(100%, 18rem);
		border-radius: calc(var(--radius-card) + 0.15rem);
		box-shadow:
			0 1rem 2.1rem rgba(var(--color-shadow-rgb), 0.12),
			inset 0 1px 0 color-mix(in srgb, white 50%, transparent);
	}
</style>
