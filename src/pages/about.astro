---
import { Picture } from 'astro:assets';
import img from '~/assets/tito_xd-walk-by-frankuwu.png';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
---

<ScaffoldLayout title="关于" description="关于这个站点与站长" currentNav="About">
	<section class="about-intro">
		<Picture
			class="about-intro__art"
			src={img}
			formats={['avif', 'webp', 'png']}
			alt="Tito_XD original character walking posture by artist Frankuwu"
		/>
		<div class="about-intro__copy">
			<h1 class="about-intro__title">About</h1>
			<div class="about-intro__body">
				<p>nameless nobody but still exploring this world.</p>
				<p>want to make 21 grams interesting.</p>
				<p>lives in Hubei, Wuhan and working as marketing, website maintainer.</p>
			</div>
		</div>
	</section>
</ScaffoldLayout>

<style>
	.about-intro {
		display: grid;
		gap: 1.15rem;
		align-items: center;
		width: min(100%, 58rem);
		margin: 0 auto;
		padding: clamp(1rem, 4vh, 2.5rem) 0 clamp(0.5rem, 2vh, 1rem);
	}

	.about-intro__art {
		max-width: min(100%, 21rem);
		justify-self: center;
	}

	.about-intro__copy {
		display: grid;
		gap: 0.95rem;
		max-width: 39rem;
	}

	.about-intro__title {
		margin: 0;
		font-size: clamp(2rem, 4.2vw, 3rem);
		font-weight: 800;
		line-height: 1.12;
		letter-spacing: -0.02em;
		text-wrap: balance;
	}

	.about-intro__body {
		display: grid;
		gap: 0.85rem;
	}

	.about-intro__body p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.9;
		color: color-mix(in srgb, var(--color-text) 92%, var(--color-muted));
		text-wrap: pretty;
	}

	@media (min-width: 1024px) {
		.about-intro {
			grid-template-columns: minmax(15rem, 21rem) minmax(0, 1fr);
			gap: 1.75rem;
		}

		.about-intro__art {
			justify-self: center;
		}
	}
</style>
