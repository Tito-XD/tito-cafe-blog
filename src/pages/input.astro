---
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
---

<ScaffoldLayout title="Thoughts Input" description="Input your thoughts here.">
	<div class="thoughts-input-container">
		<h1 class="thoughts-input-title">随想</h1>
		<p class="thoughts-input-subtitle">记录当下的想法</p>
		<textarea
			id="thought-content"
			class="thoughts-textarea"
			placeholder="在这里写下你的想法..."
		></textarea>
		<div class="thoughts-input-actions">
			<button id="save-btn" class="thoughts-save-btn">保存</button>
			<a href="/thoughts" class="thoughts-view-btn">查看随想</a>
		</div>
		<div id="message" class="thoughts-message"></div>
	</div>
</ScaffoldLayout>

<style>
	.thoughts-input-container {
		max-width: 48rem;
		margin: 2rem auto;
		padding: 1.5rem;
		border-radius: var(--radius-card);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--color-surface) 96%, var(--color-accent-soft) 4%),
			color-mix(in srgb, var(--color-surface) 94%, var(--color-surface-2) 6%)
		);
	}

	.thoughts-input-title {
		margin: 0 0 0.5rem 0;
		font-size: clamp(2rem, 4vw, 2.5rem);
		line-height: 1.1;
		text-wrap: balance;
	}

	.thoughts-input-subtitle {
		margin: 0 0 1.5rem 0;
		color: var(--color-muted);
		font-size: 1.05rem;
	}

	.thoughts-textarea {
		width: 100%;
		min-height: 12rem;
		padding: 1rem;
		border-radius: var(--radius-chip);
		border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-accent-soft));
		background: var(--color-surface-2);
		color: var(--color-text);
		font-size: 1rem;
		line-height: 1.6;
		resize: vertical;
		font-family: var(--font-default-sans);
		transition:
			border-color var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.thoughts-textarea:focus {
		outline: none;
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
	}

	.thoughts-textarea::placeholder {
		color: var(--color-muted);
		opacity: 0.7;
	}

	.thoughts-input-actions {
		display: flex;
		gap: 0.75rem;
		margin-top: 1rem;
	}

	.thoughts-save-btn,
	.thoughts-view-btn {
		border-radius: var(--radius-chip);
		padding: 0.6rem 1.2rem;
		font-size: 0.98rem;
		font-weight: 500;
		text-decoration: none;
		cursor: pointer;
		transition:
			transform var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			box-shadow var(--motion-gentle);
	}

	.thoughts-save-btn {
		border: 1px solid color-mix(in srgb, var(--color-accent) 56%, var(--color-border));
		background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface));
		color: var(--color-accent);
	}

	.thoughts-save-btn:hover {
		transform: translateY(-1px);
		background: color-mix(in srgb, var(--color-accent) 20%, var(--color-surface));
		box-shadow: 0 0.3rem 0.6rem rgba(var(--color-shadow-rgb), 0.12);
	}

	.thoughts-view-btn {
		border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-soft) 8%);
		color: var(--color-muted);
	}

	.thoughts-view-btn:hover {
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 84%, var(--color-accent-soft) 16%);
		color: var(--color-accent);
	}

	.thoughts-message {
		margin-top: 1rem;
		min-height: 1.5rem;
		font-size: 0.95rem;
		opacity: 0;
		transition: opacity var(--motion-gentle);
	}

	.thoughts-message.show {
		opacity: 1;
	}

	.thoughts-message.success {
		color: color-mix(in srgb, #10b981 85%, var(--color-surface));
	}

	.thoughts-message.error {
		color: color-mix(in srgb, #ef4444 85%, var(--color-surface));
	}
</style>

<script>
	function setupThoughtsInput() {
		const windowWithCleanup = window as Window & {
			__thoughtsInputCleanup?: () => void;
		};
		windowWithCleanup.__thoughtsInputCleanup?.();

		const textarea = document.getElementById('thought-content') as HTMLTextAreaElement;
		const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
		const messageEl = document.getElementById('message') as HTMLDivElement;

		const showMessage = (text: string, type: 'success' | 'error') => {
			messageEl.textContent = text;
			messageEl.className = `thoughts-message show ${type}`;
			setTimeout(() => {
				messageEl.className = 'thoughts-message';
			}, 2500);
		};

		const saveThought = () => {
			const content = textarea.value.trim();
			if (!content) {
				showMessage('请输入内容', 'error');
				return;
			}

			try {
				const existing = localStorage.getItem('thoughts');
				const thoughts = existing ? JSON.parse(existing) : [];
				const newThought = {
					id: crypto.randomUUID(),
					content,
					timestamp: new Date().toISOString()
				};
				thoughts.unshift(newThought);
				localStorage.setItem('thoughts', JSON.stringify(thoughts));
				textarea.value = '';
				showMessage('保存成功', 'success');
			} catch (error) {
				showMessage('保存失败', 'error');
			}
		};

		saveBtn?.addEventListener('click', saveThought);

		textarea?.addEventListener('keydown', (e) => {
			if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
				saveThought();
			}
		});

		windowWithCleanup.__thoughtsInputCleanup = () => {
			saveBtn?.removeEventListener('click', saveThought);
		};
	}

	setupThoughtsInput();
	document.addEventListener('astro:page-load', setupThoughtsInput);
</script>
