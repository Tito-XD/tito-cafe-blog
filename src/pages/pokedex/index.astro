---
import PageHeading from '~/components/PageHeading.astro';
import PokemonDex from '~/components/pokemon/PokemonDex.astro';
import PokemonDexGridStyles from '~/components/pokemon/PokemonDexGridStyles.astro';
import PokemonRegionNav from '~/components/pokemon/PokemonRegionNav.astro';
import pokemonChains from '~/data/pokemon-chains.json';
import pokemonAll from '~/data/pokemon.json';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';

const artworkBase = '/pokemon/artwork';
---

<ScaffoldLayout
	title="全国图鉴"
	description="宝可梦全国图鉴速查，支持传说、幻、悖谬、形态与地区形态交叉筛选，可按世代地区切换。"
>
	<PageHeading title="全国图鉴" />
	<p class="pokedex-lead">
		全国图鉴 #{String(pokemonAll.length).padStart(4, '0')} 只宝可梦速查。可切换下方各地区图鉴，或使用筛选交叉查看传说、幻、悖谬、特殊形态与地区形态。数据来自
		<a href="https://pokeapi.co/" target="_blank" rel="noreferrer noopener">PokeAPI</a>
		与
		<a href="https://wiki.52poke.com/" target="_blank" rel="noreferrer noopener">神奇宝贝百科</a>。
	</p>

	<PokemonRegionNav />
	<PokemonDex
		dexId="national"
		pokemonList={pokemonAll}
		chains={pokemonChains}
		artworkBase={artworkBase}
		showFilters={true}
		dexScope="national"
	/>

	<p class="pokedex-copy">
		宝可梦、Pokémon 及相关素材为 Nintendo / Creatures Inc. / GAME FREAK inc. 的商标或版权资产。立绘来自
		<a href="https://github.com/PokeAPI/sprites" target="_blank" rel="noreferrer noopener">PokeAPI Sprites</a>。
		本页为个人学习向速查工具，与任天堂等公司无关联。
	</p>
</ScaffoldLayout>

<PokemonDexGridStyles />

<style>
	.pokedex-lead {
		margin: 0 0 1rem;
		max-width: 42rem;
		color: var(--color-muted);
		line-height: 1.75;
	}

	.pokedex-copy {
		margin: 1.5rem 0 0;
		max-width: 42rem;
		font-size: 0.82rem;
		color: var(--color-muted);
		line-height: 1.65;
	}
</style>
