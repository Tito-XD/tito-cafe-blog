---
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { friends, type FriendLink } from '~/data/friends';

const trim = (value?: string) => value?.trim() ?? '';

const normalizedFriends = friends
	.map((friend: FriendLink) => ({
		id: trim(friend.id),
		avatar: trim(friend.avatar),
		bio: trim(friend.bio),
		link: trim(friend.link),
	}))
	.filter((friend) => friend.id || friend.avatar || friend.bio || friend.link);

const collator = new Intl.Collator(['zh-Hans-u-co-pinyin', 'zh', 'en'], {
	numeric: true,
	sensitivity: 'base',
});

const getSortKey = (friend: (typeof normalizedFriends)[number]) =>
	friend.id || friend.link || friend.bio || '';

const sortedFriends = [...normalizedFriends].sort((a, b) =>
	collator.compare(getSortKey(a), getSortKey(b)),
);

const toAvatarCssVar = (avatar: string) =>
	avatar ? `url("${avatar.replaceAll('"', '\\"')}")` : 'none';

const toAriaLabel = (friend: (typeof sortedFriends)[number], index: number) =>
	friend.id || friend.link || `friend-${index + 1}`;
---

<ScaffoldLayout title="Friends" description="友情链接" currentNav="Friends">
	<h1 class="mb-3 text-5xl font-extrabold">Friends</h1>
	{
		sortedFriends.length > 0 ? (
			<div class="relative mt-8">
				<ul
					id="friends-track"
					class="grid w-full gap-4 px-2 py-3"
				>
					{
						sortedFriends.map((friend, index) => (
							<li
								class="friend-card group snap-start"
								data-friend-card
								data-open="false"
								data-has-avatar={friend.avatar ? 'true' : 'false'}
								style={`--friend-avatar: ${toAvatarCssVar(friend.avatar)};`}
							>
								<div class="friend-card-content">
									{
										(friend.avatar || friend.id) && (
											<button
												type="button"
												class="friend-card-trigger"
												data-friend-toggle
												aria-expanded="false"
												aria-label={`Toggle details for ${toAriaLabel(friend, index)}`}
											>
												{friend.avatar && (
													<img
														src={friend.avatar}
														alt={friend.id ? `${friend.id} avatar` : 'Friend avatar'}
														loading="lazy"
														decoding="async"
													/>
												)}
												{friend.id && <h2>{friend.id}</h2>}
											</button>
										)
									}

									{
										(friend.bio || friend.link) && (
											<div class="friend-details">
												{friend.bio && <p>{friend.bio}</p>}
												{friend.link && (
													<a href={friend.link} target="_blank" rel="noopener noreferrer">
														{friend.link}
													</a>
												)}
											</div>
										)
									}
								</div>
							</li>
						))
					}
				</ul>
			</div>
		) : (
			<div class="mt-8 rounded-2xl border border-dashed border-zinc-300 p-6 text-sm dark:border-zinc-700">
				<p>
					No friend links yet. Edit <code>src/data/friends.ts</code> to add avatar, ID, bio, and link.
				</p>
			</div>
		)
	}
</ScaffoldLayout>

<style is:global>
	#friends-track {
		scroll-behavior: smooth;
		align-items: stretch;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
		overflow: visible;
	}

	.friend-card {
		position: relative;
		display: flex;
		width: 100%;
		min-height: 10.5rem;
		aspect-ratio: 7 / 5;
		overflow: hidden;
		border-radius: 1rem;
		border: 1px solid rgb(228 228 231 / 0.9);
		background: rgb(250 250 250 / 0.95);
		box-shadow: 0 6px 20px rgb(9 9 11 / 0.05);
		transition: transform 320ms ease;
	}

	.friend-card::before,
	.friend-card::after {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 320ms ease;
		pointer-events: none;
	}

	.friend-card::before {
		background-image: var(--friend-avatar);
		background-size: cover;
		background-position: center;
		filter: blur(14px);
		transform: scale(1.08);
	}

	.friend-card::after {
		background: rgb(255 255 255 / 0.5);
	}

	:root:is(.dark) .friend-card {
		border-color: rgb(82 82 91 / 0.75);
		background: rgb(39 39 42 / 0.85);
		box-shadow: 0 10px 24px rgb(2 6 23 / 0.35);
	}

	:root:is(.dark) .friend-card::after {
		background: rgb(17 24 39 / 0.5);
	}

	@media (prefers-color-scheme: dark) {
		:root:not(.light) .friend-card {
			border-color: rgb(82 82 91 / 0.75);
			background: rgb(39 39 42 / 0.85);
			box-shadow: 0 10px 24px rgb(2 6 23 / 0.35);
		}

		:root:not(.light) .friend-card::after {
			background: rgb(17 24 39 / 0.5);
		}
	}

	.friend-card[data-has-avatar='false']::before,
	.friend-card[data-has-avatar='false']::after {
		display: none;
	}

	.friend-card:hover,
	.friend-card:focus-within,
	.friend-card[data-open='true'] {
		transform: scale(1.04);
		z-index: 2;
	}

	.friend-card:hover::before,
	.friend-card:hover::after,
	.friend-card:focus-within::before,
	.friend-card:focus-within::after,
	.friend-card[data-open='true']::before,
	.friend-card[data-open='true']::after {
		opacity: 1;
	}

	.friend-card-content {
		position: relative;
		z-index: 1;
		display: flex;
		height: 100%;
		width: 100%;
		flex-direction: column;
	}

	.friend-card-trigger {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.85rem;
		background: transparent;
		border: 0;
		text-align: left;
		color: inherit;
	}

	.friend-card-trigger img {
		height: 2.35rem;
		width: 2.35rem;
		flex-shrink: 0;
		border-radius: 999px;
		object-fit: cover;
		border: 1px solid rgb(212 212 216 / 0.85);
	}

	.friend-card-trigger h2 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.25;
		word-break: break-word;
	}

	.friend-details {
		margin-top: auto;
		display: grid;
		gap: 0.45rem;
		padding: 0 0.85rem 0.85rem;
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		transform: translateY(8px);
		transition: max-height 320ms ease, opacity 320ms ease, transform 320ms ease;
	}

	.friend-card:hover .friend-details,
	.friend-card:focus-within .friend-details,
	.friend-card[data-open='true'] .friend-details {
		max-height: 7.8rem;
		opacity: 1;
		transform: translateY(0);
	}

	.friend-details p {
		margin: 0;
		font-size: 0.84rem;
		line-height: 1.45;
	}

	.friend-details a {
		font-size: 0.8rem;
		text-decoration: underline;
		word-break: break-all;
	}

	@media (min-width: 640px) {
		#friends-track {
			grid-template-columns: repeat(2, minmax(0, 11.5rem));
		}
	}

	@media (min-width: 1024px) {
		#friends-track {
			grid-template-columns: repeat(3, minmax(0, 11.5rem));
		}
	}
</style>

<script is:inline type="module">
	const track = document.getElementById('friends-track');

	if (track) {
		const cards = Array.from(track.querySelectorAll('[data-friend-card]'));

		const setCardOpen = (card, open) => {
			card.setAttribute('data-open', open ? 'true' : 'false');
			const trigger = card.querySelector('[data-friend-toggle]');
			if (trigger) {
				trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
			}
		};

		const closeAll = (exceptCard = null) => {
			for (const card of cards) {
				if (exceptCard && card === exceptCard) {
					continue;
				}
				setCardOpen(card, false);
			}
		};

		track.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const trigger = target.closest('[data-friend-toggle]');
			if (!trigger) {
				return;
			}

			const card = trigger.closest('[data-friend-card]');
			if (!card) {
				return;
			}

			const willOpen = card.getAttribute('data-open') !== 'true';
			closeAll(card);
			setCardOpen(card, willOpen);
		});

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Node)) {
				return;
			}
			if (!track.contains(target)) {
				closeAll();
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeAll();
			}
		});
	}
</script>
