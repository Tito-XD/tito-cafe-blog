---
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { friends, type FriendLink } from '~/data/friends';

const trim = (value?: string) => value?.trim() ?? '';

const normalizedFriends = friends
	.map((friend: FriendLink) => ({
		id: trim(friend.id),
		avatar: trim(friend.avatar),
		bio: trim(friend.bio),
		link: trim(friend.link),
	}))
	.filter((friend) => friend.id || friend.avatar || friend.bio || friend.link);

const collator = new Intl.Collator(['zh-Hans-u-co-pinyin', 'zh', 'en'], {
	numeric: true,
	sensitivity: 'base',
});

const getSortKey = (friend: (typeof normalizedFriends)[number]) =>
	friend.id || friend.link || friend.bio || '';

const sortedFriends = [...normalizedFriends].sort((a, b) =>
	collator.compare(getSortKey(a), getSortKey(b)),
);

const toAvatarCssVar = (avatar: string) =>
	avatar ? `url("${avatar.replaceAll('"', '\\"')}")` : 'none';

const toAriaLabel = (friend: (typeof sortedFriends)[number], index: number) =>
	friend.id || friend.link || `friend-${index + 1}`;
---

<ScaffoldLayout title="友链" description="朋友们的链接" currentNav="Friends">
	<section class="page-heading">
		<h1 class="page-title">Friends</h1>
	</section>
	{
		sortedFriends.length > 0 ? (
			<div class="relative mt-4">
				<ul
					id="friends-track"
					class="grid w-full gap-4 px-2 py-3"
				>
					{
						sortedFriends.map((friend, index) => (
							<li
								class="friend-card group snap-start"
								data-friend-card
								data-open="false"
								data-has-avatar={friend.avatar ? 'true' : 'false'}
								style={`--friend-avatar: ${toAvatarCssVar(friend.avatar)};`}
							>
								<div class="friend-card-content">
									{
										(friend.avatar || friend.id) && (
											<button
												type="button"
												class="friend-card-trigger"
												data-friend-toggle
												aria-expanded="false"
												aria-label={`Toggle details for ${toAriaLabel(friend, index)}`}
											>
												{friend.avatar && (
													<img
														src={friend.avatar}
														alt={friend.id ? `${friend.id} avatar` : 'Friend avatar'}
														loading="lazy"
														decoding="async"
													/>
												)}
												{friend.id && <h2>{friend.id}</h2>}
											</button>
										)
									}

									{
										(friend.bio || friend.link) && (
											<div class="friend-details">
												{friend.bio && <p>{friend.bio}</p>}
												{friend.link && (
													<a href={friend.link} target="_blank" rel="noopener noreferrer">
														{friend.link}
													</a>
												)}
											</div>
										)
									}
								</div>
							</li>
						))
					}
				</ul>
			</div>
		) : (
			<div class="mt-8 rounded-[var(--radius-card)] border border-dashed border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6 text-sm text-[var(--color-muted)]">
				<p>
					No friend links yet. Edit <code>src/data/friends.ts</code> to add avatar, ID, bio, and link.
				</p>
			</div>
		)
	}
</ScaffoldLayout>

<style is:global>
	#friends-track {
		scroll-behavior: smooth;
		align-items: stretch;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
		overflow: visible;
	}

	.friend-card {
		position: relative;
		display: flex;
		width: 100%;
		min-height: 10.5rem;
		aspect-ratio: 7 / 5;
		overflow: hidden;
		border-radius: var(--radius-soft);
		border: 1px solid var(--color-border);
		background: linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 95%, var(--color-accent-soft) 5%), color-mix(in srgb, var(--color-surface) 78%, var(--color-surface-2)));
		box-shadow: 0 0.75rem 1.6rem rgba(var(--color-shadow-rgb), 0.08);
		transition: transform 320ms ease;
	}

	.friend-card::before,
	.friend-card::after {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 320ms ease;
		pointer-events: none;
	}

	.friend-card::before {
		background-image: var(--friend-avatar);
		background-size: cover;
		background-position: center;
		filter: blur(14px);
		transform: scale(1.08);
	}

	.friend-card::after {
		background: color-mix(in srgb, var(--color-surface) 54%, transparent);
	}

	.friend-card[data-has-avatar='false']::before,
	.friend-card[data-has-avatar='false']::after {
		display: none;
	}

	.friend-card:hover,
	.friend-card:focus-within,
	.friend-card[data-open='true'] {
		transform: scale(1.04);
		z-index: 2;
	}

	.friend-card:hover::before,
	.friend-card:hover::after,
	.friend-card:focus-within::before,
	.friend-card:focus-within::after,
	.friend-card[data-open='true']::before,
	.friend-card[data-open='true']::after {
		opacity: 1;
	}

	.friend-card-content {
		position: relative;
		z-index: 1;
		display: flex;
		height: 100%;
		width: 100%;
		flex-direction: column;
	}

	.friend-card-trigger {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.85rem;
		background: transparent;
		border: 0;
		text-align: left;
		color: inherit;
	}

	.friend-card-trigger img {
		height: 2.35rem;
		width: 2.35rem;
		flex-shrink: 0;
		border-radius: 999px;
		object-fit: cover;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-surface));
	}

	.friend-card-trigger h2 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.25;
		word-break: break-word;
	}

	.friend-details {
		margin-top: auto;
		display: grid;
		gap: 0.45rem;
		padding: 0 0.85rem 0.85rem;
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		transform: translateY(8px);
		transition: max-height 320ms ease, opacity 320ms ease, transform 320ms ease;
	}

	.friend-card:hover .friend-details,
	.friend-card:focus-within .friend-details,
	.friend-card[data-open='true'] .friend-details {
		max-height: 7.8rem;
		opacity: 1;
		transform: translateY(0);
	}

	.friend-details p {
		margin: 0;
		font-size: 0.84rem;
		line-height: 1.45;
		color: color-mix(in srgb, var(--color-muted) 92%, var(--color-text));
	}

	.friend-details a {
		font-size: 0.8rem;
		color: var(--color-accent);
		text-decoration: underline;
		word-break: break-all;
	}
</style>

<script>
	function setupFriendsTrack() {
		const track = document.getElementById('friends-track');

		if (track) {
			const cards = Array.from(track.querySelectorAll('[data-friend-card]'));

			const setCardOpen = (card: Element, open: boolean) => {
				card.setAttribute('data-open', open ? 'true' : 'false');
				const trigger = card.querySelector('[data-friend-toggle]');
				if (trigger) {
					trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
				}
			};

			const closeAll = (exceptCard: Element | null = null) => {
				for (const card of cards) {
					if (exceptCard && card === exceptCard) {
						continue;
					}
					setCardOpen(card, false);
				}
			};

			track.addEventListener('click', (event) => {
				const target = event.target;
				if (!(target instanceof Element)) {
					return;
				}

				const trigger = target.closest('[data-friend-toggle]');
				if (!trigger) {
					return;
				}

				const card = trigger.closest('[data-friend-card]');
				if (!card) {
					return;
				}

				const willOpen = card.getAttribute('data-open') !== 'true';
				closeAll(card);
				setCardOpen(card, willOpen);
			});

			document.addEventListener('click', (event) => {
				const target = event.target;
				if (!(target instanceof Node)) {
					return;
				}
				if (!track.contains(target)) {
					closeAll();
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeAll();
				}
			});
		}
	}

	document.addEventListener('astro:page-load', setupFriendsTrack);
</script>



