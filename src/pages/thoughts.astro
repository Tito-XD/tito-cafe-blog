---
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
---

<ScaffoldLayout title="Thoughts" description="My thoughts and reflections.">
	<div class="thoughts-wrapper">
		<div class="thoughts-container">
			<div class="thoughts-header">
				<div class="thoughts-icon">
					<svg width="48" height="48" viewBox="0 0 48 48" fill="none">
						<path d="M24 4C12.95 4 4 12.95 4 24s8.95 20 20 20 20-8.95 20-20S35.05 4 24 4z" fill="currentColor" opacity="0.08"/>
						<path d="M24 8c-8.82 0-16 7.18-16 16s7.18 16 16 16 16-7.18 16-16-7.18-16-16-16zm0 28c-6.63 0-12-5.37-12-12s5.37-12 12-12 12 5.37 12 12-5.37 12-12 12z" fill="currentColor" opacity="0.12"/>
						<circle cx="24" cy="24" r="8" fill="currentColor" opacity="0.2"/>
						<circle cx="24" cy="24" r="4" fill="currentColor" opacity="0.4"/>
					</svg>
				</div>
				<h1 class="thoughts-title">随想</h1>
				<p class="thoughts-subtitle">记录此刻的想法</p>
			</div>

			<div id="thoughts-list" class="thoughts-list">
				<div class="thoughts-empty">
					<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
						<circle cx="32" cy="32" r="28" fill="currentColor" opacity="0.06"/>
						<path d="M32 24v16M24 32h16" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
					</svg>
					<p>暂无随想</p>
				</div>
			</div>

			<div class="thoughts-actions">
				<a href="/input" class="thoughts-add-btn">
					<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M10 4v12M4 10h12"/>
					</svg>
					<span>添加随想</span>
				</a>
			</div>
		</div>
	</div>
</ScaffoldLayout>

<style>
	.thoughts-wrapper {
		min-height: calc(100vh - 8rem);
		padding: 3rem 1.5rem;
		background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-2) 100%);
	}

	.thoughts-container {
		max-width: 40rem;
		margin: 0 auto;
	}

	.thoughts-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}

	.thoughts-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 1.5rem;
		background: linear-gradient(135deg, var(--color-accent) 0%, color-mix(in srgb, var(--color-accent) 70%, #6366f1) 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		animation: float 6s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-12px);
		}
	}

	.thoughts-title {
		font-size: clamp(2rem, 5vw, 2.5rem);
		font-weight: 700;
		margin: 0 0 0.5rem 0;
		background: linear-gradient(135deg, var(--color-text) 0%, color-mix(in srgb, var(--color-text) 70%, var(--color-accent)) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.thoughts-subtitle {
		font-size: 1rem;
		color: var(--color-muted);
		margin: 0;
		letter-spacing: 0.5px;
	}

	.thoughts-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.thought-item {
		background: var(--color-surface);
		border-radius: 16px;
		padding: 1.5rem;
		box-shadow:
			0 2px 4px -1px rgba(0, 0, 0, 0.06),
			0 1px 2px -1px rgba(0, 0, 0, 0.04),
			0 0 0 1px color-mix(in srgb, var(--color-border) 40%, transparent);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid color-mix(in srgb, var(--color-border) 20%, transparent);
		animation: slideIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.thought-item:hover {
		transform: translateX(8px);
		box-shadow:
			0 8px 16px -2px rgba(0, 0, 0, 0.1),
			0 4px 8px -2px rgba(0, 0, 0, 0.06);
		border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
	}

	.thought-content {
		margin: 0 0 1rem 0;
		color: var(--color-text);
		font-size: 1rem;
		line-height: 1.75;
		white-space: pre-wrap;
		word-wrap: break-word;
	}

	.thought-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1rem;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 20%, transparent);
	}

	.thought-time {
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 500;
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.thought-time::before {
		content: '';
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-accent);
	}

	.thought-delete {
		padding: 0.5rem 1rem;
		border-radius: 8px;
		border: 1px solid color-mix(in srgb, #ef4444 25%, transparent);
		background: transparent;
		color: color-mix(in srgb, #ef4444 90%, var(--color-text));
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.thought-delete:hover {
		background: color-mix(in srgb, #ef4444 8%, var(--color-surface));
		color: #ef4444;
		border-color: color-mix(in srgb, #ef4444 30%, transparent);
	}

	.thoughts-empty {
		text-align: center;
		padding: 4rem 2rem;
		color: var(--color-muted);
	}

	.thoughts-empty svg {
		margin: 0 auto 1.5rem;
		opacity: 0.5;
	}

	.thoughts-empty p {
		font-size: 1.05rem;
		margin: 0;
	}

	.thoughts-actions {
		text-align: center;
	}

	.thoughts-add-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 1rem 2rem;
		font-size: 0.95rem;
		font-weight: 600;
		color: white;
		background: linear-gradient(135deg, var(--color-accent) 0%, color-mix(in srgb, var(--color-accent) 70%, #6366f1) 100%);
		border: none;
		border-radius: 12px;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow:
			0 4px 6px -1px color-mix(in srgb, var(--color-accent) 40%, transparent),
			0 2px 4px -1px color-mix(in srgb, var(--color-accent) 30%, transparent);
	}

	.thoughts-add-btn:hover {
		transform: translateY(-2px);
		box-shadow:
			0 10px 15px -3px color-mix(in srgb, var(--color-accent) 40%, transparent),
			0 4px 6px -2px color-mix(in srgb, var(--color-accent) 30%, transparent);
	}

	.thoughts-add-btn:active {
		transform: translateY(0);
	}
</style>

<script>
	function setupThoughtsDisplay() {
		const windowWithCleanup = window as Window & {
			__thoughtsDisplayCleanup?: () => void;
		};
		windowWithCleanup.__thoughtsDisplayCleanup?.();

		const thoughtsList = document.getElementById('thoughts-list');

		const formatTime = (isoString: string) => {
			const date = new Date(isoString);
			const now = new Date();
			const diff = now.getTime() - date.getTime();
			const hours = Math.floor(diff / (1000 * 60 * 60));
			const days = Math.floor(hours / 24);

			if (hours < 1) {
				return '刚刚';
			} else if (hours < 24) {
				return `${hours} 小时前`;
			} else if (days < 7) {
				return `${days} 天前`;
			} else {
				return date.toLocaleDateString('zh-CN', {
					year: 'numeric',
					month: '2-digit',
					day: '2-digit'
				});
			}
		};

		const renderThoughts = () => {
			try {
				const existing = localStorage.getItem('thoughts');
				const thoughts = existing ? JSON.parse(existing) : [];

				if (thoughts.length === 0) {
					thoughtsList!.innerHTML = `
						<div class="thoughts-empty">
							<svg width="64" height="64" viewBox="0 0 64 64" fill="none">
								<circle cx="32" cy="32" r="28" fill="currentColor" opacity="0.06"/>
								<path d="M32 24v16M24 32h16" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
							</svg>
							<p>暂无随想</p>
						</div>
					`;
					return;
				}

				thoughtsList!.innerHTML = thoughts.map((thought: { id: string, content: string, timestamp: string }, index: number) => `
					<div class="thought-item" data-id="${thought.id}" style="animation-delay: ${index * 0.05}s">
						<p class="thought-content">${thought.content.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>
						<div class="thought-meta">
							<time class="thought-time">${formatTime(thought.timestamp)}</time>
							<button class="thought-delete" data-id="${thought.id}">
								<svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M2 3l1 7h6l1-7M3 3h6M4 1h4"/>
								</svg>
								删除
							</button>
						</div>
					</div>
				`).join('');

				document.querySelectorAll('.thought-delete').forEach((btn) => {
					btn.addEventListener('click', (e) => {
						const target = e.currentTarget as HTMLElement;
						const id = target.dataset.id;
						if (!id) return;

						const item = target.closest('.thought-item') as HTMLElement;
						if (item) {
							item.style.opacity = '0';
							item.style.transform = 'translateX(20px)';
						}

						setTimeout(() => {
							try {
								const existing = localStorage.getItem('thoughts');
								const thoughts = existing ? JSON.parse(existing) : [];
								const updated = thoughts.filter((t: { id: string }) => t.id !== id);
								localStorage.setItem('thoughts', JSON.stringify(updated));
								renderThoughts();
							} catch (error) {
								console.error('删除失败', error);
								if (item) {
									item.style.opacity = '1';
									item.style.transform = '';
								}
							}
						}, 200);
					});
				});
			} catch (error) {
				console.error('加载随想失败', error);
				thoughtsList!.innerHTML = `
					<div class="thoughts-empty">
						<p>加载失败</p>
					</div>
				`;
			}
		};

		renderThoughts();

		windowWithCleanup.__thoughtsDisplayCleanup = () => {
			document.querySelectorAll('.thought-delete').forEach((btn) => {
				btn.removeEventListener('click', () => {});
			});
		};
	}

	setupThoughtsDisplay();
	document.addEventListener('astro:page-load', setupThoughtsDisplay);
</script>
