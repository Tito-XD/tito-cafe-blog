---
import { SiteDescription, SiteTitle } from '~/config';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
---

<ScaffoldLayout title={SiteTitle} description={SiteDescription} currentNav="Home">
	<section class="home-intro">
		<img
			class="home-intro__art"
			src="/sample/home-hero.svg"
			alt="Sample hero illustration for Revamped Astro Zozo"
			loading="eager"
		/>
		<div class="home-intro__copy">
			<h1 class="home-intro__title">Revamped Astro Zozo<br />A warmer Astro starter.</h1>
			<div class="home-intro__body">
				<p>This branch turns the original Astro Zozo theme into a sample-first starter with a gallery, friends page, and more deliberate interaction patterns.</p>
				<p>It keeps the lightweight writing flow, then layers in a warmer visual system, a refined mobile menu, and content collections that are easier to extend.</p>
				<p>If you want to build a personal blog with room for illustration notes, curated links, and editorial landing pages, this branch is meant to be a cleaner starting point.</p>
				<p class="home-intro__links">
					<a href="/posts/template-overview">Read the template overview</a>,
					<a href="/posts/content-structure-guide">see the content structure guide</a>.
				</p>
			</div>
		</div>
	</section>
</ScaffoldLayout>

<style>
	.home-intro {
		display: grid;
		gap: 1.15rem;
		align-items: center;
		width: min(100%, 58rem);
		margin: 0 auto;
		padding: clamp(1rem, 4vh, 2.5rem) 0 clamp(0.5rem, 2vh, 1rem);
	}

	.home-intro__art {
		max-width: min(100%, 21rem);
		justify-self: center;
	}

	.home-intro__copy {
		display: grid;
		gap: 0.95rem;
		max-width: 39rem;
	}

	.home-intro__title {
		margin: 0;
		font-size: clamp(2rem, 4.2vw, 3rem);
		font-weight: 800;
		line-height: 1.12;
		letter-spacing: -0.02em;
		text-wrap: balance;
	}

	.home-intro__body {
		display: grid;
		gap: 0.85rem;
	}

	.home-intro__body p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.9;
		color: color-mix(in srgb, var(--color-text) 92%, var(--color-muted));
		text-wrap: pretty;
	}

	.home-intro__links {
		color: color-mix(in srgb, var(--color-text) 92%, var(--color-muted));
	}

	.home-intro__links a {
		color: var(--color-accent);
		text-decoration-color: color-mix(in srgb, var(--color-accent) 54%, transparent);
		text-underline-offset: 0.18em;
	}

	.home-intro__links a:hover,
	.home-intro__links a:focus-visible {
		color: color-mix(in srgb, var(--color-accent) 84%, var(--color-text));
	}

	@media (min-width: 1024px) {
		.home-intro {
			grid-template-columns: minmax(15rem, 21rem) minmax(0, 1fr);
			gap: 1.75rem;
		}

		.home-intro__art {
			justify-self: center;
		}
	}
</style>