---
import SplitHero from '~/components/SplitHero.astro';
import { SiteDescription, SiteTitle } from '~/config';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
---

<ScaffoldLayout title={SiteTitle} description={SiteDescription} currentNav="Home">
	<SplitHero title={`Revamped Astro Zozo\nA warmer Astro starter.`} className="home-intro">
		<img
			slot="art"
			class="home-intro__art"
			src="/sample/home-hero.svg"
			alt="Sample home hero for Revamped Astro Zozo"
			loading="eager"
		/>
		<p>
			This branch turns the original Astro Zozo theme into a sample-first starter with a
			gallery, friends page, and more deliberate interaction patterns.
		</p>
		<p>
			It keeps the lightweight writing flow, then layers in a warmer visual system, a
			refined mobile menu, and content collections that are easier to extend.
		</p>
		<p>
			If you want to build a writing-driven site with room for illustration notes, curated
			links, and editorial landing pages, this branch is meant to be a cleaner starting
			point.
		</p>
		<p class="home-intro__links">
			<a href="/posts/template-overview">Read the template overview</a>,
			<a href="/posts/content-structure-guide">see the content structure guide</a>.
		</p>
	</SplitHero>
</ScaffoldLayout>

<style>
	.home-intro__art {
		width: 100%;
		max-width: min(100%, 18rem);
		border-radius: calc(var(--radius-card) + 0.15rem);
		box-shadow:
			0 1rem 2.1rem rgba(var(--color-shadow-rgb), 0.12),
			inset 0 1px 0 color-mix(in srgb, white 50%, transparent);
	}

	.home-intro__links {
		color: color-mix(in srgb, var(--color-text) 92%, var(--color-muted));
	}

	.home-intro__links a {
		color: var(--color-accent);
		text-decoration-color: color-mix(in srgb, var(--color-accent) 54%, transparent);
		text-underline-offset: 0.18em;
	}

	.home-intro__links a:hover,
	.home-intro__links a:focus-visible {
		color: color-mix(in srgb, var(--color-accent) 84%, var(--color-text));
	}
</style>
