---
import BlogSectionTabs from '~/components/BlogSectionTabs.astro';
import PageHeading from '~/components/PageHeading.astro';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { getPosts } from '~/utils/collection';

const tagsCount = new Map<string, number>();
const posts = await getPosts(false, 'desc');
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		tagsCount.set(tag, (tagsCount.get(tag) ?? 0) + 1);
	}
}
---

<ScaffoldLayout title="Tags" description="Post tags" currentNav="Blog">
	<PageHeading title="Blog" className="tags-page-heading">
		<BlogSectionTabs active="tags" />
	</PageHeading>
	<div class="tags-intro">
		<p>Browse by tag.</p>
	</div>
	<div class="tags-cloud" aria-label="All tags">
		{
			[...tagsCount.entries()].map(([tag, count]) => (
				<a class="tag-chip ui-pressable" href={`/tags/${tag}/1`} aria-label={`More posts of tag ${tag}`}>
					<strong>{tag}</strong>
					<span>{count}</span>
				</a>
			))
		}
	</div>
</ScaffoldLayout>

<style>
	.tags-page-heading {
		padding-bottom: 0.55rem;
	}

	.tags-intro {
		padding-bottom: 1.2rem;
	}

	.tags-intro p {
		margin: 0;
		font-size: 0.98rem;
		color: var(--color-muted);
	}

	.tags-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.tag-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		border-radius: var(--radius-soft);
		padding: 0.9rem 1rem;
		color: inherit;
		text-decoration: none;
		transition:
			transform var(--motion-lift),
			background var(--motion-lift),
			box-shadow var(--motion-lift),
			color var(--motion-lift);
	}

	.tag-chip:hover,
	.tag-chip:focus-visible {
		color: var(--color-accent);
	}

	.tag-chip strong,
	.tag-chip span {
		display: block;
	}

	.tag-chip strong {
		font-size: 1rem;
		font-weight: 650;
	}

	.tag-chip span {
		border-radius: calc(var(--radius-chip) - 0.12rem);
		background: color-mix(in srgb, var(--color-accent-soft) 72%, var(--color-surface));
		padding: 0.2rem 0.55rem;
		font-size: 0.78rem;
		line-height: 1.2;
		color: var(--color-muted);
	}
</style>
