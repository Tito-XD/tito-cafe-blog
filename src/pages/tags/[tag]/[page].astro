---
import BlogSectionTabs from '~/components/BlogSectionTabs.astro';
import PageHeading from '~/components/PageHeading.astro';
import type { GetStaticPathsOptions } from 'astro';
import Paginator from '~/components/Paginator.astro';
import PostCard from '~/components/PostCard.astro';
import { PageSize } from '~/config';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { getPosts } from '~/utils/collection';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const allPosts = await getPosts(false, 'desc');
	const dedupTags = new Set<string>();
	for (const post of allPosts) {
		for (const tag of post.data.tags ?? []) {
			dedupTags.add(tag);
		}
	}
	return [...dedupTags].flatMap((tag) => {
		return paginate(
			allPosts.filter((post) => post.data.tags?.includes(tag) ?? false),
			{ params: { tag }, pageSize: PageSize },
		);
	});
}

const { page } = Astro.props;
const { tag } = Astro.params;
---

<ScaffoldLayout title={tag} description={`Posts with tag ${tag}`} currentNav="Blog">
	<PageHeading title="Blog" className="tag-page-heading">
		<BlogSectionTabs active="tags" />
	</PageHeading>
	<section class="tag-detail-heading">
		<p>Tag archive</p>
		<h2>{tag}</h2>
		<div class="tag-detail-chip ui-pressable is-active" aria-label={`Current tag ${tag}`}>
			<span>Current tag</span>
			<strong>{tag}</strong>
		</div>
	</section>
	{page.data.map((post) => <PostCard {...post} />)}
	<Paginator {...page} />
</ScaffoldLayout>

<style>
	.tag-page-heading {
		padding-bottom: 0.55rem;
	}

	.tag-detail-heading {
		display: grid;
		gap: 0.5rem;
		padding-bottom: 1.5rem;
	}

	.tag-detail-heading p {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.tag-detail-heading h2 {
		margin: 0;
		font-size: clamp(1.7rem, 4vw, 2.3rem);
		line-height: 1;
		text-wrap: balance;
		overflow-wrap: anywhere;
	}

	.tag-detail-chip {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		gap: 0.6rem;
		border-radius: var(--radius-soft);
		padding: 0.85rem 1rem;
	}

	.tag-detail-chip span {
		font-size: 0.76rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.tag-detail-chip strong {
		font-size: 1rem;
		color: var(--color-accent);
	}
</style>
