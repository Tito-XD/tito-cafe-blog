---
import { Icon } from 'astro-icon/components';
import PageHeading from '~/components/PageHeading.astro';
import PokemonDexGridStyles from '~/components/pokemon/PokemonDexGridStyles.astro';
import PokemonRegionNav from '~/components/pokemon/PokemonRegionNav.astro';
import pokemon151Chains from '~/data/pokemon151-chains.json';
import pokemon151 from '~/data/pokemon151.json';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';

const wikiBase = 'https://wiki.52poke.com/wiki/';
const artworkBase = '/pokemon151/artwork';
---

<ScaffoldLayout
	title="宝可梦 151 · 关都图鉴"
	description="关都地区 151 只宝可梦图鉴速查与中文名测验，备战线下答题。"
>
	<PageHeading title="宝可梦 151 · 关都" />
	<p class="p151-lead">
		关都地区 151 只宝可梦速查 + 中文名小测验。数据来自
		<a href="https://pokeapi.co/" target="_blank" rel="noreferrer noopener">PokeAPI</a>
		与
		<a href="https://wiki.52poke.com/" target="_blank" rel="noreferrer noopener">神奇宝贝百科</a>。
	</p>

	<PokemonRegionNav currentSlug="kanto" />

	<div class="p151-tabs" role="tablist" aria-label="页面模式">
		<button class="p151-tab is-active" type="button" role="tab" aria-selected="true" data-tab="dex">
			图鉴速查
		</button>
		<button class="p151-tab" type="button" role="tab" aria-selected="false" data-tab="quiz">
			名字测验
		</button>
	</div>

	<section class="p151-panel is-active" id="panel-dex" role="tabpanel" aria-labelledby="tab-dex">
		<div class="p151-toolbar">
			<label class="p151-search">
				<Icon name="ri:search-line" class="p151-search__icon" aria-hidden="true" />
				<input id="dex-search" type="search" placeholder="输入编号/中英文名" autocomplete="off" />
			</label>
			<button
				class="p151-toolbar__toggle"
				type="button"
				id="dex-hide-names"
				aria-pressed="false"
			>
				隐藏名字核对
			</button>
		</div>
		<p class="p151-toolbar-hint" id="dex-hide-hint" hidden>名字已隐藏，点按卡片显示中文名核对。</p>
		<ul class="p151-grid" id="dex-grid"></ul>
	</section>

	<section class="p151-panel" id="panel-quiz" role="tabpanel" hidden>
		<div class="p151-quiz-setup" id="quiz-setup">
			<h2 class="p151-section-title">选择测验方式</h2>
			<div class="p151-tabs" role="group" aria-label="测验方式">
				<button
					class="p151-tab is-active"
					type="button"
					data-quiz-mode="choice"
					aria-pressed="true"
				>
					四选一
				</button>
				<button class="p151-tab" type="button" data-quiz-mode="typing" aria-pressed="false">
					输入中文名
				</button>
				<button class="p151-tab" type="button" data-quiz-mode="round3" aria-pressed="false">
					三题练习
				</button>
			</div>
			<p class="p151-mode-hint" id="quiz-mode-hint">
				看立绘，从四个中文名里选正确答案。
			</p>
			<button class="p151-primary ui-pressable" type="button" id="quiz-start">开始测验</button>
		</div>

		<div class="p151-quiz-play" id="quiz-play" hidden>
			<div class="p151-quiz-meta">
				<span id="quiz-progress">1 / 151</span>
				<span id="quiz-score">正确 0</span>
				<span id="quiz-chances" class="p151-quiz-chances" hidden>本题还剩 3 次机会</span>
				<button class="p151-ghost ui-pressable" type="button" id="quiz-end">结束</button>
			</div>
			<div class="p151-quiz-card">
				<p class="p151-quiz-no" id="quiz-number">#001</p>
				<img class="p151-quiz-art" id="quiz-art" src="" alt="" width="220" height="220" />
				<div id="quiz-choice" class="p151-choices"></div>
				<form id="quiz-typing" class="p151-typing" hidden>
					<input id="quiz-input" type="text" placeholder="输入中文名" autocomplete="off" />
					<button class="p151-primary ui-pressable" type="submit">确认</button>
				</form>
				<p class="p151-feedback" id="quiz-feedback" hidden></p>
				<button class="p151-primary ui-pressable" type="button" id="quiz-next" hidden>下一题</button>
			</div>
		</div>

		<div class="p151-quiz-done" id="quiz-done" hidden>
			<h2 class="p151-section-title">本轮结束</h2>
			<p id="quiz-summary"></p>
			<button class="p151-primary ui-pressable" type="button" id="quiz-restart">再来一轮</button>
		</div>
	</section>

	<p class="p151-copy">
		宝可梦、Pokémon 及相关素材为 Nintendo / Creatures Inc. / GAME FREAK inc. 的商标或版权资产。
		立绘来自
		<a href="https://github.com/PokeAPI/sprites" target="_blank" rel="noreferrer noopener">PokeAPI Sprites</a>，
		中文名与百科链接参考神奇宝贝百科。属性弱点按双属性倍率计算（含免疫、抵抗），数据来自 PokeAPI 现行相克表。本页为个人学习向速查工具，与任天堂等公司无关联。
	</p>

	<script is:inline define:vars={{ pokemon151, pokemon151Chains, wikiBase, artworkBase }}>
		const ROUND3_SIZE = 3;
		const ROUND3_TRIES = 3;

		const state = {
			tab: 'dex',
			dexHideNames: false,
			quizMode: 'choice',
			queue: [],
			index: 0,
			score: 0,
			answered: false,
			attemptsLeft: ROUND3_TRIES,
			retryQueue: [],
			roundPhase: 'main',
			round3MainScore: 0,
			round3RetryScore: 0,
			retryRoundSize: 0,
		};

		const modeHints = {
			choice: '看立绘，从四个中文名里选正确答案。',
			typing: '看立绘，输入完整中文名，需完全匹配。',
			round3:
				'模拟线下答题：随机 3 题，每题最多说 3 次中文名；本回合猜错的题会在末尾再练一遍。',
		};

		const els = {
			tabs: [],
			panelDex: null,
			panelQuiz: null,
			dexSearch: null,
			dexGrid: null,
			dexHideNamesBtn: null,
			dexHideHint: null,
			quizSetup: null,
			quizPlay: null,
			quizDone: null,
			quizStart: null,
			quizEnd: null,
			quizRestart: null,
			quizProgress: null,
			quizScore: null,
			quizChances: null,
			quizNumber: null,
			quizArt: null,
			quizChoice: null,
			quizTyping: null,
			quizInput: null,
			quizFeedback: null,
			quizNext: null,
			quizSummary: null,
			quizModeHint: null,
			quizModeTabs: [],
		};

		const refreshEls = () => {
			els.tabs = document.querySelectorAll('[data-tab]');
			els.panelDex = document.getElementById('panel-dex');
			els.panelQuiz = document.getElementById('panel-quiz');
			els.dexSearch = document.getElementById('dex-search');
			els.dexGrid = document.getElementById('dex-grid');
			els.dexHideNamesBtn = document.getElementById('dex-hide-names');
			els.dexHideHint = document.getElementById('dex-hide-hint');
			els.quizSetup = document.getElementById('quiz-setup');
			els.quizPlay = document.getElementById('quiz-play');
			els.quizDone = document.getElementById('quiz-done');
			els.quizStart = document.getElementById('quiz-start');
			els.quizEnd = document.getElementById('quiz-end');
			els.quizRestart = document.getElementById('quiz-restart');
			els.quizProgress = document.getElementById('quiz-progress');
			els.quizScore = document.getElementById('quiz-score');
			els.quizChances = document.getElementById('quiz-chances');
			els.quizNumber = document.getElementById('quiz-number');
			els.quizArt = document.getElementById('quiz-art');
			els.quizChoice = document.getElementById('quiz-choice');
			els.quizTyping = document.getElementById('quiz-typing');
			els.quizInput = document.getElementById('quiz-input');
			els.quizFeedback = document.getElementById('quiz-feedback');
			els.quizNext = document.getElementById('quiz-next');
			els.quizSummary = document.getElementById('quiz-summary');
			els.quizModeHint = document.getElementById('quiz-mode-hint');
			els.quizModeTabs = document.querySelectorAll('[data-quiz-mode]');
		};

		const wikiUrl = (nameCn) => `${wikiBase}${encodeURIComponent(nameCn)}`;
		const artUrl = (id) => `${artworkBase}/${id}.png`;
		const formatNo = (id) => `#${String(id).padStart(3, '0')}`;
		const pokemonById = Object.fromEntries(pokemon151.map((p) => [p.id, p]));

		const TYPE_COLORS = {
			normal: '#9fa19f',
			fighting: '#c22e28',
			fire: '#ee8130',
			water: '#4592c4',
			electric: '#c9a01e',
			grass: '#5bbd4a',
			ice: '#3aa8a3',
			poison: '#9140a0',
			ground: '#c9a227',
			flying: '#8b7ad6',
			psychic: '#ee6b76',
			bug: '#91a119',
			rock: '#bfb889',
			ghost: '#735797',
			dragon: '#6f35fc',
			dark: '#715344',
			steel: '#8a8aa8',
			fairy: '#d685ad',
		};

		const renderTypeLabel = (typeName, label, kind = 'type') => {
			const color = TYPE_COLORS[typeName] || TYPE_COLORS.normal;
			const chipClass =
				kind === 'weak'
					? 'pokedex-type-chip pokedex-type-chip--weak'
					: 'pokedex-type-chip';
			return `<span class="${chipClass}" style="--type-color:${color}">${label}</span>`;
		};

		const renderTypeRow = (p) => {
			const types = p.types || [];
			const typesCn = p.typesCn || [];
			return types
				.map((typeName, index) => renderTypeLabel(typeName, typesCn[index] || typeName))
				.join('');
		};

		const renderWeaknessRow = (p) => {
			const weaknesses = p.weaknesses || [];
			const labels = p.weaknessesCn || [];
			if (weaknesses.length === 0) return '';
			const items = weaknesses
				.map((typeName, index) =>
					renderTypeLabel(typeName, labels[index] || typeName, 'weak'),
				)
				.join('');
			const weakLabel = labels.join('、');
			return `<div class="p151-member__weak" aria-label="弱点 ${weakLabel}"><span class="p151-weak-prefix">弱</span>${items}</div>`;
		};

		const shuffle = (arr) => {
			const copy = [...arr];
			for (let i = copy.length - 1; i > 0; i -= 1) {
				const j = Math.floor(Math.random() * (i + 1));
				[copy[i], copy[j]] = [copy[j], copy[i]];
			}
			return copy;
		};

		const pickWrongNames = (correct, count = 3) => {
			const pool = pokemon151.filter((p) => p.nameCn !== correct.nameCn);
			return shuffle(pool).slice(0, count);
		};

		const matchesPokemon = (p, filterText) => {
			const q = filterText.trim().toLowerCase();
			if (!q) return true;
			const typesText = (p.typesCn || []).join('');
			const weakText = (p.weaknessesCn || []).join('');
			const genusText = p.genusCn || '';
			const jaText = p.nameJa || '';
			return (
				String(p.id).includes(q) ||
				p.nameCn.includes(filterText.trim()) ||
				p.nameEn.toLowerCase().includes(q) ||
				p.slug.includes(q) ||
				typesText.includes(filterText.trim()) ||
				weakText.includes(filterText.trim()) ||
				genusText.includes(filterText.trim()) ||
				jaText.includes(filterText.trim())
			);
		};

		const renderMember = (p) => {
			const typeRow = renderTypeRow(p);
			const weakRow = renderWeaknessRow(p);
			const sup = String(p.id).padStart(3, '0');
			const artAlt = state.dexHideNames ? '宝可梦立绘' : p.nameCn;
			const maskClass = state.dexHideNames ? ' p151-member--mask-name' : '';

			return `
    <a class="p151-member p151-member--card${maskClass}" href="${wikiUrl(p.nameCn)}" target="_blank" rel="noreferrer noopener" data-id="${p.id}">
      <img class="p151-member__art" src="${artUrl(p.id)}" alt="${artAlt}" width="72" height="72" loading="lazy" />
      <span class="p151-member__no">${sup}</span>
      <span class="p151-member__label">${p.nameCn}</span>
      <span class="p151-member__en">${p.nameEn}</span>
      ${typeRow ? `<div class="p151-member__types">${typeRow}</div>` : ''}
      ${weakRow}
    </a>`;
		};

		const setDexHideNames = (on) => {
			state.dexHideNames = on;
			els.panelDex.classList.toggle('p151-panel--hide-names', on);
			els.dexHideNamesBtn?.setAttribute('aria-pressed', on ? 'true' : 'false');
			els.dexHideNamesBtn?.classList.toggle('is-active', on);
			if (els.dexHideNamesBtn) {
				els.dexHideNamesBtn.textContent = on ? '显示全部名字' : '隐藏名字核对';
			}
			if (els.dexHideHint) els.dexHideHint.hidden = !on;
			renderDex(els.dexSearch?.value || '');
		};

		const renderChainGroup = (ids) => {
			const parts = [];
			ids.forEach((id, index) => {
				parts.push(renderMember(pokemonById[id]));
				if (index < ids.length - 1) {
					parts.push('<span class="pokedex-chain__sep" aria-hidden="true">›</span>');
				}
			});
			return `<li class="pokedex-chain-group" data-count="${ids.length}"><div class="pokedex-chain-group__track">${parts.join('')}</div></li>`;
		};

		const renderDex = (filter = '') => {
			const trimmed = filter.trim();
			const chains = pokemon151Chains.filter(
				(ids) => !trimmed || ids.some((id) => matchesPokemon(pokemonById[id], filter)),
			);
			els.dexGrid.classList.add('pokedex-grid--chains');
			els.dexGrid.innerHTML = chains.map(renderChainGroup).join('');
		};

		const switchTab = (tab) => {
			state.tab = tab;
			els.tabs.forEach((btn) => {
				const active = btn.dataset.tab === tab;
				btn.classList.toggle('is-active', active);
				btn.setAttribute('aria-selected', active ? 'true' : 'false');
			});
			els.panelDex.classList.toggle('is-active', tab === 'dex');
			els.panelDex.hidden = tab !== 'dex';
			els.panelQuiz.hidden = tab !== 'quiz';
		};

		const showQuizPhase = (phase) => {
			els.quizSetup.hidden = phase !== 'setup';
			els.quizPlay.hidden = phase !== 'play';
			els.quizDone.hidden = phase !== 'done';
		};

		const currentPokemon = () => state.queue[state.index];

		const updateQuizMeta = () => {
			if (state.quizMode === 'round3') {
				const phaseLabel = state.roundPhase === 'retry' ? '错题重练 ' : '';
				els.quizProgress.textContent = `${phaseLabel}${state.index + 1} / ${state.queue.length}`;
				els.quizScore.textContent = `主回合 ${state.round3MainScore} · 重练 ${state.round3RetryScore}`;
				els.quizChances.hidden = false;
				els.quizChances.textContent = `本题还剩 ${state.attemptsLeft} 次机会`;
			} else {
				els.quizProgress.textContent = `${state.index + 1} / ${state.queue.length}`;
				els.quizScore.textContent = `正确 ${state.score}`;
				els.quizChances.hidden = true;
			}
		};

		const renderQuestion = () => {
			const p = currentPokemon();
			if (!p) return;
			state.answered = false;
			state.attemptsLeft = ROUND3_TRIES;
			els.quizFeedback.hidden = true;
			els.quizNext.hidden = true;

			els.quizNumber.textContent = formatNo(p.id);
			els.quizArt.src = artUrl(p.id);
			els.quizArt.alt = '猜猜这是哪只宝可梦';

			if (state.quizMode === 'choice') {
				els.quizChoice.hidden = false;
				els.quizTyping.hidden = true;
				const options = shuffle([p, ...pickWrongNames(p)]);
				els.quizChoice.innerHTML = options
					.map(
						(opt) =>
							`<button type="button" class="p151-choice ui-pressable" data-cn="${opt.nameCn}">${opt.nameCn}</button>`,
					)
					.join('');
			} else {
				els.quizChoice.hidden = true;
				els.quizTyping.hidden = false;
				els.quizInput.value = '';
				els.quizInput.placeholder = '输入中文名';
				els.quizInput.focus();
			}
			updateQuizMeta();
		};

		const highlightChoiceAnswer = (p) => {
			els.quizChoice.querySelectorAll('.p151-choice').forEach((btn) => {
				btn.disabled = true;
				if (btn.dataset.cn === p.nameCn) btn.classList.add('is-correct');
			});
		};

		const showFeedback = (ok, p) => {
			state.answered = true;
			els.quizFeedback.hidden = false;
			els.quizFeedback.className = `p151-feedback ${ok ? 'is-ok' : 'is-bad'}`;
			els.quizFeedback.textContent = ok
				? `正确！${p.nameCn}（${p.nameEn}）${formatNo(p.id)}`
				: `不对，正确答案是：${p.nameCn}（${p.nameEn}）${formatNo(p.id)}`;
			els.quizNext.hidden = false;
			if (state.quizMode === 'choice') highlightChoiceAnswer(p);
		};

		const switchQuizMode = (mode) => {
			state.quizMode = modeHints[mode] ? mode : 'choice';
			els.quizModeTabs.forEach((btn) => {
				const active = btn.dataset.quizMode === state.quizMode;
				btn.classList.toggle('is-active', active);
				btn.setAttribute('aria-pressed', active ? 'true' : 'false');
			});
			if (els.quizModeHint) {
				els.quizModeHint.textContent = modeHints[state.quizMode];
			}
		};

		const startQuiz = () => {
			state.score = 0;
			state.index = 0;
			state.roundPhase = 'main';
			state.retryQueue = [];
			state.round3MainScore = 0;
			state.round3RetryScore = 0;
			state.retryRoundSize = 0;

			if (state.quizMode === 'round3') {
				state.queue = shuffle(pokemon151).slice(0, ROUND3_SIZE);
			} else {
				state.queue = shuffle(pokemon151);
			}
			state.attemptsLeft = ROUND3_TRIES;
			showQuizPhase('play');
			renderQuestion();
		};

		const finishQuiz = () => {
			if (state.quizMode === 'round3') {
				const retryPart =
					state.retryRoundSize > 0
						? `错题重练 ${state.retryRoundSize} 题，答对 ${state.round3RetryScore} 题。`
						: '三题全部一次过关！';
				els.quizSummary.textContent = `主回合 3 题答对 ${state.round3MainScore} 题。${retryPart}继续加油，线下活动稳了！`;
			} else {
				els.quizSummary.textContent = `共 ${state.queue.length} 题，答对 ${state.score} 题。继续加油，线下活动稳了！`;
			}
			showQuizPhase('done');
		};

		const nextQuestion = () => {
			if (state.index + 1 < state.queue.length) {
				state.index += 1;
				renderQuestion();
				return;
			}
			if (state.quizMode === 'round3' && state.roundPhase === 'main' && state.retryQueue.length > 0) {
				state.retryRoundSize = state.retryQueue.length;
				state.roundPhase = 'retry';
				state.queue = shuffle([...state.retryQueue]);
				state.retryQueue = [];
				state.index = 0;
				renderQuestion();
				return;
			}
			finishQuiz();
		};

		const checkChoiceAnswer = (btn) => {
			if (!btn || state.answered || state.quizMode !== 'choice') return;
			const p = currentPokemon();
			const ok = btn.dataset.cn === p.nameCn;
			if (ok) state.score += 1;
			showFeedback(ok, p);
			updateQuizMeta();
		};

		const checkTypingAnswer = () => {
			if (state.answered) return;
			const p = currentPokemon();
			const input = els.quizInput.value.trim();
			const ok = input === p.nameCn;

			if (state.quizMode === 'round3') {
				if (ok) {
					if (state.roundPhase === 'main') state.round3MainScore += 1;
					else state.round3RetryScore += 1;
					showFeedback(true, p);
					updateQuizMeta();
					return;
				}
				state.attemptsLeft -= 1;
				if (state.attemptsLeft > 0) {
					els.quizFeedback.hidden = false;
					els.quizFeedback.className = 'p151-feedback is-bad';
					els.quizFeedback.textContent = `不对，再试一次（还剩 ${state.attemptsLeft} 次）`;
					els.quizInput.value = '';
					els.quizInput.focus();
					updateQuizMeta();
					return;
				}
				if (
					state.roundPhase === 'main' &&
					!state.retryQueue.some((item) => item.id === p.id)
				) {
					state.retryQueue.push(p);
				}
				showFeedback(false, p);
				updateQuizMeta();
				return;
			}

			if (ok) state.score += 1;
			showFeedback(ok, p);
			updateQuizMeta();
		};

		const setup = () => {
			const windowWithCleanup = window;
			windowWithCleanup.__p151Cleanup?.();
			refreshEls();
			if (!els.panelDex) return;

			setDexHideNames(false);
			switchTab('dex');
			showQuizPhase('setup');
			switchQuizMode('choice');

			const onTabClick = (btn) => switchTab(btn.dataset.tab);
			els.tabs.forEach((btn) => {
				btn.addEventListener('click', () => onTabClick(btn));
			});

			const onQuizModeClick = (btn) => switchQuizMode(btn.dataset.quizMode);
			els.quizModeTabs.forEach((btn) => {
				btn.addEventListener('click', () => onQuizModeClick(btn));
			});

			const onDexSearch = (e) => renderDex(e.target.value);
			const onHideNames = () => setDexHideNames(!state.dexHideNames);
			const onDexGridClick = (e) => {
				if (!state.dexHideNames) return;
				const member = e.target.closest('.p151-member');
				if (!member) return;
				if (!member.classList.contains('p151-member--revealed')) {
					e.preventDefault();
					member.classList.add('p151-member--revealed');
					const id = Number(member.dataset.id);
					const p = pokemonById[id];
					if (p) {
						const art = member.querySelector('.p151-member__art');
						if (art) art.alt = p.nameCn;
					}
				}
			};
			const onQuizStart = () => startQuiz();
			const onQuizEnd = () => showQuizPhase('setup');
			const onQuizRestart = () => showQuizPhase('setup');
			const onQuizNext = () => nextQuestion();
			const onQuizChoice = (e) => {
				const btn = e.target.closest('.p151-choice');
				checkChoiceAnswer(btn);
			};
			const onQuizTyping = (e) => {
				e.preventDefault();
				checkTypingAnswer();
			};

			els.dexSearch?.addEventListener('input', onDexSearch);
			els.dexHideNamesBtn?.addEventListener('click', onHideNames);
			els.dexGrid?.addEventListener('click', onDexGridClick);
			els.quizStart?.addEventListener('click', onQuizStart);
			els.quizEnd?.addEventListener('click', onQuizEnd);
			els.quizRestart?.addEventListener('click', onQuizRestart);
			els.quizNext?.addEventListener('click', onQuizNext);
			els.quizChoice?.addEventListener('click', onQuizChoice);
			els.quizTyping?.addEventListener('submit', onQuizTyping);

			windowWithCleanup.__p151Cleanup = () => {
				els.dexSearch?.removeEventListener('input', onDexSearch);
				els.dexHideNamesBtn?.removeEventListener('click', onHideNames);
				els.dexGrid?.removeEventListener('click', onDexGridClick);
				els.quizStart?.removeEventListener('click', onQuizStart);
				els.quizEnd?.removeEventListener('click', onQuizEnd);
				els.quizRestart?.removeEventListener('click', onQuizRestart);
				els.quizNext?.removeEventListener('click', onQuizNext);
				els.quizChoice?.removeEventListener('click', onQuizChoice);
				els.quizTyping?.removeEventListener('submit', onQuizTyping);
			};
		};

		setup();
		document.addEventListener('astro:page-load', setup);
	</script>
</ScaffoldLayout>

