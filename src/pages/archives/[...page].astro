---
import type { GetStaticPathsOptions } from 'astro';
import BlogSectionTabs from '~/components/BlogSectionTabs.astro';
import PageHeading from '~/components/PageHeading.astro';
import Paginator from '~/components/Paginator.astro';
import { PageSize } from '~/config';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { getPostRouteSlug, getPosts } from '~/utils/collection';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	return paginate(await getPosts(false, 'desc'), { pageSize: PageSize });
}

const { page } = Astro.props;
---

<ScaffoldLayout title="Timeline" description="all articles." currentNav="Blog">
	<PageHeading title="Blog" className="archive-heading">
		<BlogSectionTabs active="timeline" />
	</PageHeading>
	<div class="archive-intro">
		<p>Timeline</p>
	</div>
	{
		page.data.map((post) => {
			const date = post.data.lastmod || post.data.date;
			return (
				<div class="archive-row">
					<h5 class="archive-title">
						<a
							class="archive-link ui-type-link"
							data-text={post.data.title}
							href={`/posts/${getPostRouteSlug(post)}`}
							aria-label={`Read post: ${post.data.title}`}
						>
							<span class="ui-type-link__text">{post.data.title}</span>
						</a>
					</h5>
					{date && <time class="archive-date" datetime={date.toISOString()}>{date.toLocaleDateString()}</time>}
				</div>
			);
		})
	}
	<Paginator {...page} />
</ScaffoldLayout>

<style>
	.archive-heading {
		padding-bottom: 0.55rem;
	}

	.archive-intro {
		padding-bottom: 1.2rem;
	}

	.archive-intro p {
		margin: 0;
		font-size: 0.98rem;
		color: var(--color-muted);
	}

	.archive-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.9rem;
		border-radius: var(--radius-soft);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 95%, var(--color-surface-2) 5%);
		padding: 1rem 1.1rem;
		transition:
			transform var(--motion-lift),
			border-color var(--motion-lift),
			box-shadow var(--motion-lift),
			background var(--motion-lift),
			color var(--motion-lift);
	}

	.archive-row:hover,
	.archive-row:focus-within {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-accent) 52%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 88%, var(--color-accent-soft) 12%);
		box-shadow: 0 0.9rem 1.8rem rgba(var(--color-shadow-rgb), 0.12);
	}

	.archive-title,
	.archive-date {
		margin: 0;
	}

	.archive-title {
		font-size: 1.15rem;
		line-height: 1.4;
	}

	.archive-link {
		color: inherit;
		text-decoration: none;
	}

	.archive-row:hover .archive-link,
	.archive-row:focus-within .archive-link,
	.archive-row:hover .archive-date,
	.archive-row:focus-within .archive-date {
		color: var(--color-accent);
	}

	.archive-date {
		flex-shrink: 0;
		color: var(--color-muted);
	}

	@media (max-width: 640px) {
		.archive-row {
			flex-direction: column;
		}
	}
</style>

