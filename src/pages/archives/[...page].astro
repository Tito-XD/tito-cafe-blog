---
import type { GetStaticPathsOptions } from 'astro';
import Paginator from '~/components/Paginator.astro';
import { PageSize } from '~/config';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { getPostRouteSlug, getPosts } from '~/utils/collection';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	return paginate(await getPosts(false, 'desc'), { pageSize: PageSize });
}

const { page } = Astro.props;
---

<ScaffoldLayout title="Archive" description="all articles." currentNav="Archives">
	<section class="archive-heading">
		<p>Timeline</p>
		<h1>Archives</h1>
		<span>Every post in a cleaner list view, with a little more motion on hover.</span>
	</section>
	{
		page.data.map((post) => {
			const date = post.data.lastmod || post.data.date;
			return (
				<div class="archive-row">
					<h5 class="archive-title">
						<a class="archive-link" href={`/posts/${getPostRouteSlug(post)}`} aria-label={`Read post: ${post.data.title}`}>
							{post.data.title}
						</a>
					</h5>
					{date && <time class="archive-date" datetime={date.toISOString()}>{date.toLocaleDateString()}</time>}
				</div>
			);
		})
	}
	<Paginator {...page} />
</ScaffoldLayout>

<style>
	.archive-heading {
		display: grid;
		gap: 0.45rem;
		padding-bottom: 1.5rem;
	}

	.archive-heading p,
	.archive-heading span {
		margin: 0;
		color: var(--color-muted);
	}

	.archive-heading p {
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.archive-heading h1 {
		margin: 0;
		font-size: clamp(2.6rem, 6vw, 4.5rem);
		line-height: 0.95;
		text-wrap: balance;
	}

	.archive-heading span {
		max-width: 36rem;
		line-height: 1.7;
	}

	.archive-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.9rem;
		border-radius: 1.15rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 95%, var(--color-surface-2) 5%);
		padding: 1rem 1.1rem;
		transition:
			transform 280ms ease,
			border-color 280ms ease,
			box-shadow 280ms ease,
			background 280ms ease,
			color 280ms ease;
	}

	.archive-row:hover,
	.archive-row:focus-within {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-accent) 52%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 88%, var(--color-accent-soft) 12%);
		box-shadow: 0 0.9rem 1.8rem rgba(var(--color-shadow-rgb), 0.12);
	}

	.archive-title,
	.archive-date {
		margin: 0;
	}

	.archive-title {
		font-size: 1.15rem;
		line-height: 1.4;
	}

	.archive-link {
		color: inherit;
		text-decoration: none;
	}

	.archive-row:hover .archive-link,
	.archive-row:focus-within .archive-link,
	.archive-row:hover .archive-date,
	.archive-row:focus-within .archive-date {
		color: var(--color-accent);
	}

	.archive-date {
		flex-shrink: 0;
		color: var(--color-muted);
	}

	@media (max-width: 640px) {
		.archive-row {
			flex-direction: column;
		}
	}
</style>

