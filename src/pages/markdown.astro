---
import { SiteTitle } from '~/config';
import BaseLayout from '~/layouts/BaseLayout.astro';
import '@toast-ui/editor/dist/toastui-editor.css';
---

<BaseLayout
	title={`Markdown / ${SiteTitle}`}
	description="A standalone local-first markdown studio with source and WYSIWYG editing, media inserts, and export tools."
	rootClass="markdown-root"
	bodyClass="markdown-body"
>
	<main class="markdown-app">
		<div class="markdown-app__chrome">
			<p class="markdown-app__portal">Markdown Studio</p>
			<p class="markdown-app__hint">Source, visual mode, mixed media, export ready.</p>
		</div>

		<section class="markdown-stage">
			<header class="markdown-hero">
				<div class="markdown-hero__copy">
					<p class="markdown-eyebrow">Standalone Writing Workbench</p>
					<h1 class="markdown-title">/markdown</h1>
					<p class="markdown-intro">
						这是一个本地写作工作台。你可以用源码模式写 Markdown，也可以切到可视化模式直接编辑。
						图片、视频、音频和其他附件会进入旁边的素材架，最后一键导出为纯
						<code>.md</code> 或带 <code>assets/</code> 的 <code>.zip</code>。
					</p>
				</div>

				<div class="markdown-actions">
					<button class="markdown-button markdown-button--primary" type="button" id="export-md">
						Export .md
					</button>
					<button class="markdown-button" type="button" id="export-zip">Export .zip</button>
					<label class="markdown-button markdown-button--ghost" for="load-md">Load .md</label>
					<input id="load-md" type="file" accept=".md,.markdown,text/markdown,text/plain" hidden />
				</div>
			</header>

			<section class="markdown-dashboard">
				<div class="markdown-stat">
					<span>Mode</span>
					<strong id="editor-mode">wysiwyg</strong>
				</div>
				<div class="markdown-stat">
					<span>Words</span>
					<strong id="stat-words">0</strong>
				</div>
				<div class="markdown-stat">
					<span>Assets</span>
					<strong id="stat-assets">0</strong>
				</div>
				<div class="markdown-stat">
					<span>Status</span>
					<strong id="save-status">Local draft</strong>
				</div>
			</section>

			<div class="markdown-grid">
				<section class="markdown-editor-panel">
					<div class="markdown-editor-panel__head">
						<div>
							<p class="markdown-eyebrow">Editor</p>
							<h2 class="markdown-panel-title">Write, switch, export</h2>
						</div>
						<div class="markdown-mode-switches">
							<button class="markdown-button markdown-button--tiny" type="button" id="mode-markdown">
								Code
							</button>
							<button class="markdown-button markdown-button--tiny" type="button" id="mode-wysiwyg">
								Visual
							</button>
						</div>
					</div>

					<div class="markdown-editor" id="markdown-editor"></div>

					<section class="markdown-render-panel">
						<div class="markdown-panel__head">
							<div>
								<p class="markdown-eyebrow">View</p>
								<h2 class="markdown-panel-title">Mixed layout preview</h2>
							</div>
							<div class="markdown-editor-panel__notes">
								<span>Text + media</span>
								<span>Live rendered</span>
							</div>
						</div>

						<div class="markdown-rendered" id="rendered-view">
							<p class="markdown-empty">这里会显示实时渲染后的排版效果。</p>
						</div>
					</section>
				</section>

				<aside class="markdown-side">
					<section class="markdown-panel">
						<div class="markdown-panel__head">
							<div>
								<p class="markdown-eyebrow">Blocks</p>
								<h2 class="markdown-panel-title">Quick inserts</h2>
							</div>
						</div>

						<div class="markdown-template-grid">
							<button class="markdown-template" type="button" data-insert-snippet="heading">
								<strong>Heading</strong>
								<span>Section title + lead</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="quote">
								<strong>Quote</strong>
								<span>Blockquote with spacing</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="code">
								<strong>Code</strong>
								<span>Fenced code block</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="callout">
								<strong>Callout</strong>
								<span>Highlighted note block</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="details">
								<strong>Details</strong>
								<span>Foldable HTML section</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="media-grid">
								<strong>Media Grid</strong>
								<span>Two-up image layout</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="video">
								<strong>Video</strong>
								<span>Embedded video tag</span>
							</button>
							<button class="markdown-template" type="button" data-insert-snippet="audio">
								<strong>Audio</strong>
								<span>Embedded audio tag</span>
							</button>
						</div>
					</section>

					<section class="markdown-panel">
						<div class="markdown-panel__head">
							<div>
								<p class="markdown-eyebrow">Frontmatter</p>
								<h2 class="markdown-panel-title">Export metadata</h2>
							</div>
							<span class="markdown-chip" id="slug-preview">untitled-note</span>
						</div>

						<div class="markdown-fields">
							<label class="markdown-field">
								<span>Title</span>
								<input class="markdown-input" id="meta-title" type="text" placeholder="文章标题" />
							</label>
							<label class="markdown-field">
								<span>Slug</span>
								<input class="markdown-input" id="meta-slug" type="text" placeholder="auto-generated-slug" />
							</label>
							<label class="markdown-field">
								<span>Description</span>
								<textarea
									class="markdown-input markdown-input--textarea"
									id="meta-description"
									rows="3"
									placeholder="导出 frontmatter description"
								></textarea>
							</label>
							<div class="markdown-fields__row">
								<label class="markdown-field">
									<span>Date</span>
									<input class="markdown-input" id="meta-date" type="datetime-local" />
								</label>
								<label class="markdown-field markdown-field--check">
									<input id="meta-draft" type="checkbox" />
									<span>Draft</span>
								</label>
							</div>
							<label class="markdown-field">
								<span>Tags</span>
								<input class="markdown-input" id="meta-tags" type="text" placeholder="coffee, review, note" />
							</label>
						</div>
					</section>

					<section class="markdown-panel">
						<div class="markdown-panel__head">
							<div>
								<p class="markdown-eyebrow">Assets</p>
								<h2 class="markdown-panel-title">Media shelf</h2>
							</div>
							<label class="markdown-button markdown-button--ghost" for="asset-input">Add files</label>
						</div>

						<input
							id="asset-input"
							type="file"
							multiple
							accept="image/*,video/*,audio/*,.pdf,.svg,.webp,.png,.jpg,.jpeg,.gif,.mp4,.mp3,.wav,.m4a,.mov"
							hidden
						/>

						<p class="markdown-panel__hint">
							图片会自动插入成 Markdown 图片语法，视频和音频会插入成 HTML 标签，其他文件会插入成相对路径链接。
						</p>

						<div class="markdown-assets" id="asset-list">
							<p class="markdown-empty">还没有素材。把图、视频或附件放进来之后，可以直接插入正文并随 zip 一起导出。</p>
						</div>
					</section>

					<section class="markdown-panel">
						<div class="markdown-panel__head">
							<div>
								<p class="markdown-eyebrow">Output</p>
								<h2 class="markdown-panel-title">Export preview</h2>
							</div>
						</div>
						<pre class="markdown-output" id="output-preview">---</pre>
					</section>
				</aside>
			</div>
		</section>
	</main>

	<script>
		// @ts-nocheck
		import { Editor } from '@toast-ui/editor';
		import JSZip from 'jszip';

		const DRAFT_KEY = 'tito-cafe-markdown-studio.v1';
		const DB_NAME = 'tito-cafe-markdown-studio';
		const STORE_NAME = 'assets';

		const mount = document.querySelector('#markdown-editor');
		const modeLabel = document.querySelector('#editor-mode');
		const wordsLabel = document.querySelector('#stat-words');
		const assetsLabel = document.querySelector('#stat-assets');
		const saveStatus = document.querySelector('#save-status');
		const exportMdButton = document.querySelector('#export-md');
		const exportZipButton = document.querySelector('#export-zip');
		const loadMdInput = document.querySelector('#load-md');
		const assetInput = document.querySelector('#asset-input');
		const assetList = document.querySelector('#asset-list');
		const outputPreview = document.querySelector('#output-preview');
		const slugPreview = document.querySelector('#slug-preview');
		const renderedView = document.querySelector('#rendered-view');
		const modeMarkdownButton = document.querySelector('#mode-markdown');
		const modeWysiwygButton = document.querySelector('#mode-wysiwyg');
		const snippetButtons = [...document.querySelectorAll('[data-insert-snippet]')];

		const fields = {
			title: document.querySelector('#meta-title'),
			slug: document.querySelector('#meta-slug'),
			description: document.querySelector('#meta-description'),
			date: document.querySelector('#meta-date'),
			tags: document.querySelector('#meta-tags'),
			draft: document.querySelector('#meta-draft'),
		};

		let editor;
		let autosaveTimer = null;
		let hasManualSlug = false;
		let assetCache = [];
		const snippetLibrary = {
			heading: '## New section\n\nWrite a short lead-in here.\n',
			quote: '> Pull one line out and let it breathe a little.\n',
			code: '```ts\nconsole.log("hello from markdown studio");\n```\n',
			callout:
				'> [!NOTE]\n> Add a short highlight, warning, or context block here.\n',
			details:
				'<details>\n<summary>Expand notes</summary>\n\nAdd the hidden details here.\n\n</details>\n',
			'media-grid':
				'<div class="media-grid">\n  <figure>\n    <img src="./assets/example-image-1.jpg" alt="Describe image one." />\n    <figcaption>Caption one.</figcaption>\n  </figure>\n  <figure>\n    <img src="./assets/example-image-2.jpg" alt="Describe image two." />\n    <figcaption>Caption two.</figcaption>\n  </figure>\n</div>\n',
			video: '<video controls src="./assets/example-video.mp4"></video>\n',
			audio: '<audio controls src="./assets/example-audio.mp3"></audio>\n'
		};

		function slugify(value) {
			return String(value ?? '')
				.toLocaleLowerCase()
				.trim()
				.replace(/['"]/g, '')
				.replace(/[^a-z0-9\u4e00-\u9fff]+/g, '-')
				.replace(/^-+|-+$/g, '') || 'untitled-note';
		}

		function parseTags(value) {
			return [...new Set(String(value ?? '')
				.split(',')
				.map((item) => item.trim())
				.filter(Boolean))];
		}

		function escapeYaml(value) {
			return String(value ?? '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
		}

		function formatDateForInput(iso) {
			const date = iso ? new Date(iso) : new Date();
			const pad = (value) => String(value).padStart(2, '0');
			return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(
				date.getHours(),
			)}:${pad(date.getMinutes())}`;
		}

		function inputToIso(value) {
			if (!value) return new Date().toISOString();
			return new Date(value).toISOString();
		}

		function buildFrontmatter() {
			const tags = parseTags(fields.tags.value);
			const lines = ['---'];
			if (fields.title.value.trim()) lines.push(`title: "${escapeYaml(fields.title.value.trim())}"`);
			lines.push(`slug: "${escapeYaml(fields.slug.value.trim() || slugify(fields.title.value))}"`);
			if (fields.description.value.trim()) {
				lines.push(`description: "${escapeYaml(fields.description.value.trim())}"`);
			}
			lines.push(`date: ${inputToIso(fields.date.value)}`);
			if (tags.length) {
				lines.push('tags:');
				tags.forEach((tag) => lines.push(`  - "${escapeYaml(tag)}"`));
			}
			if (fields.draft.checked) lines.push('draft: true');
			lines.push('---');
			return lines.join('\n');
		}

		function buildMarkdownDocument() {
			const frontmatter = buildFrontmatter();
			const content = editor.getMarkdown().trim();
			return `${frontmatter}\n\n${content}\n`;
		}

		function updatePreview() {
			const output = buildMarkdownDocument();
			outputPreview.textContent = output.slice(0, 1400) + (output.length > 1400 ? '\n…' : '');
			slugPreview.textContent = `${fields.slug.value.trim() || slugify(fields.title.value)}.md`;
		}

		function renderMixedView() {
			const html = editor.getHTML().trim();
			renderedView.innerHTML = html || '<p class="markdown-empty">这里会显示实时渲染后的排版效果。</p>';
		}

		function getWordCount(markdown) {
			const plain = markdown
				.replace(/```[\s\S]*?```/g, ' ')
				.replace(/`[^`]+`/g, ' ')
				.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
				.replace(/\[[^\]]+\]\([^)]+\)/g, ' ')
				.replace(/[#>*_\-\[\]()]/g, ' ')
				.trim();
			return plain ? plain.split(/\s+/u).length : 0;
		}

		function setSaveStatus(label) {
			saveStatus.textContent = label;
		}

		function downloadBlob(blob, filename) {
			const href = URL.createObjectURL(blob);
			const anchor = document.createElement('a');
			anchor.href = href;
			anchor.download = filename;
			anchor.click();
			URL.revokeObjectURL(href);
		}

		function getDraftPayload() {
			return {
				meta: {
					title: fields.title.value,
					slug: fields.slug.value,
					description: fields.description.value,
					date: fields.date.value,
					tags: fields.tags.value,
					draft: fields.draft.checked,
					hasManualSlug,
				},
				content: editor.getMarkdown(),
				mode: editor?.isMarkdownMode?.() ? 'markdown' : 'wysiwyg',
				savedAt: new Date().toISOString(),
			};
		}

		function saveDraft() {
			localStorage.setItem(DRAFT_KEY, JSON.stringify(getDraftPayload()));
			setSaveStatus('Saved locally');
			updatePreview();
		}

		function scheduleSave() {
			setSaveStatus('Editing…');
			window.clearTimeout(autosaveTimer);
			autosaveTimer = window.setTimeout(saveDraft, 280);
		}

		function restoreDraft() {
			try {
				const raw = localStorage.getItem(DRAFT_KEY);
				if (!raw) return null;
				return JSON.parse(raw);
			} catch {
				return null;
			}
		}

		function openDb() {
			return new Promise((resolve, reject) => {
				const request = indexedDB.open(DB_NAME, 1);
				request.onupgradeneeded = () => {
					const db = request.result;
					if (!db.objectStoreNames.contains(STORE_NAME)) {
						db.createObjectStore(STORE_NAME, { keyPath: 'id' });
					}
				};
				request.onsuccess = () => resolve(request.result);
				request.onerror = () => reject(request.error);
			});
		}

		async function readAssets() {
			const db = await openDb();
			return new Promise((resolve, reject) => {
				const transaction = db.transaction(STORE_NAME, 'readonly');
				const store = transaction.objectStore(STORE_NAME);
				const request = store.getAll();
				request.onsuccess = () => resolve(request.result ?? []);
				request.onerror = () => reject(request.error);
			});
		}

		async function writeAsset(asset) {
			const db = await openDb();
			return new Promise((resolve, reject) => {
				const transaction = db.transaction(STORE_NAME, 'readwrite');
				transaction.objectStore(STORE_NAME).put(asset);
				transaction.oncomplete = () => resolve(asset);
				transaction.onerror = () => reject(transaction.error);
			});
		}

		async function deleteAsset(assetId) {
			const db = await openDb();
			return new Promise((resolve, reject) => {
				const transaction = db.transaction(STORE_NAME, 'readwrite');
				transaction.objectStore(STORE_NAME).delete(assetId);
				transaction.oncomplete = () => resolve();
				transaction.onerror = () => reject(transaction.error);
			});
		}

		function sanitizeFilename(name) {
			const extMatch = /\.([a-zA-Z0-9]+)$/.exec(name);
			const ext = extMatch ? `.${extMatch[1].toLowerCase()}` : '';
			const base = name
				.replace(ext, '')
				.toLocaleLowerCase()
				.replace(/[^a-z0-9\u4e00-\u9fff]+/g, '-')
				.replace(/^-+|-+$/g, '') || 'asset';
			return `${base}${ext}`;
		}

		function ensureUniqueFilename(name) {
			const taken = new Set(assetCache.map((item) => item.fileName));
			if (!taken.has(name)) return name;
			const extIndex = name.lastIndexOf('.');
			const ext = extIndex >= 0 ? name.slice(extIndex) : '';
			const base = extIndex >= 0 ? name.slice(0, extIndex) : name;
			let index = 2;
			let next = `${base}-${index}${ext}`;
			while (taken.has(next)) {
				index += 1;
				next = `${base}-${index}${ext}`;
			}
			return next;
		}

		function snippetForAsset(asset) {
			const src = `./assets/${asset.fileName}`;
			if (asset.type.startsWith('image/')) {
				return `![${asset.alt || asset.fileName}](${src})`;
			}
			if (asset.type.startsWith('video/')) {
				return `<video controls src="${src}"></video>`;
			}
			if (asset.type.startsWith('audio/')) {
				return `<audio controls src="${src}"></audio>`;
			}
			return `[${asset.fileName}](${src})`;
		}

		function insertSnippet(snippet) {
			editor.insertText(`${snippet}\n`);
			scheduleSave();
		}

		function syncModeButtons() {
			const isMarkdown = editor.isMarkdownMode?.() ?? false;
			modeMarkdownButton.dataset.current = String(isMarkdown);
			modeWysiwygButton.dataset.current = String(!isMarkdown);
		}

		function renderAssets() {
			assetsLabel.textContent = String(assetCache.length);
			assetList.innerHTML = '';

			if (!assetCache.length) {
				assetList.innerHTML =
					'<p class="markdown-empty">还没有素材。把图、视频或附件放进来之后，可以直接插入正文并随 zip 一起导出。</p>';
				return;
			}

			for (const asset of assetCache) {
				const article = document.createElement('article');
				article.className = 'markdown-asset';
				const preview = asset.type.startsWith('image/')
					? `<img class="markdown-asset__thumb" src="${asset.previewUrl}" alt="${asset.alt}" />`
					: `<div class="markdown-asset__icon">${asset.type.startsWith('video/') ? 'Video' : asset.type.startsWith('audio/') ? 'Audio' : 'File'}</div>`;
				article.innerHTML = `
					${preview}
					<div class="markdown-asset__copy">
						<strong>${asset.fileName}</strong>
						<p>${Math.round(asset.size / 1024)} KB · ${asset.type || 'application/octet-stream'}</p>
					</div>
					<div class="markdown-asset__actions">
						<button type="button" data-action="insert">Insert</button>
						<button type="button" data-action="remove">Remove</button>
					</div>
				`;

				article.addEventListener('click', async (event) => {
					const button = event.target.closest('button[data-action]');
					if (!button) return;
					const action = button.dataset.action;
					if (action === 'insert') {
						insertSnippet(snippetForAsset(asset));
						return;
					}
					if (action === 'remove') {
						if (!window.confirm(`Remove ${asset.fileName} from the media shelf?`)) return;
						await deleteAsset(asset.id);
						if (asset.previewUrl) URL.revokeObjectURL(asset.previewUrl);
						assetCache = await hydrateAssets();
						renderAssets();
					}
				});

				assetList.append(article);
			}
		}

		async function hydrateAssets() {
			const items = await readAssets();
			return items.map((asset) => ({
				...asset,
				previewUrl: asset.type.startsWith('image/') ? URL.createObjectURL(asset.blob) : '',
			}));
		}

		async function addFiles(fileList, { insert = false } = {}) {
			const files = [...fileList];
			const addedAssets = [];
			for (const file of files) {
				const fileName = ensureUniqueFilename(sanitizeFilename(file.name));
				const asset = {
					id: crypto.randomUUID?.() || `${Date.now()}-${Math.random().toString(16).slice(2, 8)}`,
					fileName,
					alt: file.name.replace(/\.[^.]+$/, ''),
					type: file.type || 'application/octet-stream',
					size: file.size,
					blob: file,
				};
				await writeAsset(asset);
				addedAssets.push(asset);
			}
			assetCache = await hydrateAssets();
			renderAssets();
			if (insert) {
				addedAssets.forEach((asset) => insertSnippet(snippetForAsset(asset)));
			}
			scheduleSave();
			return addedAssets;
		}

		function stripFrontmatter(raw) {
			if (!raw.startsWith('---')) return { content: raw, meta: null };
			const match = raw.match(/^---\n([\s\S]*?)\n---\n?/);
			if (!match) return { content: raw, meta: null };
			return { content: raw.slice(match[0].length), meta: match[1] };
		}

		function parseFrontmatterBlock(block) {
			if (!block) return null;
			const result = { tags: [] };
			let currentArray = null;
			block.split('\n').forEach((line) => {
				if (/^\s*-\s+/.test(line) && currentArray === 'tags') {
					result.tags.push(line.replace(/^\s*-\s+/, '').replace(/^"|"$/g, ''));
					return;
				}
				currentArray = null;
				const [key, ...rest] = line.split(':');
				if (!key || !rest.length) return;
				const value = rest.join(':').trim().replace(/^"|"$/g, '');
				if (key.trim() === 'tags') {
					currentArray = 'tags';
					return;
				}
				result[key.trim()] = value;
			});
			return result;
		}

		function applyLoadedMarkdown(raw) {
			const { content, meta } = stripFrontmatter(raw);
			const parsed = parseFrontmatterBlock(meta);
			if (parsed) {
				fields.title.value = parsed.title || '';
				fields.slug.value = parsed.slug || '';
				fields.description.value = parsed.description || '';
				fields.date.value = parsed.date ? formatDateForInput(parsed.date) : formatDateForInput();
				fields.tags.value = Array.isArray(parsed.tags) ? parsed.tags.join(', ') : '';
				fields.draft.checked = parsed.draft === 'true';
				hasManualSlug = Boolean(parsed.slug);
			}
			editor.setMarkdown(content.trim());
			updatePreview();
			scheduleSave();
		}

		function buildFileBaseName() {
			return fields.slug.value.trim() || slugify(fields.title.value);
		}

		async function exportZip() {
			const zip = new JSZip();
			const baseName = buildFileBaseName();
			zip.file(`${baseName}.md`, buildMarkdownDocument());
			for (const asset of assetCache) {
				zip.file(`assets/${asset.fileName}`, asset.blob);
			}
			const blob = await zip.generateAsync({ type: 'blob' });
			downloadBlob(blob, `${baseName}.zip`);
		}

		function syncSlug() {
			if (!hasManualSlug) fields.slug.value = slugify(fields.title.value);
			updatePreview();
			scheduleSave();
		}

		function updateStats() {
			const markdown = editor.getMarkdown();
			wordsLabel.textContent = String(getWordCount(markdown));
			modeLabel.textContent = editor.isMarkdownMode?.() ? 'markdown' : 'wysiwyg';
			updatePreview();
			renderMixedView();
			syncModeButtons();
		}

		function initEditor(initialContent, initialMode) {
			editor = new Editor({
				el: mount,
				height: '72dvh',
				initialValue: initialContent,
				initialEditType: initialMode === 'markdown' ? 'markdown' : 'wysiwyg',
				previewStyle: 'vertical',
				usageStatistics: false,
				hideModeSwitch: false,
				autofocus: false,
				toolbarItems: [
					['heading', 'bold', 'italic', 'strike'],
					['hr', 'quote'],
					['ul', 'ol', 'task'],
					['table', 'link'],
					['code', 'codeblock'],
				],
				hooks: {
					addImageBlobHook: async (blob, callback) => {
						const fileName = ensureUniqueFilename(sanitizeFilename(blob.name || 'image'));
						const asset = {
							id: crypto.randomUUID?.() || `${Date.now()}-${Math.random().toString(16).slice(2, 8)}`,
							fileName,
							alt: blob.name?.replace(/\.[^.]+$/, '') || 'image',
							type: blob.type || 'image/png',
							size: blob.size,
							blob,
						};
						await writeAsset(asset);
						assetCache = await hydrateAssets();
						renderAssets();
						callback(`./assets/${asset.fileName}`, asset.alt);
						scheduleSave();
						return false;
					},
				},
			});

			editor.on('change', () => {
				updateStats();
				scheduleSave();
			});

			mount.addEventListener('click', () => {
				window.setTimeout(updateStats, 40);
			});

			mount.addEventListener('dragover', (event) => {
				event.preventDefault();
			});

			mount.addEventListener('drop', async (event) => {
				event.preventDefault();
				const files = event.dataTransfer?.files;
				if (!files?.length) return;
				await addFiles(files, { insert: true });
			});
		}

		async function bootstrap() {
			const stored = restoreDraft();
			fields.date.value = stored?.meta?.date || formatDateForInput();
			fields.title.value = stored?.meta?.title || '';
			fields.slug.value = stored?.meta?.slug || slugify(fields.title.value);
			fields.description.value = stored?.meta?.description || '';
			fields.tags.value = stored?.meta?.tags || '';
			fields.draft.checked = Boolean(stored?.meta?.draft);
			hasManualSlug = Boolean(stored?.meta?.hasManualSlug);

			initEditor(stored?.content || '', stored?.mode || 'wysiwyg');
			assetCache = await hydrateAssets();
			renderAssets();
			updateStats();

			if (stored?.savedAt) {
				setSaveStatus(`Recovered draft from ${new Intl.DateTimeFormat('zh-CN', {
					dateStyle: 'medium',
					timeStyle: 'short',
				}).format(new Date(stored.savedAt))}`);
			}
		}

		fields.title.addEventListener('input', syncSlug);
		fields.slug.addEventListener('input', () => {
			hasManualSlug = Boolean(fields.slug.value.trim());
			updatePreview();
			scheduleSave();
		});
		fields.description.addEventListener('input', scheduleSave);
		fields.date.addEventListener('change', scheduleSave);
		fields.tags.addEventListener('input', scheduleSave);
		fields.draft.addEventListener('change', scheduleSave);

		assetInput.addEventListener('change', async () => {
			const files = assetInput.files;
			if (!files?.length) return;
			await addFiles(files);
			assetInput.value = '';
		});

		loadMdInput.addEventListener('change', async () => {
			const file = loadMdInput.files?.[0];
			if (!file) return;
			const raw = await file.text();
			applyLoadedMarkdown(raw);
			loadMdInput.value = '';
		});

		exportMdButton.addEventListener('click', () => {
			const baseName = buildFileBaseName();
			downloadBlob(new Blob([buildMarkdownDocument()], { type: 'text/markdown;charset=utf-8' }), `${baseName}.md`);
		});

		modeMarkdownButton.addEventListener('click', () => {
			editor.changeMode('markdown');
			window.setTimeout(updateStats, 40);
		});

		modeWysiwygButton.addEventListener('click', () => {
			editor.changeMode('wysiwyg');
			window.setTimeout(updateStats, 40);
		});

		snippetButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const key = button.dataset.insertSnippet;
				if (!key || !snippetLibrary[key]) return;
				insertSnippet(snippetLibrary[key]);
			});
		});

		document.addEventListener('paste', async (event) => {
			const files = [...(event.clipboardData?.files ?? [])];
			if (!files.length) return;
			await addFiles(files, { insert: true });
		});

		exportZipButton.addEventListener('click', exportZip);

		bootstrap();
	</script>

