---
import PageHeading from '~/components/PageHeading.astro';
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import { galleryCategories, getGalleryItemsByCategory } from '~/utils/gallery';

const categories = await Promise.all(
	galleryCategories.map(async (category) => {
		const items = await getGalleryItemsByCategory(category.slug);
		return {
			...category,
			count: items.length,
			cover: items[0],
			previews: items.slice(0, 3),
			highlightCount: items.filter((item) => item.data.focusCharacters?.length)
				.length,
			latestYear: items
				.map((item) => Number(item.data.year))
				.filter((year) => Number.isFinite(year))
				.sort((left, right) => right - left)[0],
		};
	}),
);
---

<ScaffoldLayout
	title="Gallery"
	description="Illustration, life, and view galleries."
	currentNav={undefined}
>
	<PageHeading title="Gallery" className="gallery-hero" />

	<section class="gallery-category-grid" aria-label="Gallery categories">
		{
			categories.map((category) => (
				<a class="gallery-category-card" href={`/gallery/${category.slug}/`}>
					<div class="gallery-category-cover">
						{category.cover && (
							<img
								src={category.cover.data.image.src}
								width={category.cover.data.image.width}
								height={category.cover.data.image.height}
								alt={category.cover.data.alt}
								loading="lazy"
								decoding="async"
							/>
						)}
						<div class="gallery-category-overlay">
							<p>{category.subtitle}</p>
							<div>
								<span>{category.count} works</span>
								{category.highlightCount > 0 && <span>{category.highlightCount} interactive</span>}
							</div>
						</div>
					</div>
					<div class="gallery-category-copy">
						<p>{category.subtitle}</p>
						<h2>{category.title}</h2>
						<p>{category.description}</p>
						<div class="gallery-category-preview-strip" aria-hidden="true">
							{
								category.previews.map((preview) => (
									<img
										src={preview.data.image.src}
										width={preview.data.image.width}
										height={preview.data.image.height}
										alt=""
										loading="lazy"
										decoding="async"
									/>
								))
							}
						</div>
						<div class="gallery-category-footer">
							<small>{category.latestYear ? `Latest ${category.latestYear}` : 'Preview ready'}</small>
							<strong>Open {category.title}</strong>
						</div>
					</div>
				</a>
			))
		}
	</section>
</ScaffoldLayout>

<style is:global>
	.gallery-hero {
		padding: 0.1rem 0 1.35rem;
	}

	.gallery-category-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
		gap: 1.25rem;
		padding: 1.75rem 0 0.5rem;
	}

	.gallery-category-card {
		display: grid;
		min-width: 0;
		overflow: hidden;
		border-radius: var(--radius-card);
		border: 1px solid var(--color-border);
		background: linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 95%, var(--color-accent-soft) 5%), color-mix(in srgb, var(--color-surface-2) 86%, var(--color-surface) 14%));
		text-decoration: none;
		color: inherit;
		box-shadow: 0 1rem 2rem rgba(var(--color-shadow-rgb), 0.07);
		transition: transform var(--motion-lift), border-color var(--motion-lift);
	}

	.gallery-category-card:hover,
	.gallery-category-card:focus-visible {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--color-accent) 68%, var(--color-border));
	}

	.gallery-category-cover {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
	}

	.gallery-category-cover img {
		height: 100%;
		width: 100%;
		object-fit: cover;
		transition: transform 420ms ease;
	}

	.gallery-category-card:hover .gallery-category-cover img,
	.gallery-category-card:focus-visible .gallery-category-cover img {
		transform: scale(1.04);
	}

	.gallery-category-overlay {
		position: absolute;
		inset: auto 0 0;
		display: grid;
		gap: 0.5rem;
		padding: 1rem;
		background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--color-text) 74%, transparent));
		color: var(--color-surface);
	}

	.gallery-category-overlay p,
	.gallery-category-overlay span {
		margin: 0;
	}

	.gallery-category-overlay p {
		font-size: 0.8rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.gallery-category-overlay div {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.gallery-category-overlay span {
		border-radius: var(--radius-chip);
		background: color-mix(in srgb, var(--color-surface) 16%, transparent);
		padding: 0.3rem 0.6rem;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.gallery-category-copy {
		display: grid;
		gap: 0.65rem;
		min-width: 0;
		padding: 1.2rem 1.2rem 1.35rem;
	}

	.gallery-category-copy > p:first-child {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.gallery-category-copy h2 {
		margin: 0;
		font-size: 1.7rem;
		overflow-wrap: anywhere;
	}

	.gallery-category-copy > p:last-of-type {
		margin: 0;
		font-size: 0.96rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-muted) 92%, var(--color-text));
		overflow-wrap: anywhere;
	}

	.gallery-category-preview-strip {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.55rem;
		padding-top: 0.15rem;
	}

	.gallery-category-preview-strip img {
		aspect-ratio: 1;
		width: 100%;
		border-radius: var(--radius-media);
		object-fit: cover;
	}

	.gallery-category-footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding-top: 0.25rem;
	}

	.gallery-category-footer small {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
		overflow-wrap: anywhere;
	}

	.gallery-category-footer strong {
		font-size: 0.9rem;
		overflow-wrap: anywhere;
	}
</style>

