---
import ScaffoldLayout from '~/layouts/ScaffoldLayout.astro';
import {
	galleryCategories,
	getGalleryCategory,
	getGalleryItemsByCategory,
} from '~/utils/gallery';

export const getStaticPaths = () =>
	galleryCategories.map((category) => ({
		params: { category: category.slug },
		props: { categorySlug: category.slug },
	}));

const { categorySlug } = Astro.props;
const category = getGalleryCategory(categorySlug);

if (!category) {
	throw new Error(`Unknown gallery category: ${categorySlug}`);
}

const items = await getGalleryItemsByCategory(category.slug);
---

<ScaffoldLayout
	title={`Gallery / ${category.title}`}
	description={category.description}
	currentNav={undefined}
>
	<section class="gallery-section-heading">
		<a class="gallery-back-link" href="/gallery/">Gallery</a>
		<p>{category.subtitle}</p>
		<h1>{category.title}</h1>
		<p>{category.description}</p>
	</section>

	<nav class="gallery-tab-list" aria-label="Gallery categories">
		{
			galleryCategories.map((entry) => (
				<a
					class:list={['gallery-tab', 'ui-pressable', { active: entry.slug === category.slug }]}
					href={`/gallery/${entry.slug}/`}
				>
					{entry.title}
				</a>
			))
		}
	</nav>

	<section class="gallery-wall" aria-label={`${category.title} wall`}>
		{
			items.map((item) => (
				<a
					class:list={[
						'gallery-wall-card',
						{ interactive: Boolean(item.data.focusCharacters?.length) },
					]}
					href={`/gallery/${category.slug}/${item.data.slug}/`}
				>
					<img
						src={item.data.image.src}
						width={item.data.image.width}
						height={item.data.image.height}
						alt={item.data.alt}
						loading="lazy"
						decoding="async"
					/>
					<div class="gallery-wall-card-copy">
						<div class="gallery-wall-card-meta">
							<p>{item.data.eyebrow}</p>
							{item.data.focusCharacters?.length && <span>Interactive Focus</span>}
						</div>
						<h2>{item.data.title}</h2>
						<span>{item.data.summary}</span>
						<div class="gallery-wall-card-footer">
							<small>{item.data.year ?? category.title}</small>
							<small>{item.data.location ?? item.data.credit ?? 'Open viewer'}</small>
						</div>
					</div>
				</a>
			))
		}
	</section>
</ScaffoldLayout>

<style is:global>
	.gallery-section-heading {
		display: grid;
		gap: 0.45rem;
		padding: 1.4rem 0 1rem;
	}

	.gallery-back-link {
		width: fit-content;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
		text-decoration: none;
	}

	.gallery-section-heading p {
		margin: 0;
		max-width: 44rem;
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-muted) 92%, var(--color-text));
		overflow-wrap: anywhere;
	}

	.gallery-section-heading h1 {
		margin: 0;
		font-size: clamp(2.35rem, 6vw, 4rem);
		line-height: 1;
		text-wrap: balance;
	}

	.gallery-tab-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0.5rem 0 1.5rem;
	}

	.gallery-tab {
		border-radius: var(--radius-chip);
		padding: 0.65rem 1rem;
		font-size: 0.9rem;
		text-decoration: none;
		color: inherit;
	}

	.gallery-tab.active {
		transform: translateY(1px);
	}

	.gallery-wall {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr));
		gap: 1rem;
		padding-bottom: 1rem;
	}

	.gallery-wall-card {
		position: relative;
		display: grid;
		min-width: 0;
		overflow: hidden;
		border-radius: var(--radius-card);
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-surface) 94%, var(--color-accent-soft));
		text-decoration: none;
		color: inherit;
		box-shadow: 0 0.85rem 1.8rem rgba(var(--color-shadow-rgb), 0.06);
		transition: transform var(--motion-lift), border-color var(--motion-lift);
	}

	.gallery-wall-card:hover,
	.gallery-wall-card:focus-visible {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--color-accent) 68%, var(--color-border));
	}

	.gallery-wall-card img {
		aspect-ratio: 7 / 5;
		height: 100%;
		width: 100%;
		object-fit: cover;
	}

	.gallery-wall-card-copy {
		display: grid;
		gap: 0.45rem;
		min-width: 0;
		padding: 0.9rem 1rem 1rem;
	}

	.gallery-wall-card-copy p,
	.gallery-wall-card-copy span {
		margin: 0;
		color: var(--color-muted);
	}

	.gallery-wall-card-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}

	.gallery-wall-card-copy p,
	.gallery-wall-card-meta span,
	.gallery-wall-card-footer small {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.gallery-wall-card-meta span {
		border-radius: var(--radius-chip);
		background: color-mix(in srgb, var(--color-accent-soft) 72%, var(--color-surface));
		padding: 0.3rem 0.6rem;
		color: color-mix(in srgb, var(--color-accent) 72%, var(--color-text));
	}

	.gallery-wall-card-copy h2 {
		margin: 0;
		font-size: 1.15rem;
		overflow-wrap: anywhere;
	}

	.gallery-wall-card-copy span {
		font-size: 0.92rem;
		line-height: 1.55;
		text-transform: none;
		letter-spacing: normal;
		overflow-wrap: anywhere;
		color: color-mix(in srgb, var(--color-muted) 92%, var(--color-text));
	}

	.gallery-wall-card-footer {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 0.75rem;
		padding-top: 0.35rem;
	}

	.gallery-wall-card-footer small {
		color: var(--color-muted);
	}
</style>
