---
import { ClientRouter } from 'astro:transitions';
import { FontConfig, SiteLanguage, SiteTitle } from '~/config';

export interface Props {
	title?: string;
	description?: string;
	socialImage?: string;
	rootClass?:
		| Iterable<
				string | Record<string, boolean> | string[] | false | null | undefined
		  >
		| string;
	bodyClass?:
		| Iterable<
				string | Record<string, boolean> | string[] | false | null | undefined
		  >
		| string;
}
const { title, description, socialImage, rootClass, bodyClass } = Astro.props;
const socialImg = new URL(socialImage ?? '/og.png', Astro.url).href;
const fontFaceStyles = `
	@font-face {
		font-family: 'Inter';
		src: url('${FontConfig.sansLatinPath}') format('woff2');
		font-style: normal;
		font-weight: 400;
		font-display: swap;
	}

	@font-face {
		font-family: 'Noto Sans SC';
		src: url('${FontConfig.sansCjkPath}') format('opentype');
		font-style: normal;
		font-weight: 400;
		font-display: swap;
	}
`;
---

<html lang={SiteLanguage} class:list={rootClass}>
	<head>
		<meta charset="utf-8" />
		<link rel="canonical" href={Astro.url.href} />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta http-equiv="x-ua-compatible" content="ie=edge" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="alternate" type="application/rss+xml" title=`${SiteTitle} RSS Feed` href="/rss.xml" />
		<link rel="sitemap" type="application/xml" title=`${SiteTitle} site map` href="/sitemap-index.xml" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:type" content="website" />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImg} />
		<meta property="og:site_name" content={SiteTitle} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url.href} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImg} />
		<ClientRouter />

		<script is:inline>
			// Blocking theme init — runs before first paint to prevent FOUC.
			// Reads from the same localStorage key used by @nanostores/persistent in store.ts.
			(function () {
				try {
					var raw = localStorage.getItem('theme');
					var resolved =
						raw === '"dark"' || raw === '"light"'
							? raw.slice(1, -1)
							: window.matchMedia('(prefers-color-scheme: dark)').matches
								? 'dark'
								: 'light';
					document.documentElement.classList.add(resolved);
				} catch (_) {}
			})();
		</script>

		<style is:global set:html={fontFaceStyles} />
		<style is:global>
			@tailwind base;
			@layer base {
				*:hover,
				*:focus,
				*:active {
					@apply motion-safe:transition;
				}

				:root {
					@apply scroll-smooth antialiased;

					--color-bg: #f5f7fa;
					--color-surface: #ffffff;
					--color-surface-2: #e9edf2;
					--color-text: #2d3436;
					--color-muted: #636e72;
					--color-border: #dfe6e9;
					--color-accent: #4a90e2;
					--color-accent-soft: #e1f0ff;
					--color-shadow-rgb: 74 144 226;
					--radius-shell: 1.9rem;
					--radius-card: 1.3rem;
					--radius-soft: 1rem;
					--radius-button: 0.95rem;
					--radius-chip: 0.8rem;
					--radius-media: 1.05rem;
					--motion-gentle: 260ms cubic-bezier(0.22, 1, 0.36, 1);
					--motion-lift: 320ms cubic-bezier(0.2, 0.9, 0.2, 1);
					--pagefind-ui-scale: 1;
					--pagefind-ui-primary: var(--color-text);
					--pagefind-ui-text: var(--color-muted);
					--pagefind-ui-background: var(--color-surface);
					--pagefind-ui-border: var(--color-border);
					--pagefind-ui-tag: var(--color-surface-2);
					--pagefind-ui-font: inherit;
				}

				:root:is(.dark) {
					--color-bg: #121417;
					--color-surface: #1e2126;
					--color-surface-2: #2c313a;
					--color-text: #e1e6eb;
					--color-muted: #a0a7b1;
					--color-border: #383e4a;
					--color-accent: #5da9ff;
					--color-accent-soft: rgba(93, 169, 255, 0.15);
					--color-shadow-rgb: 93 169 255;
					--pagefind-ui-primary: var(--color-text);
					--pagefind-ui-text: var(--color-muted);
					--pagefind-ui-background: var(--color-surface);
					--pagefind-ui-border: var(--color-border);
					--pagefind-ui-tag: var(--color-surface-2);
				}

				body {
					background:
						radial-gradient(circle at top left, color-mix(in srgb, var(--color-accent-soft) 88%, transparent) 0, transparent 34%),
						radial-gradient(circle at right 12%, color-mix(in srgb, var(--color-surface-2) 78%, transparent) 0, transparent 26%),
						var(--color-bg);
					color: var(--color-text);
					font-family:
						'Inter',
						'Noto Sans SC',
						'PingFang SC',
						'Hiragino Sans GB',
						'Microsoft YaHei',
						'Segoe UI',
						system-ui,
						sans-serif;
				}

				:focus-visible {
					outline: 2px solid color-mix(in srgb, var(--color-accent) 72%, transparent);
					outline-offset: 2px;
				}

				a {
					text-decoration-color: color-mix(in srgb, var(--color-accent) 38%, transparent);
				}

				.ui-type-link {
					display: inline-flex;
					line-height: 1.08;
					text-decoration: none;
					transition:
						color var(--motion-gentle),
						opacity var(--motion-gentle);
				}

				.ui-type-link__text {
					display: inline;
				}

				.ui-type-link::after {
					content: none;
				}

				.ui-type-link:hover,
				.ui-type-link:focus-visible {
					color: var(--color-accent);
				}

				.ui-pressable {
					border-radius: var(--radius-button);
					background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-soft) 8%);
					box-shadow:
						inset 0 1px 0 color-mix(in srgb, var(--color-surface) 82%, transparent),
						inset 0 -1px 0 color-mix(in srgb, var(--color-border) 68%, transparent),
						0 1px 0 color-mix(in srgb, var(--color-bg) 72%, transparent);
					transition:
						transform var(--motion-gentle),
						background var(--motion-gentle),
						color var(--motion-gentle),
						box-shadow var(--motion-gentle),
						opacity var(--motion-gentle);
				}

				.ui-pressable:hover,
				.ui-pressable:focus-visible {
					transform: translateY(1px);
					background: color-mix(in srgb, var(--color-surface-2) 82%, var(--color-accent-soft) 18%);
					box-shadow:
						inset 0 0.2rem 0.55rem rgba(var(--color-shadow-rgb), 0.16),
						inset 0 1px 0 color-mix(in srgb, var(--color-surface) 46%, transparent),
						0 0 0 1px color-mix(in srgb, var(--color-accent) 14%, transparent);
					color: var(--color-accent);
				}

				.ui-pressable.is-active,
				.ui-pressable[aria-current='page'] {
					transform: translateY(1px);
					background: color-mix(in srgb, var(--color-accent) 90%, var(--color-surface));
					box-shadow:
						inset 0 0.26rem 0.7rem rgba(var(--color-shadow-rgb), 0.28),
						inset 0 1px 0 color-mix(in srgb, var(--color-surface) 18%, transparent),
						0 0 0 1px color-mix(in srgb, var(--color-accent) 22%, transparent);
					color: var(--color-surface);
					font-weight: 600;
				}

				::selection {
					background: color-mix(in srgb, var(--color-accent) 24%, var(--color-surface));
					color: var(--color-text);
				}

				.prose pre {
					scrollbar-color: var(--color-border) transparent;
				}
			}

			:root:is(.dark) .astro-code,
			:root:is(.dark) .astro-code span {
				color: var(--shiki-dark) !important;
				background-color: var(--shiki-dark-bg) !important;
				font-style: var(--shiki-dark-font-style) !important;
				font-weight: var(--shiki-dark-font-weight) !important;
				text-decoration: var(--shiki-dark-text-decoration) !important;
			}

			@tailwind components;
			@tailwind utilities;
		</style>
	</head>
	<body class:list={bodyClass}>
		<slot />
	</body>
</html>

