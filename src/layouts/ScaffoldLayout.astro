---
import BackToTop from '~/components/BackToTop.astro';
import Footer from '~/components/Footer.astro';
import Header from '~/components/Header.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
	title?: string;
	description?: string;
	socialImage?: string;
	currentNav?: string;
}
---

<BaseLayout {...Astro.props} rootClass="scrollbar-none" bodyClass="app-body">
	<div class="app-shell">
		<div class="app-panel">
			<Header currentNav={Astro.props.currentNav} />
			<main class="app-main">
				<slot />
			</main>
			<Footer />
		</div>
	</div>
	<BackToTop />
</BaseLayout>

<style>
	:global(.page-heading) {
		display: grid;
		gap: 0.75rem;
		padding: 0.1rem 0 1.4rem;
	}

	:global(.page-title) {
		margin: 0;
		font-size: clamp(2.2rem, 4.6vw, 3.4rem);
		line-height: 1;
		text-wrap: balance;
	}

	:global(.app-body) {
		min-height: 100dvh;
		padding: clamp(1.25rem, 2.5vw, 2.5rem);
	}

	.app-shell {
		margin: 0 auto;
		width: min(100%, 88rem);
	}

	.app-panel {
		display: flex;
		min-height: calc(100dvh - clamp(2.5rem, 5vw, 5rem));
		flex-direction: column;
		border: 1px solid color-mix(
			in srgb,
			var(--color-border) 82%,
			var(--color-accent-soft)
		);
		border-radius: var(--radius-shell);
		background:
			linear-gradient(
				180deg,
				color-mix(
					in srgb,
					var(--color-surface) 92%,
					var(--color-accent-soft) 8%
				),
				color-mix(
					in srgb,
					var(--color-surface) 97%,
					var(--color-surface-2) 3%
				)
			);
		padding: clamp(1.5rem, 3vw, 2.75rem);
		box-shadow:
			0 1.25rem 3rem rgba(var(--color-shadow-rgb), 0.12),
			0 0 0 1px rgba(255, 255, 255, 0.04) inset;
		backdrop-filter: blur(16px);
	}

	.app-main {
		flex: 1;
		padding: clamp(1.5rem, 3vw, 2.75rem) 0 0;
	}

	@media (min-width: 1024px) {
		:global(.app-body) {
			padding: clamp(2rem, 4vw, 3.5rem);
		}

		.app-panel {
			min-height: calc(100dvh - clamp(4rem, 8vw, 7rem));
		}
	}

	@media (max-width: 767px) {
		:global(.app-body) {
			padding: 1rem;
		}

		.app-panel {
			min-height: calc(100dvh - 2rem);
			border-radius: calc(var(--radius-shell) - 0.45rem);
			padding: 1.25rem;
		}

		.app-main {
			padding-top: 1.25rem;
		}
	}
</style>
