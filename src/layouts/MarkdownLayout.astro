---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Comments from '~/components/Comments.astro';
import { Hide, type HideElements } from '~/config';
import type { PostHideElements } from '~/content.config';
import ScaffoldLayout from './ScaffoldLayout.astro';
import 'katex/dist/katex.css';

type Props = CollectionEntry<'posts'>['data'] & {
	currentNav?: string;
	socialImage?: string;
};
const { title, date, lastmod, tags, readingTime, hide } = Astro.props;
const show = (key: string) =>
	!(
		Hide.includes(key as HideElements) ||
		hide?.includes(key as PostHideElements)
	);
const showDate = date && show('date');
const showLastmod = lastmod && show('lastmod');
const showReadingTime = readingTime && show('readingTime');
const showTimes = showDate || showLastmod || showReadingTime;
---

<ScaffoldLayout {...Astro.props}>
	{title && show('title') && <h1 class="post-layout-title">{title}</h1>}
	<div class="post-layout-meta">
		{
			showTimes && (
				<div class="post-layout-times">
					{showDate && (
						<time datetime={date.toISOString()}>
							<Icon name="ri:time-line" class="fill-current" title="date" aria-label="date" />
							{date.toLocaleString()}
						</time>
					)}
					{showLastmod && (
						<time datetime={lastmod.toISOString()}>
							<Icon
								name="ri:history-line"
								class="fill-current"
								title="last modified date"
								aria-label="last modified date"
							/>
							{lastmod.toLocaleString()}
						</time>
					)}
					{showReadingTime && (
						<span>
							<Icon
								name="ri:hourglass-fill"
								class="fill-current"
								title="read time"
								aria-label="read time"
							/>
							{readingTime.text}
						</span>
					)}
				</div>
			)
		}
		{
			tags && show('tags') && (
				<div class="post-layout-tags">
					{tags.map((tag: string) => (
						<a
							class="post-layout-tag"
							href={`/tags/${tag}/1`}
							aria-label={`More posts of tag ${tag}`}
						>
							{tag}
						</a>
					))}
				</div>
			)
		}
	</div>
	<article class="post-prose prose max-w-full dark:prose-invert">
		<slot />
	</article>
	{
		show('comments') && (
			<>
				<hr class="mx-auto my-4 h-px w-48 border-0 bg-[color:var(--color-border)] md:my-10" />
				<Comments />
			</>
		)
	}
</ScaffoldLayout>

<style>
	.post-layout-title {
		margin: 0;
		font-size: clamp(2.75rem, 6vw, 4.5rem);
		line-height: 0.95;
		text-wrap: balance;
	}

	.post-layout-meta {
		margin: 1dvh 0;
		color: var(--color-muted);
	}

	.post-layout-times {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		opacity: 0.8;
	}

	.post-layout-times > * {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.post-layout-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		padding-top: 0.85rem;
	}

	.post-layout-tag {
		display: inline-flex;
		align-items: center;
		border-radius: var(--radius-chip);
		border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 93%, var(--color-accent-soft) 7%);
		padding: 0.34rem 0.75rem;
		font-size: 0.96rem;
		color: var(--color-muted);
		text-decoration: none;
		transition:
			transform var(--motion-gentle),
			border-color var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle);
	}

	.post-layout-tag:hover,
	.post-layout-tag:focus-visible {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 56%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 84%, var(--color-accent-soft) 16%);
		color: var(--color-accent);
	}

	.post-prose :global(h1),
	.post-prose :global(h2),
	.post-prose :global(h3),
	.post-prose :global(h4),
	.post-prose :global(h5),
	.post-prose :global(h6) {
		color: var(--color-text);
	}

	.post-prose :global(strong) {
		color: var(--color-text);
	}

	.post-prose :global(a) {
		color: var(--color-accent);
	}

	.post-prose :global(p) {
		hyphens: auto;
		text-align: justify;
	}

	.post-prose :global(pre) {
		border-radius: 0.5rem;
		background: var(--color-surface-2) !important;
	}

	.post-prose :global(img),
	.post-prose :global(video),
	.post-prose :global(iframe) {
		border-radius: 0.5rem;
	}

	.post-prose :global(p code) {
		border-radius: 0.25rem;
		background: var(--color-surface-2);
		padding: 0.25rem;
	}

	.post-prose :global(p code)::before,
	.post-prose :global(p code)::after {
		content: none;
	}

	@media (min-width: 1024px) {
		.post-layout-meta {
			margin: 3dvh 0;
		}

		.post-layout-times {
			flex-direction: row;
			gap: 1rem;
		}
	}
</style>
<script>
	function setupCopyButtons() {
		const copy = async (copyButton: Element) => {
			const code = copyButton.nextElementSibling?.children[0];
			if (!code) {
				return;
			}
			await navigator.clipboard.writeText(code.textContent ?? '');
			copyButton.setAttribute('aria-pressed', 'true');
			setTimeout(() => {
				copyButton.setAttribute('aria-pressed', 'false');
			}, 700);
		};

		const copyButtons = Array.from(document.querySelectorAll('.prose button.copy'));
		for (const copyButton of copyButtons) {
			copyButton.addEventListener('click', () => copy(copyButton));
		}
	}

	document.addEventListener('astro:page-load', setupCopyButtons);
</script>
